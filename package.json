{
  "name": "json-engine",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "src/packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build:packages": "npm run build --workspaces"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "echarts": "^6.0.0"
  }
}
