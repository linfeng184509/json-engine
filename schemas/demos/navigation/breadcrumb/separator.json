{
  "name": "BreadcrumbSeparatorDemo",
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        {
          "type": "h3",
          "children": ["Breadcrumb Separator"]
        },
        {
          "type": "ABreadcrumb",
          "props": {
            "separator": ">"
          },
          "children": [
            { "type": "ABreadcrumbItem", "children": ["Home"] },
            { "type": "ABreadcrumbItem", "children": [{ "type": "a", "props": { "href": "#" }, "children": ["Application Center"] }] },
            { "type": "ABreadcrumbItem", "children": ["Application List"] }
          ]
        }
      ]
    }
  }
}