{
  "name": "DropdownBasicDemo",
  "state": {
    "visible": {
      "type": "ref",
      "initial": false
    }
  },
  "methods": {
    "handleMenuClick": {
      "$fn": "console.log('click', args[0])"
    }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "ADropdown",
      "children": [
        {
          "type": "template",
          "directives": {
            "vSlot": {
              "name": "default"
            }
          },
          "children": [
            {
              "type": "AButton",
              "children": [
                "Hover me "
              ]
            }
          ]
        },
        {
          "type": "template",
          "directives": {
            "vSlot": {
              "name": "overlay"
            }
          },
          "children": [
            {
              "type": "AMenu",
              "directives": {
                "vOn": {
                  "click": {
                    "$fn": "methods.handleMenuClick(args[0])"
                  }
                }
              },
              "children": [
                {
                  "type": "AMenuItem",
                  "children": [
                    "1st menu item"
                  ]
                },
                {
                  "type": "AMenuItem",
                  "children": [
                    "2nd menu item"
                  ]
                },
                {
                  "type": "AMenuItem",
                  "children": [
                    "3rd menu item"
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  }
}
