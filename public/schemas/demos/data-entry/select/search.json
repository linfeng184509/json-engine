{
  "name": "SelectSearchDemo",
  "state": {
    "searchValue": { "type": "ref", "initial": "" },
    "options": { "type": "ref", "initial": [] }
  },
  "methods": {
    "handleSearch": {
      "$fn": "var val = args[0]; if(val) { state.options = [{value: val, label: val}]; } else { state.options = []; }"
    }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        {
          "type": "h3",
          "props": { "style": "margin-bottom:16px" },
          "children": ["Select Search"]
        },
        {
          "type": "ASpace",
          "props": { "direction": "vertical", "size": 12 },
          "children": [
            {
              "type": "ASelect",
              "props": {
                "showSearch": true,
                "placeholder": "Search and select",
                "filterOption": false,
                "options": { "$expr": "$state.options" }
              },
              "directives": {
                "vOn": {
                  "search": { "$fn": "methods.handleSearch(args[0]);" }
                }
              }
            },
            {
              "type": "ASelect",
              "props": {
                "showSearch": true,
                "placeholder": "Search with filter",
                "options": [
                  { "value": "apple", "label": "Apple" },
                  { "value": "banana", "label": "Banana" },
                  { "value": "orange", "label": "Orange" },
                  { "value": "pear", "label": "Pear" }
                ]
              }
            }
          ]
        }
      ]
    }
  }
}