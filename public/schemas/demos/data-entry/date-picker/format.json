{
  "name": "DatePickerFormatDemo",
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        {
          "type": "h3",
          "children": ["DatePicker Format"]
        },
        {
          "type": "ASpace",
          "props": { "direction": "vertical" },
          "children": [
            { "type": "ADatePicker", "props": { "format": "YYYY-MM-DD", "placeholder": "YYYY-MM-DD" } },
            { "type": "ADatePicker", "props": { "format": "DD/MM/YYYY", "placeholder": "DD/MM/YYYY" } },
            { "type": "ADatePicker", "props": { "format": "YYYY年MM月DD日", "placeholder": "YYYY年MM月DD日" } }
          ]
        }
      ]
    }
  }
}