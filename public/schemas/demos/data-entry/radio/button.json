{
  "name": "RadioButtonDemo",
  "state": {
    "value1": { "type": "ref", "initial": "a" },
    "value2": { "type": "ref", "initial": "a" },
    "value3": { "type": "ref", "initial": "a" }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        {
          "type": "div",
          "children": [
            {
              "type": "ARadioGroup",
              "directives": {
                "vModel": {
                  "prop": { "_type": "reference", "prefix": "state", "variable": "value1" },
                  "arg": "value"
                }
              },
              "children": [
                { "type": "ARadioButton", "props": { "value": "a" }, "children": ["Hangzhou"] },
                { "type": "ARadioButton", "props": { "value": "b" }, "children": ["Shanghai"] },
                { "type": "ARadioButton", "props": { "value": "c" }, "children": ["Beijing"] },
                { "type": "ARadioButton", "props": { "value": "d" }, "children": ["Chengdu"] }
              ]
            }
          ]
        },
        {
          "type": "div",
          "props": { "style": "margin-top:16px" },
          "children": [
            {
              "type": "ARadioGroup",
              "directives": {
                "vModel": {
                  "prop": { "_type": "reference", "prefix": "state", "variable": "value2" },
                  "arg": "value"
                }
              },
              "children": [
                { "type": "ARadioButton", "props": { "value": "a" }, "children": ["Hangzhou"] },
                { "type": "ARadioButton", "props": { "value": "b", "disabled": true }, "children": ["Shanghai"] },
                { "type": "ARadioButton", "props": { "value": "c" }, "children": ["Beijing"] },
                { "type": "ARadioButton", "props": { "value": "d" }, "children": ["Chengdu"] }
              ]
            }
          ]
        },
        {
          "type": "div",
          "props": { "style": "margin-top:16px" },
          "children": [
            {
              "type": "ARadioGroup",
              "props": { "disabled": true },
              "directives": {
                "vModel": {
                  "prop": { "_type": "reference", "prefix": "state", "variable": "value3" },
                  "arg": "value"
                }
              },
              "children": [
                { "type": "ARadioButton", "props": { "value": "a" }, "children": ["Hangzhou"] },
                { "type": "ARadioButton", "props": { "value": "b" }, "children": ["Shanghai"] },
                { "type": "ARadioButton", "props": { "value": "c" }, "children": ["Beijing"] },
                { "type": "ARadioButton", "props": { "value": "d" }, "children": ["Chengdu"] }
              ]
            }
          ]
        }
      ]
    }
  }
}
