{
  "name": "ProgressDynamicDemo",
  "state": {
    "defaultPercent": { "type": "ref", "initial": 0 }
  },
  "methods": {
    "increase": { "$fn": "var p = state.defaultPercent + 10; state.defaultPercent = p > 100 ? 100 : p;" },
    "decline": { "$fn": "var p = state.defaultPercent - 10; state.defaultPercent = p < 0 ? 0 : p;" }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        { "type": "AProgress", "props": { "percent": { "$expr": "$state.defaultPercent" } } },
        {
          "type": "AButtonGroup",
          "children": [
            {
              "type": "AButton",
              "directives": { "vOn": { "click": { "$fn": "methods.decline();" } } },
              "children": [
                { "type": "MinusOutlined", "directives": { "vSlot": { "name": "icon" } } }
              ]
            },
            {
              "type": "AButton",
              "directives": { "vOn": { "click": { "$fn": "methods.increase();" } } },
              "children": [
                { "type": "PlusOutlined", "directives": { "vSlot": { "name": "icon" } } }
              ]
            }
          ]
        }
      ]
    }
  }
}
