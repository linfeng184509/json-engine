{
  "name": "MessageTypeDemo",
  "methods": {
    "success": {
      "$fn": "$_core.antd.message.success('This is a success message')"
    },
    "error": {
      "$fn": "$_core.antd.message.error('This is an error message')"
    },
    "warning": {
      "$fn": "$_core.antd.message.warning('This is a warning message')"
    }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "ASpace",
      "children": [
        {
          "type": "AButton",
          "directives": {
            "vOn": {
              "click": {
                "$fn": "methods.success()"
              }
            }
          },
          "children": [
            "Success"
          ]
        },
        {
          "type": "AButton",
          "directives": {
            "vOn": {
              "click": {
                "$fn": "methods.error()"
              }
            }
          },
          "children": [
            "Error"
          ]
        },
        {
          "type": "AButton",
          "directives": {
            "vOn": {
              "click": {
                "$fn": "methods.warning()"
              }
            }
          },
          "children": [
            "Warning"
          ]
        }
      ]
    }
  }
}
