{
  "name": "MessageLoadingDemo",
  "methods": {
    "success": {
      "$fn": "var hide = $_core.antd.message.loading('Action in progress..', 0); setTimeout(hide, 2500);"
    }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "AButton",
      "directives": {
        "vOn": {
          "click": {
            "$fn": "methods.success()"
          }
        }
      },
      "children": [
        "Display a loading indicator"
      ]
    }
  }
}
