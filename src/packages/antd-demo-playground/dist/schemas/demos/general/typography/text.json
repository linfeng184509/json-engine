{
  "name": "TypographyTextDemo",
  "render": {
    "type": "template",
    "content": {
      "type": "ASpace",
      "props": { "direction": "vertical" },
      "children": [
        { "type": "ATypographyText", "children": ["Ant Design Vue (default)"] },
        { "type": "ATypographyText", "props": { "type": "secondary" }, "children": ["Ant Design Vue (secondary)"] },
        { "type": "ATypographyText", "props": { "type": "success" }, "children": ["Ant Design Vue (success)"] },
        { "type": "ATypographyText", "props": { "type": "warning" }, "children": ["Ant Design Vue (warning)"] },
        { "type": "ATypographyText", "props": { "type": "danger" }, "children": ["Ant Design Vue (danger)"] },
        { "type": "ATypographyText", "props": { "disabled": true }, "children": ["Ant Design Vue (disabled)"] },
        { "type": "ATypographyText", "props": { "mark": true }, "children": ["Ant Design Vue (mark)"] },
        { "type": "ATypographyText", "props": { "code": true }, "children": ["Ant Design Vue (code)"] },
        { "type": "ATypographyText", "props": { "keyboard": true }, "children": ["Ant Design Vue (keyboard)"] },
        { "type": "ATypographyText", "props": { "underline": true }, "children": ["Ant Design Vue (underline)"] },
        { "type": "ATypographyText", "props": { "delete": true }, "children": ["Ant Design Vue (delete)"] },
        { "type": "ATypographyText", "props": { "strong": true }, "children": ["Ant Design Vue (strong)"] },
        { "type": "ATypographyLink", "props": { "href": "https://antdv.com", "target": "_blank" }, "children": ["Ant Design Vue (Link)"] }
      ]
    }
  }
}
