{
  "name": "NotificationPlacementDemo",
  "methods": {
    "openTop": {
      "$fn": "$_core.antd.notification.open({ message: 'Notification top', description: 'This is the content of the notification. This is the content of the notification. This is the content of the notification.', placement: 'top' })"
    },
    "openBottom": {
      "$fn": "$_core.antd.notification.open({ message: 'Notification bottom', description: 'This is the content of the notification. This is the content of the notification. This is the content of the notification.', placement: 'bottom' })"
    },
    "openTopLeft": {
      "$fn": "$_core.antd.notification.open({ message: 'Notification topLeft', description: 'This is the content of the notification. This is the content of the notification. This is the content of the notification.', placement: 'topLeft' })"
    },
    "openTopRight": {
      "$fn": "$_core.antd.notification.open({ message: 'Notification topRight', description: 'This is the content of the notification. This is the content of the notification. This is the content of the notification.', placement: 'topRight' })"
    },
    "openBottomLeft": {
      "$fn": "$_core.antd.notification.open({ message: 'Notification bottomLeft', description: 'This is the content of the notification. This is the content of the notification. This is the content of the notification.', placement: 'bottomLeft' })"
    },
    "openBottomRight": {
      "$fn": "$_core.antd.notification.open({ message: 'Notification bottomRight', description: 'This is the content of the notification. This is the content of the notification. This is the content of the notification.', placement: 'bottomRight' })"
    }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        {
          "type": "AButton",
          "props": {
            "type": "primary"
          },
          "directives": {
            "vOn": {
              "click": {
                "$fn": "methods.openTop()"
              }
            }
          },
          "children": [
            {
              "type": "BorderTopOutlined",
              "directives": {
                "vSlot": {
                  "name": "icon"
                }
              }
            },
            "top"
          ]
        },
        {
          "type": "AButton",
          "props": {
            "type": "primary"
          },
          "directives": {
            "vOn": {
              "click": {
                "$fn": "methods.openBottom()"
              }
            }
          },
          "children": [
            {
              "type": "BorderBottomOutlined",
              "directives": {
                "vSlot": {
                  "name": "icon"
                }
              }
            },
            "bottom"
          ]
        },
        {
          "type": "AButton",
          "props": {
            "type": "primary"
          },
          "directives": {
            "vOn": {
              "click": {
                "$fn": "methods.openTopLeft()"
              }
            }
          },
          "children": [
            {
              "type": "RadiusUpleftOutlined",
              "directives": {
                "vSlot": {
                  "name": "icon"
                }
              }
            },
            "topLeft"
          ]
        },
        {
          "type": "AButton",
          "props": {
            "type": "primary"
          },
          "directives": {
            "vOn": {
              "click": {
                "$fn": "methods.openTopRight()"
              }
            }
          },
          "children": [
            {
              "type": "RadiusUprightOutlined",
              "directives": {
                "vSlot": {
                  "name": "icon"
                }
              }
            },
            "topRight"
          ]
        },
        {
          "type": "ADivider"
        },
        {
          "type": "AButton",
          "props": {
            "type": "primary"
          },
          "directives": {
            "vOn": {
              "click": {
                "$fn": "methods.openBottomLeft()"
              }
            }
          },
          "children": [
            {
              "type": "RadiusBottomleftOutlined",
              "directives": {
                "vSlot": {
                  "name": "icon"
                }
              }
            },
            "bottomLeft"
          ]
        },
        {
          "type": "AButton",
          "props": {
            "type": "primary"
          },
          "directives": {
            "vOn": {
              "click": {
                "$fn": "methods.openBottomRight()"
              }
            }
          },
          "children": [
            {
              "type": "RadiusBottomrightOutlined",
              "directives": {
                "vSlot": {
                  "name": "icon"
                }
              }
            },
            "bottomRight"
          ]
        }
      ]
    }
  }
}
