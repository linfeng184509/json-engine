{
  "name": "DrawerBasicDemo",
  "state": {
    "open": { "type": "ref", "initial": false }
  },
  "methods": {
    "showDrawer": { "$fn": "state.open = true;" },
    "onClose": { "$fn": "state.open = false;" }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        { "type": "AButton", "props": { "type": "primary" }, "directives": { "vOn": { "click": { "$fn": "methods.showDrawer();" } } }, "children": ["Open"] },
        { "type": "ADrawer", "props": { "title": "Basic Drawer", "open": { "$expr": "$state.open" }, "onClose": { "$fn": "methods.onClose();" } }, "children": [
          { "type": "p", "children": ["Some contents..."] },
          { "type": "p", "children": ["Some contents..."] },
          { "type": "p", "children": ["Some contents..."] }
        ]}
      ]
    }
  }
}