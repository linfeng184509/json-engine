{
  "name": "DrawerPlacementDemo",
  "state": {
    "visible": { "type": "ref", "initial": false },
    "placement": { "type": "ref", "initial": "right" }
  },
  "methods": {
    "showDrawer": {
      "$fn": "state.placement = args[0]; state.visible = true;"
    },
    "closeDrawer": {
      "$fn": "state.visible = false;"
    }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        {
          "type": "h3",
          "children": ["Drawer Placement"]
        },
        {
          "type": "ASpace",
          "children": [
            {
              "type": "AButton",
              "directives": {
                "vOn": {
                  "click": { "$fn": "methods.showDrawer('left');" }
                }
              },
              "children": ["Left"]
            },
            {
              "type": "AButton",
              "directives": {
                "vOn": {
                  "click": { "$fn": "methods.showDrawer('right');" }
                }
              },
              "children": ["Right"]
            },
            {
              "type": "AButton",
              "directives": {
                "vOn": {
                  "click": { "$fn": "methods.showDrawer('top');" }
                }
              },
              "children": ["Top"]
            },
            {
              "type": "AButton",
              "directives": {
                "vOn": {
                  "click": { "$fn": "methods.showDrawer('bottom');" }
                }
              },
              "children": ["Bottom"]
            }
          ]
        },
        {
          "type": "ADrawer",
          "props": {
            "open": { "$expr": "$state.visible" },
            "placement": { "$expr": "$state.placement" },
            "title": "Drawer",
            "onClose": { "$fn": "methods.closeDrawer();" }
          },
          "children": [
            { "type": "p", "children": ["Drawer content..."] }
          ]
        }
      ]
    }
  }
}