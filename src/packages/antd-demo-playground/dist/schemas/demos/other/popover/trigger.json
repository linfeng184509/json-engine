{
  "name": "PopoverTriggerDemo",
  "state": {
    "visible": { "type": "ref", "initial": false }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        {
          "type": "h3",
          "children": ["Popover Trigger"]
        },
        {
          "type": "ASpace",
          "children": [
            {
              "type": "APopover",
              "props": {
                "content": "Hover trigger",
                "title": "Title",
                "trigger": "hover"
              },
              "children": [
                { "type": "AButton", "children": ["Hover me"] }
              ]
            },
            {
              "type": "APopover",
              "props": {
                "content": "Click trigger",
                "title": "Title",
                "trigger": "click"
              },
              "children": [
                { "type": "AButton", "children": ["Click me"] }
              ]
            },
            {
              "type": "APopover",
              "props": {
                "content": "Focus trigger",
                "title": "Title",
                "trigger": "focus"
              },
              "children": [
                { "type": "AButton", "children": ["Focus me"] }
              ]
            }
          ]
        }
      ]
    }
  }
}