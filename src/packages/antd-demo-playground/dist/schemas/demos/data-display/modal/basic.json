{
  "name": "ModalBasicDemo",
  "state": {
    "open": { "type": "ref", "initial": false }
  },
  "methods": {
    "showModal": {
      "$fn": "state.open = true;"
    },
    "handleOk": {
      "$fn": "state.open = false;"
    },
    "handleCancel": {
      "$fn": "state.open = false;"
    }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        { 
          "type": "AButton", 
          "props": { "type": "primary" }, 
          "directives": { "vOn": { "click": { "$fn": "methods.showModal();" } } },
          "children": ["Open Modal"]
        },
        {
          "type": "AModal",
          "props": {
            "title": "Basic Modal",
            "open": { "$expr": "$state.open" }
          },
          "directives": {
            "vOn": {
              "ok": { "$fn": "methods.handleOk();" },
              "cancel": { "$fn": "methods.handleCancel();" }
            }
          },
          "children": [
            { "type": "p", "children": ["Some contents..."] },
            { "type": "p", "children": ["Some contents..."] },
            { "type": "p", "children": ["Some contents..."] }
          ]
        }
      ]
    }
  }
}