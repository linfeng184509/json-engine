{
  "name": "BadgeBasicDemo",
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        {
          "type": "ABadge",
          "props": { "count": 5 },
          "children": [{ "type": "AAvatar", "props": { "shape": "square", "size": "large" } }]
        },
        {
          "type": "ABadge",
          "props": { "count": 0, "showZero": true },
          "children": [{ "type": "AAvatar", "props": { "shape": "square", "size": "large" } }]
        },
        {
          "type": "ABadge",
          "children": [
            { "type": "ClockCircleOutlined", "props": { "style": "color:#f5222d" }, "directives": { "vSlot": { "name": "count" } } },
            { "type": "AAvatar", "props": { "shape": "square", "size": "large" } }
          ]
        }
      ]
    }
  }
}
