{
  "name": "InputAddonDemo",
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        {
          "type": "h3",
          "props": { "style": "margin-bottom:16px" },
          "children": ["Input with Addon"]
        },
        {
          "type": "ASpace",
          "props": { "direction": "vertical", "size": 12 },
          "children": [
            { "type": "AInput", "props": { "addonBefore": "http://", "addonAfter": ".com", "placeholder": "website" } },
            { "type": "AInput", "props": { "addonBefore": "$", "addonAfter": "USD", "placeholder": "price" } },
            {
              "type": "AInputGroup",
              "props": { "compact": true },
              "children": [
                { "type": "AInput", "props": { "addonBefore": "From", "style": "width:calc(50% - 80px)" } },
                { "type": "AInput", "props": { "addonBefore": "To", "style": "width:50%" } }
              ]
            }
          ]
        }
      ]
    }
  }
}