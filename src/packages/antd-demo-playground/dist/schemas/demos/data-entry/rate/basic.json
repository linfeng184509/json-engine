{
  "name": "RateBasicDemo",
  "state": {
    "value": { "type": "ref", "initial": 2 }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "ARate",
      "props": {
        "value": { "$expr": "$state.value" }
      },
      "directives": {
        "vOn": {
          "update:value": { "$fn": "state.value = args[0];" }
        }
      }
    }
  }
}