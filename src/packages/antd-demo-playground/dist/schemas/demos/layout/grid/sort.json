{
  "name": "GridSortDemo",
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        {
          "type": "h3",
          "children": ["Grid Sort"]
        },
        {
          "type": "ARow",
          "props": { "gutter": 16 },
          "children": [
            { "type": "ACol", "props": { "span": 6, "push": 18 }, "children": [{ "type": "div", "props": { "class": "grid-box" }, "children": ["col-6 push-18"] }] },
            { "type": "ACol", "props": { "span": 6, "pull": 6 }, "children": [{ "type": "div", "props": { "class": "grid-box" }, "children": ["col-6 pull-6"] }] },
            { "type": "ACol", "props": { "span": 6, "push": 6 }, "children": [{ "type": "div", "props": { "class": "grid-box" }, "children": ["col-6 push-6"] }] },
            { "type": "ACol", "props": { "span": 6 }, "children": [{ "type": "div", "props": { "class": "grid-box" }, "children": ["col-6"] }] }
          ]
        }
      ]
    }
  }
}