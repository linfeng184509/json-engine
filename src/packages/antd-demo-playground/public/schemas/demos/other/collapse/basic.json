{
  "name": "CollapseBasicDemo",
  "state": {
    "activeKey": { "type": "ref", "initial": ["1"] },
    "text": { "type": "ref", "initial": "A dog is a type of domesticated animal. Known for its loyalty and faithfulness, it can be found as a welcome guest in many households across the world." }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "ACollapse",
      "directives": {
        "vModel": {
          "prop": { "$ref": "state.activeKey" },
          "arg": "activeKey"
        }
      },
      "children": [
        { "type": "ACollapsePanel", "props": { "key": "1", "header": "This is panel header 1" }, "children": [{ "type": "p", "children": [{ "$expr": "$state.text" }] }] },
        { "type": "ACollapsePanel", "props": { "key": "2", "header": "This is panel header 2" }, "children": [{ "type": "p", "children": [{ "$expr": "$state.text" }] }] },
        { "type": "ACollapsePanel", "props": { "key": "3", "header": "This is panel header 3", "collapsible": "disabled" }, "children": [{ "type": "p", "children": [{ "$expr": "$state.text" }] }] }
      ]
    }
  }
}
