{
  "name": "DrawerPlacementDemo",
  "state": {
    "visible": { "type": "ref", "initial": false },
    "placement": { "type": "ref", "initial": "right" }
  },
  "methods": {
    "showDrawer": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{ref_state_placement = args[0]; ref_state_visible = true}}"
    },
    "closeDrawer": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{ref_state_visible = false}}"
    }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        {
          "type": "h3",
          "children": ["Drawer Placement"]
        },
        {
          "type": "ASpace",
          "children": [
            {
              "type": "AButton",
              "directives": {
                "vOn": {
                  "click": { "type": "function", "params": "{{{}}}", "body": "{{methods.showDrawer('left')}}" }
                }
              },
              "children": ["Left"]
            },
            {
              "type": "AButton",
              "directives": {
                "vOn": {
                  "click": { "type": "function", "params": "{{{}}}", "body": "{{methods.showDrawer('right')}}" }
                }
              },
              "children": ["Right"]
            },
            {
              "type": "AButton",
              "directives": {
                "vOn": {
                  "click": { "type": "function", "params": "{{{}}}", "body": "{{methods.showDrawer('top')}}" }
                }
              },
              "children": ["Top"]
            },
            {
              "type": "AButton",
              "directives": {
                "vOn": {
                  "click": { "type": "function", "params": "{{{}}}", "body": "{{methods.showDrawer('bottom')}}" }
                }
              },
              "children": ["Bottom"]
            }
          ]
        },
        {
          "type": "ADrawer",
          "props": {
            "open": { "type": "expression", "body": "{{ref_state_visible}}" },
            "placement": { "type": "expression", "body": "{{ref_state_placement}}" },
            "title": "Drawer",
            "onClose": { "type": "function", "params": "{{{}}}", "body": "{{methods.closeDrawer()}}" }
          },
          "children": [
            { "type": "p", "children": ["Drawer content..."] }
          ]
        }
      ]
    }
  }
}