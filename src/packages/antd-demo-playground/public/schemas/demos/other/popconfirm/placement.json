{
  "name": "PopconfirmPlacementDemo",
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        {
          "type": "h3",
          "children": ["Popconfirm Placement"]
        },
        {
          "type": "ASpace",
          "children": [
            {
              "type": "APopconfirm",
              "props": {
                "title": "Are you sure?",
                "placement": "top"
              },
              "children": [
                { "type": "AButton", "children": ["Top"] }
              ]
            },
            {
              "type": "APopconfirm",
              "props": {
                "title": "Are you sure?",
                "placement": "left"
              },
              "children": [
                { "type": "AButton", "children": ["Left"] }
              ]
            },
            {
              "type": "APopconfirm",
              "props": {
                "title": "Are you sure?",
                "placement": "right"
              },
              "children": [
                { "type": "AButton", "children": ["Right"] }
              ]
            },
            {
              "type": "APopconfirm",
              "props": {
                "title": "Are you sure?",
                "placement": "bottom"
              },
              "children": [
                { "type": "AButton", "children": ["Bottom"] }
              ]
            }
          ]
        }
      ]
    }
  }
}