{
  "name": "ButtonBlockDemo",
  "render": {
    "type": "template",
    "content": {
      "type": "ASpace",
      "props": { "wrap": true },
      "children": [
        { "type": "AButton", "props": { "type": "primary", "block": true }, "children": ["Primary"] },
        { "type": "AButton", "props": { "block": true }, "children": ["Default"] },
        { "type": "AButton", "props": { "type": "dashed", "block": true }, "children": ["Dashed"] },
        { "type": "AButton", "props": { "danger": true, "block": true }, "children": ["Danger"] },
        { "type": "AButton", "props": { "type": "link", "block": true }, "children": ["Link"] }
      ]
    }
  }
}
