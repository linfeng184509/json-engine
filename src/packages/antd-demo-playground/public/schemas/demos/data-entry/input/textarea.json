{
  "name": "InputTextareaDemo",
  "state": {
    "textareaValue": { "type": "ref", "initial": "" }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        {
          "type": "h3",
          "props": { "style": "margin-bottom:16px" },
          "children": ["Input TextArea"]
        },
        {
          "type": "ASpace",
          "props": { "direction": "vertical", "size": 12 },
          "children": [
            { "type": "ATextarea", "props": { "placeholder": "Basic textarea", "rows": 4 } },
            { "type": "ATextarea", "props": { "placeholder": "Textarea with autosize", "autoSize": true } },
            { "type": "ATextarea", "props": { "placeholder": "Textarea with min/max rows", "autoSize": { "minRows": 2, "maxRows": 6 } } },
            { "type": "ATextarea", "props": { "placeholder": "Textarea with maxLength", "maxLength": 100, "showCount": true } }
          ]
        }
      ]
    }
  }
}