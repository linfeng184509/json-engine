{
  "name": "InputBasicDemo",
  "state": {
    "value": { "type": "ref", "initial": "" },
    "value1": { "type": "ref", "initial": "" }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "ASpace",
      "props": { "direction": "vertical" },
      "children": [
        {
          "type": "AInput",
          "props": { "placeholder": "Basic usage" },
          "directives": {
            "vModel": {
              "prop": { "_type": "reference", "prefix": "state", "variable": "value" },
              "arg": "value"
            }
          }
        },
        {
          "type": "AInput",
          "props": { "placeholder": "Lazy usage", "autofocus": true },
          "directives": {
            "vModel": {
              "prop": { "_type": "reference", "prefix": "state", "variable": "value1" },
              "arg": "value"
            }
          }
        }
      ]
    }
  }
}
