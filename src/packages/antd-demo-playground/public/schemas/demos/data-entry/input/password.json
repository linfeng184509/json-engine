{
  "name": "InputPasswordDemo",
  "state": {
    "value": { "type": "ref", "initial": "" },
    "value2": { "type": "ref", "initial": "" },
    "value3": { "type": "ref", "initial": "" },
    "value4": { "type": "ref", "initial": "" },
    "visible": { "type": "ref", "initial": true }
  },
  "methods": {
    "toggleVisible": { "type": "function", "params": "{{{}}}", "body": "{{ref_state_visible.value = !ref_state_visible.value}}" }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "ASpace",
      "props": { "direction": "vertical", "size": "middle", "style": "width:100%" },
      "children": [
        {
          "type": "AInputPassword",
          "props": { "placeholder": "input password" },
          "directives": {
            "vModel": {
              "prop": { "_type": "reference", "prefix": "state", "variable": "value" },
              "arg": "value"
            }
          }
        },
        {
          "type": "AInputPassword",
          "props": { "placeholder": "input password" },
          "children": [
            {
              "type": "EyeTwoTone",
              "directives": { "vSlot": { "name": "iconRender", "props": ["v"] } },
              "directives": { "vIf": { "type": "expression", "body": "{{v}}" } }
            },
            {
              "type": "EyeInvisibleOutlined",
              "directives": { "vSlot": { "name": "iconRender", "props": ["v"] } },
              "directives": { "vIf": { "type": "expression", "body": "{{!v}}" } }
            }
          ]
        },
        {
          "type": "AInputPassword",
          "props": { "placeholder": "input password", "visibilityToggle": false },
          "directives": {
            "vModel": {
              "prop": { "_type": "reference", "prefix": "state", "variable": "value3" },
              "arg": "value"
            }
          }
        },
        {
          "type": "ASpace",
          "children": [
            {
              "type": "AInputPassword",
              "props": { "placeholder": "input password" },
              "directives": {
                "vModel": {
                  "prop": { "_type": "reference", "prefix": "state", "variable": "value4" },
                  "arg": "value"
                }
              }
            },
            {
              "type": "AButton",
              "directives": { "vOn": { "click": { "type": "function", "params": "{{{}}}", "body": "{{methods.toggleVisible()}}" } } },
              "children": [{ "type": "expression", "body": "{{ref_state_visible.value ? 'Hide' : 'Show'}}" }]
            }
          ]
        }
      ]
    }
  }
}
