{
  "name": "SwitchSizeDemo",
  "state": {
    "checked1": { "type": "ref", "initial": true },
    "checked2": { "type": "ref", "initial": false }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "ASpace",
      "props": { "direction": "vertical" },
      "children": [
        {
          "type": "ASwitch",
          "directives": {
            "vModel": {
              "prop": { "$ref": "state.checked1" },
              "arg": "checked"
            }
          }
        },
        {
          "type": "ASwitch",
          "props": { "size": "small" },
          "directives": {
            "vModel": {
              "prop": { "$ref": "state.checked2" },
              "arg": "checked"
            }
          }
        }
      ]
    }
  }
}
