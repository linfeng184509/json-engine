{
  "name": "TimePickerBasicDemo",
  "state": {
    "value": { "type": "ref", "initial": null },
    "strValue": { "type": "ref", "initial": "09:00:00" }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "ASpace",
      "props": { "direction": "vertical" },
      "children": [
        {
          "type": "ATimePicker",
          "directives": {
            "vModel": {
              "prop": { "_type": "reference", "prefix": "state", "variable": "value" },
              "arg": "value"
            }
          }
        },
        {
          "type": "ATimePicker",
          "props": { "valueFormat": "HH:mm:ss" },
          "directives": {
            "vModel": {
              "prop": { "_type": "reference", "prefix": "state", "variable": "strValue" },
              "arg": "value"
            }
          }
        }
      ]
    }
  }
}
