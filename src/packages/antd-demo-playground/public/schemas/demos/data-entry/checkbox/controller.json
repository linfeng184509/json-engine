{
  "name": "CheckboxControllerDemo",
  "state": {
    "checked": { "type": "ref", "initial": false },
    "disabled": { "type": "ref", "initial": false }
  },
  "computed": {
    "label": {
      "type": "computed",
      "body": "{{(ref_state_checked.value ? 'Checked' : 'Unchecked') + '-' + (ref_state_disabled.value ? 'Disabled' : 'Enabled')}}"
    }
  },
  "methods": {
    "toggleChecked": { "type": "function", "params": "{{{}}}", "body": "{{ref_state_checked.value = !ref_state_checked.value}}" },
    "toggleDisable": { "type": "function", "params": "{{{}}}", "body": "{{ref_state_disabled.value = !ref_state_disabled.value}}" }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        {
          "type": "p",
          "props": { "style": "margin-bottom:20px" },
          "children": [
            {
              "type": "ACheckbox",
              "directives": {
                "vModel": {
                  "prop": { "_type": "reference", "prefix": "state", "variable": "checked" },
                  "arg": "checked"
                }
              },
              "props": {
                "disabled": { "type": "expression", "body": "{{ref_state_disabled}}" }
              },
              "children": [{ "type": "expression", "body": "{{ref_computed_label}}" }]
            }
          ]
        },
        {
          "type": "p",
          "children": [
            {
              "type": "AButton",
              "props": { "type": "primary", "size": "small" },
              "directives": { "vOn": { "click": { "type": "function", "params": "{{{}}}", "body": "{{methods.toggleChecked()}}" } } },
              "children": [{ "type": "expression", "body": "{{!ref_state_checked.value ? 'Check' : 'Uncheck'}}" }]
            },
            {
              "type": "AButton",
              "props": { "type": "primary", "size": "small", "style": "margin-left:10px" },
              "directives": { "vOn": { "click": { "type": "function", "params": "{{{}}}", "body": "{{methods.toggleDisable()}}" } } },
              "children": [{ "type": "expression", "body": "{{!ref_state_disabled.value ? 'Disable' : 'Enable'}}" }]
            }
          ]
        }
      ]
    }
  }
}
