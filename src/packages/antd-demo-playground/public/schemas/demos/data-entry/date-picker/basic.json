{
  "name": "DatePickerBasicDemo",
  "state": {
    "value1": { "type": "ref", "initial": null },
    "value2": { "type": "ref", "initial": null },
    "value3": { "type": "ref", "initial": null },
    "value4": { "type": "ref", "initial": null },
    "value5": { "type": "ref", "initial": null }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "ASpace",
      "props": { "direction": "vertical", "size": 12 },
      "children": [
        {
          "type": "ADatePicker",
          "directives": {
            "vModel": {
              "prop": { "_type": "reference", "prefix": "state", "variable": "value1" },
              "arg": "value"
            }
          }
        },
        {
          "type": "ADatePicker",
          "props": { "picker": "week" },
          "directives": {
            "vModel": {
              "prop": { "_type": "reference", "prefix": "state", "variable": "value2" },
              "arg": "value"
            }
          }
        },
        {
          "type": "ADatePicker",
          "props": { "picker": "month" },
          "directives": {
            "vModel": {
              "prop": { "_type": "reference", "prefix": "state", "variable": "value3" },
              "arg": "value"
            }
          }
        },
        {
          "type": "ADatePicker",
          "props": { "picker": "quarter" },
          "directives": {
            "vModel": {
              "prop": { "_type": "reference", "prefix": "state", "variable": "value4" },
              "arg": "value"
            }
          }
        },
        {
          "type": "ADatePicker",
          "props": { "picker": "year" },
          "directives": {
            "vModel": {
              "prop": { "_type": "reference", "prefix": "state", "variable": "value5" },
              "arg": "value"
            }
          }
        }
      ]
    }
  }
}
