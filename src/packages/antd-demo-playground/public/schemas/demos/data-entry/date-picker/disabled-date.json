{
  "name": "DatePickerDisabledDateDemo",
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        {
          "type": "h3",
          "children": ["DatePicker Disabled Date"]
        },
        {
          "type": "ADatePicker",
          "props": {
            "placeholder": "Select date",
            "disabledDate": "function(current){return current && current < Date.now() - 86400000}"
          }
        }
      ]
    }
  }
}