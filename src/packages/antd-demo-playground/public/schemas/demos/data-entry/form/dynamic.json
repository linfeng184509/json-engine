{
  "name": "FormDynamicDemo",
  "state": {
    "items": { "type": "ref", "initial": [{ "id": 1, "name": "" }] }
  },
  "methods": {
    "addItem": {
      "$fn": "state.items.push({id: Date.now(), name: ''});"
    },
    "removeItem": {
      "$fn": "var id = args[0]; state.items = state.items.filter(item => item.id !== id);"
    }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        {
          "type": "h3",
          "props": { "style": "margin-bottom:16px" },
          "children": ["Dynamic Form Items"]
        },
        {
          "type": "AForm",
          "props": {
            "labelCol": { "span": 4 },
            "wrapperCol": { "span": 18 }
          },
          "children": [
            {
              "type": "template",
              "directives": {
                "vFor": {
                  "value": { "$expr": "$state.items" },
                  "key": "id"
                }
              },
              "children": [
                {
                  "type": "ASpace",
                  "props": { "style": "display:flex;margin-bottom:8px" },
                  "children": [
                    {
                      "type": "AInput",
                      "props": { "placeholder": "Item name", "style": "width:300px" }
                    },
                    {
                      "type": "AButton",
                      "props": { "type": "dashed", "danger": true },
                      "directives": {
                        "vOn": {
                          "click": { "$fn": "methods.removeItem(scope.item.id);" }
                        }
                      },
                      "children": ["Remove"]
                    }
                  ]
                }
              ]
            },
            {
              "type": "AFormItem",
              "children": [
                {
                  "type": "AButton",
                  "props": { "type": "dashed" },
                  "directives": {
                    "vOn": {
                      "click": { "$fn": "methods.addItem();" }
                    }
                  },
                  "children": [
                    { "type": "PlusOutlined" },
                    "type": "span",
                    "children": [" Add Item"]
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  }
}