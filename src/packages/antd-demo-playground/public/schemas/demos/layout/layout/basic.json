{
  "name": "LayoutBasicDemo",
  "state": {
    "collapsed": { "type": "ref", "initial": false }
  },
  "methods": {
    "toggle": { "$fn": "state.collapsed = !state.collapsed;" }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "ALayout",
      "props": { "style": "min-height:380px" },
      "children": [
        { "type": "ALayoutSider", "props": { "collapsible": true, "collapsed": { "$expr": "$state.collapsed" }, "onCollapse": { "$fn": "state.collapsed = args[0];" } }, "children": [
          { "type": "div", "props": { "style": "height:32px;margin:16px;background:rgba(255,255,255,0.2)" } }
        ]},
        { "type": "ALayout", "children": [
          { "type": "ALayoutHeader", "props": { "style": "background:#fff;padding:0" } },
          { "type": "ALayoutContent", "props": { "style": "margin:16px" }, "children": [
            { "type": "div", "props": { "style": "padding:24px;min-height:360px;background:#fff" }, "children": ["Content"] }
          ]},
          { "type": "ALayoutFooter", "props": { "style": "text-align:center" }, "children": ["Ant Design Vue Demo"] }
        ]}
      ]
    }
  }
}