{
  "name": "LayoutTopSideDemo",
  "render": {
    "type": "template",
    "content": {
      "type": "ALayout",
      "props": { "style": "min-height:100vh" },
      "children": [
        {
          "type": "ALayoutHeader",
          "props": { "class": "header" },
          "children": [
            { "type": "div", "props": { "class": "logo" }, "children": ["Top Side Layout"] }
          ]
        },
        {
          "type": "ALayout",
          "props": { "hasSider": true },
          "children": [
            {
              "type": "ALayoutSider",
              "props": { "width": 200, "class": "sider" },
              "children": [
                { "type": "AMenu", "props": { "mode": "inline", "defaultSelectedKeys": ["1"] }, "children": [
                  { "type": "AMenuItem", "props": { "key": "1" }, "children": ["nav 1"] },
                  { "type": "AMenuItem", "props": { "key": "2" }, "children": ["nav 2"] }
                ]}
              ]
            },
            {
              "type": "ALayoutContent",
              "props": { "style": "padding:24px" },
              "children": ["Content"]
            }
          ]
        }
      ]
    }
  }
}