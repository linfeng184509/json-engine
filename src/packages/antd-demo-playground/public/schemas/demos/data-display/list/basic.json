{
  "name": "ListBasicDemo",
  "state": {
    "data": {
      "type": "ref",
      "initial": [
        { "title": "Ant Design Title 1" },
        { "title": "Ant Design Title 2" },
        { "title": "Ant Design Title 3" },
        { "title": "Ant Design Title 4" }
      ]
    }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "AList",
      "props": {
        "dataSource": { "type": "expression", "body": "{{ref_state_data}}" },
        "bordered": true,
        "header": "Header",
        "footer": "Footer"
      },
      "children": [
        {
          "type": "template",
          "directives": { "vSlot": { "name": "renderItem", "props": ["item"] } },
          "children": [
            { "type": "AListItem", "children": [
              { "type": "AListItemMeta", "props": { "description": "Ant Design, a design language for background applications" }, "children": [
                { "type": "template", "directives": { "vSlot": { "name": "title" } }, "children": [
                  { "type": "a", "props": { "href": "https://www.antdv.com/" }, "children": [ { "type": "expression", "body": "{{ref_state_item.title}}" } ] }
                ]}
              ]}
            ]}
          ]
        }
      ]
    }
  }
}