{
  "name": "ListVerticalDemo",
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        {
          "type": "h3",
          "children": ["List Vertical"]
        },
        {
          "type": "AList",
          "props": {
            "itemLayout": "vertical",
            "dataSource": [
              { "title": "Title 1", "description": "Description 1" },
              { "title": "Title 2", "description": "Description 2" }
            ]
          },
          "directives": {
            "vSlot": {
              "name": "renderItem",
              "value": "item"
            }
          },
          "children": [
            {
              "type": "AListItem",
              "children": [
                {
                  "type": "AListItemMeta",
                  "props": {
                    "title": { "type": "expression", "body": "{{scope.item.title}}" },
                    "description": { "type": "expression", "body": "{{scope.item.description}}" }
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  }
}