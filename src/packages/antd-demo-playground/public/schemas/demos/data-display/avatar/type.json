{
  "name": "AvatarTypeDemo",
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        {
          "type": "h3",
          "children": ["Avatar Type"]
        },
        {
          "type": "ASpace",
          "props": { "size": 16 },
          "children": [
            { "type": "AAvatar", "props": { "size": 64 }, "children": ["U"] },
            { "type": "AAvatar", "props": { "size": "large" }, "children": ["U"] },
            { "type": "AAvatar", "children": ["U"] },
            { "type": "AAvatar", "props": { "size": "small" }, "children": ["U"] },
            { "type": "AAvatar", "props": { "shape": "square", "size": 40 }, "children": ["U"] }
          ]
        }
      ]
    }
  }
}