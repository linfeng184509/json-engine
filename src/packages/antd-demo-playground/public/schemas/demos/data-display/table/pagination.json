{
  "name": "TablePaginationDemo",
  "state": {
    "columns": { "type": "ref", "initial": [
      { "title": "Name", "dataIndex": "name" },
      { "title": "Age", "dataIndex": "age" },
      { "title": "Address", "dataIndex": "address" }
    ]},
    "data": { "type": "ref", "initial": [
      { "key": "1", "name": "John Brown", "age": 32, "address": "New York No. 1 Lake Park" },
      { "key": "2", "name": "Jim Green", "age": 42, "address": "London No. 1 Lake Park" },
      { "key": "3", "name": "Joe Black", "age": 32, "address": "Sidney No. 1 Lake Park" },
      { "key": "4", "name": "Disabled User", "age": 99, "address": "Sidney No. 1 Lake Park" }
    ]},
    "pagination": { "type": "ref", "initial": { "pageSize": 2, "total": 4 } }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "ATable",
      "props": {
        "columns": { "type": "expression", "body": "{{ref_state_columns}}" },
        "dataSource": { "type": "expression", "body": "{{ref_state_data}}" },
        "pagination": { "type": "expression", "body": "{{ref_state_pagination}}" }
      }
    }
  }
}