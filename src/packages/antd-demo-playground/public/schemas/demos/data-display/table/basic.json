{
  "name": "TableBasicDemo",
  "state": {
    "columns": {
      "type": "ref",
      "initial": [
        { "name": "Name", "dataIndex": "name", "key": "name" },
        { "title": "Age", "dataIndex": "age", "key": "age" },
        { "title": "Address", "dataIndex": "address", "key": "address" },
        { "title": "Tags", "key": "tags", "dataIndex": "tags" },
        { "title": "Action", "key": "action" }
      ]
    },
    "data": {
      "type": "ref",
      "initial": [
        { "key": "1", "name": "John Brown", "age": 32, "address": "New York No. 1 Lake Park", "tags": ["nice", "developer"] },
        { "key": "2", "name": "Jim Green", "age": 42, "address": "London No. 1 Lake Park", "tags": ["loser"] },
        { "key": "3", "name": "Joe Black", "age": 32, "address": "Sidney No. 1 Lake Park", "tags": ["cool", "teacher"] }
      ]
    }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "ATable",
      "props": {
        "columns": { "type": "expression", "body": "{{ref_state_columns}}" },
        "dataSource": { "type": "expression", "body": "{{ref_state_data}}" }
      },
      "children": [
        {
          "type": "template",
          "directives": { "vSlot": { "name": "headerCell", "props": ["column"] } },
          "children": [
            {
              "type": "template",
              "directives": { "vIf": { "type": "expression", "body": "{{ref_state_column.key === 'name'}}" } },
              "children": [
                { "type": "span", "children": [ { "type": "SmileOutlined" }, " Name" ] }
              ]
            }
          ]
        },
        {
          "type": "template",
          "directives": { "vSlot": { "name": "bodyCell", "props": ["column", "record"] } },
          "children": [
            {
              "type": "template",
              "directives": { "vIf": { "type": "expression", "body": "{{ref_state_column.key === 'name'}}" } },
              "children": [
                { "type": "a", "children": [ { "type": "expression", "body": "{{ref_state_record.name}}" } ] }
              ]
            },
            {
              "type": "template",
              "directives": { "vIf": { "type": "expression", "body": "{{ref_state_column.key === 'tags'}}" } },
              "children": [
                { "type": "span", "children": [
                  { "type": "ATag", "props": { "color": "blue" }, "children": [ { "type": "expression", "body": "{{ref_state_record.tags[0]}}" } ] }
                ]}
              ]
            },
            {
              "type": "template",
              "directives": { "vIf": { "type": "expression", "body": "{{ref_state_column.key === 'action'}}" } },
              "children": [
                { "type": "span", "children": [
                  { "type": "a", "children": ["Invite"] },
                  { "type": "ADivider", "props": { "type": "vertical" } },
                  { "type": "a", "children": ["Delete"] }
                ]}
              ]
            }
          ]
        }
      ]
    }
  }
}