{
  "name": "TabsBasicDemo",
  "state": {
    "activeKey": { "type": "ref", "initial": "1" }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "ATabs",
      "props": {
        "activeKey": { "type": "expression", "body": "{{ref_state_activeKey}}" }
      },
      "directives": {
        "vModel": {
          "prop": { "_type": "reference", "prefix": "state", "variable": "activeKey" },
          "arg": "activeKey"
        }
      },
      "children": [
        { "type": "ATabPane", "props": { "tab": "Tab 1", "key": "1" }, "children": ["Content of Tab Pane 1"] },
        { "type": "ATabPane", "props": { "tab": "Tab 2", "key": "2", "forceRender": true }, "children": ["Content of Tab Pane 2"] },
        { "type": "ATabPane", "props": { "tab": "Tab 3", "key": "3" }, "children": ["Content of Tab Pane 3"] }
      ]
    }
  }
}