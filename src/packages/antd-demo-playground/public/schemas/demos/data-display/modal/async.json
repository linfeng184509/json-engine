{
  "name": "ModalAsyncDemo",
  "state": {
    "visible": { "type": "ref", "initial": false },
    "confirmLoading": { "type": "ref", "initial": false },
    "modalText": { "type": "ref", "initial": "Content of the modal" }
  },
  "methods": {
    "showModal": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{ref_state_visible.value = true}}"
    },
    "handleOk": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{ref_state_modalText.value = 'The modal will be closed after two seconds'; ref_state_confirmLoading.value = true; setTimeout(function(){ ref_state_visible.value = false; ref_state_confirmLoading.value = false; }, 2000)}}"
    },
    "handleCancel": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{ref_state_visible.value = false}}"
    }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        {
          "type": "AButton",
          "props": { "type": "primary" },
          "directives": {
            "vOn": {
              "click": { "type": "function", "params": "{{{}}}", "body": "{{methods.showModal()}}" }
            }
          },
          "children": ["Open Modal with async logic"]
        },
        {
          "type": "AModal",
          "directives": {
            "vModel": {
              "prop": { "_type": "reference", "prefix": "state", "variable": "visible" },
              "arg": "open"
            }
          },
          "props": {
            "title": "Title",
            "confirmLoading": { "type": "expression", "body": "{{ref_state_confirmLoading}}" }
          },
          "directives": {
            "vOn": {
              "ok": { "type": "function", "params": "{{{}}}", "body": "{{methods.handleOk()}}" }
            }
          },
          "children": [
            { "type": "p", "children": [{ "type": "expression", "body": "{{ref_state_modalText}}" }] }
          ]
        }
      ]
    }
  }
}
