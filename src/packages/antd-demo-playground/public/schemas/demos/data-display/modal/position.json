{
  "name": "ModalPositionDemo",
  "state": {
    "modal1Visible": { "type": "ref", "initial": false },
    "modal2Visible": { "type": "ref", "initial": false }
  },
  "methods": {
    "setModal1Visible": {
      "$fn": "state.modal1Visible = args[0];"
    }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        {
          "type": "AButton",
          "props": { "type": "primary" },
          "directives": { "vOn": { "click": { "$fn": "methods.setModal1Visible(true);" } } },
          "children": ["Display a modal dialog at 20px to Top"]
        },
        {
          "type": "AModal",
          "props": { "title": "20px to Top", "style": "top:20px" },
          "directives": {
            "vModel": {
              "prop": { "$ref": "state.modal1Visible" },
              "arg": "open"
            }
          },
          "children": [
            { "type": "p", "children": ["some contents..."] },
            { "type": "p", "children": ["some contents..."] },
            { "type": "p", "children": ["some contents..."] }
          ]
        },
        { "type": "br" },
        { "type": "br" },
        {
          "type": "AButton",
          "props": { "type": "primary" },
          "directives": { "vOn": { "click": { "$fn": "state.modal2Visible = true;" } } },
          "children": ["Vertically centered modal dialog"]
        },
        {
          "type": "AModal",
          "props": { "title": "Vertically centered modal dialog", "centered": true },
          "directives": {
            "vModel": {
              "prop": { "$ref": "state.modal2Visible" },
              "arg": "open"
            }
          },
          "children": [
            { "type": "p", "children": ["some contents..."] },
            { "type": "p", "children": ["some contents..."] },
            { "type": "p", "children": ["some contents..."] }
          ]
        }
      ]
    }
  }
}
