{
  "name": "ModalPositionDemo",
  "state": {
    "visible": { "type": "ref", "initial": false },
    "modalPosition": { "type": "ref", "initial": "center" }
  },
  "methods": {
    "showModal": {
      "type": "function",
      "params": {},
      "body": "{{ref_state_visible = true}}"
    },
    "hideModal": {
      "type": "function",
      "params": {},
      "body": "{{ref_state_visible = false}}"
    }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        {
          "type": "h3",
          "props": { "style": "margin-bottom:16px" },
          "children": ["Modal Position"]
        },
        {
          "type": "ASpace",
          "children": [
            {
              "type": "AButton",
              "directives": {
                "vOn": {
                  "click": { "type": "function", "params": {}, "body": "{{ref_state_modalPosition = 'center'; methods.showModal()}}" }
                }
              },
              "children": ["Center Modal"]
            },
            {
              "type": "AButton",
              "directives": {
                "vOn": {
                  "click": { "type": "function", "params": {}, "body": "{{ref_state_modalPosition = 'top'; methods.showModal()}}" }
                }
              },
              "children": ["Top Modal"]
            }
          ]
        },
        {
          "type": "AModal",
          "props": {
            "open": { "type": "expression", "body": "{{ref_state_visible}}" },
            "title": "Modal at Position",
            "centered": { "type": "expression", "body": "{{ref_state_modalPosition === 'center'}}" },
            "onOk": { "type": "function", "params": {}, "body": "{{methods.hideModal()}}" },
            "onCancel": { "type": "function", "params": {}, "body": "{{methods.hideModal()}}" }
          },
          "children": [
            { "type": "p", "children": ["Modal content here..."] }
          ]
        }
      ]
    }
  }
}