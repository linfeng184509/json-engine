{
  "name": "ModalPositionDemo",
  "state": {
    "modal1Visible": { "type": "ref", "initial": false },
    "modal2Visible": { "type": "ref", "initial": false }
  },
  "methods": {
    "setModal1Visible": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{ref_state_modal1Visible.value = args[0]}}"
    }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        {
          "type": "AButton",
          "props": { "type": "primary" },
          "directives": { "vOn": { "click": { "type": "function", "params": "{{{}}}", "body": "{{methods.setModal1Visible(true)}}" } } },
          "children": ["Display a modal dialog at 20px to Top"]
        },
        {
          "type": "AModal",
          "props": { "title": "20px to Top", "style": "top:20px" },
          "directives": {
            "vModel": {
              "prop": { "_type": "reference", "prefix": "state", "variable": "modal1Visible" },
              "arg": "open"
            }
          },
          "children": [
            { "type": "p", "children": ["some contents..."] },
            { "type": "p", "children": ["some contents..."] },
            { "type": "p", "children": ["some contents..."] }
          ]
        },
        { "type": "br" },
        { "type": "br" },
        {
          "type": "AButton",
          "props": { "type": "primary" },
          "directives": { "vOn": { "click": { "type": "function", "params": "{{{}}}", "body": "{{ref_state_modal2Visible.value = true}}" } } },
          "children": ["Vertically centered modal dialog"]
        },
        {
          "type": "AModal",
          "props": { "title": "Vertically centered modal dialog", "centered": true },
          "directives": {
            "vModel": {
              "prop": { "_type": "reference", "prefix": "state", "variable": "modal2Visible" },
              "arg": "open"
            }
          },
          "children": [
            { "type": "p", "children": ["some contents..."] },
            { "type": "p", "children": ["some contents..."] },
            { "type": "p", "children": ["some contents..."] }
          ]
        }
      ]
    }
  }
}
