{
  "name": "BadgeBasicDemo",
  "render": {
    "type": "template",
    "content": {
      "type": "ASpace",
      "props": { "size": "large" },
      "children": [
        { "type": "ABadge", "props": { "count": 5 }, "children": [ { "type": "AAvatar", "props": { "shape": "square" } } ] },
        { "type": "ABadge", "props": { "count": 0, "showZero": true }, "children": [ { "type": "AAvatar", "props": { "shape": "square" } } ] },
        { "type": "ABadge", "props": { "dot": true }, "children": [ { "type": "AAvatar", "props": { "shape": "square" } } ] }
      ]
    }
  }
}