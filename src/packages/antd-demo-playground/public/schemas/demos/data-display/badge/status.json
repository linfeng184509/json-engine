{
  "name": "BadgeStatusDemo",
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        { "type": "ABadge", "props": { "status": "success" } },
        { "type": "ABadge", "props": { "status": "error" } },
        { "type": "ABadge", "props": { "status": "default" } },
        { "type": "ABadge", "props": { "status": "processing" } },
        { "type": "ABadge", "props": { "status": "warning" } },
        { "type": "br" },
        {
          "type": "ASpace",
          "props": { "direction": "vertical" },
          "children": [
            { "type": "ABadge", "props": { "status": "success", "text": "Success" } },
            { "type": "ABadge", "props": { "status": "error", "text": "Error" } },
            { "type": "ABadge", "props": { "status": "default", "text": "Default" } },
            { "type": "ABadge", "props": { "status": "processing", "text": "Processing" } },
            { "type": "ABadge", "props": { "status": "warning", "text": "warning" } }
          ]
        }
      ]
    }
  }
}
