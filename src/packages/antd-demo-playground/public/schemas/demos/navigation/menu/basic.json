{
  "name": "MenuBasicDemo",
  "state": {
    "current": { "type": "ref", "initial": "mail" }
  },
  "methods": {
    "handleClick": {
      "type": "function",
      "params": {},
      "body": "{{ref_state_current.value = args[0].key}}"
    }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "AMenu",
      "props": {
        "mode": "horizontal",
        "selectedKeys": { "type": "expression", "body": "[ref_state_current.value]" }
      },
      "directives": { "vOn": { "click": { "type": "function", "params": {}, "body": "{{methods.handleClick(args[0])}}" } } },
      "children": [
        { "type": "AMenuItem", "props": { "key": "mail" }, "children": [ { "type": "MailOutlined" }, " Navigation One" ] },
        { "type": "AMenuItem", "props": { "key": "app", "disabled": true }, "children": [ { "type": "AppstoreOutlined" }, " Navigation Two" ] },
        { "type": "AMenuItem", "props": { "key": "alipay" }, "children": [ { "type": "LinkOutlined" }, " Navigation Three" ] }
      ]
    }
  }
}