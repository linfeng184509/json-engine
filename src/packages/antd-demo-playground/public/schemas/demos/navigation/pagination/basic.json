{
  "name": "PaginationBasicDemo",
  "state": {
    "current": { "type": "ref", "initial": 1 }
  },
  "methods": {
    "onChange": { "$fn": "state.current = args[0];" }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "APagination",
      "props": {
        "current": { "$expr": "state.current" },
        "total": 50
      },
      "directives": { "vOn": { "change": { "$fn": "methods.onChange(args[0]);" } } }
    }
  }
}