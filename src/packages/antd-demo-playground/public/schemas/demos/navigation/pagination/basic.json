{
  "name": "PaginationBasicDemo",
  "state": {
    "current": { "type": "ref", "initial": 1 }
  },
  "methods": {
    "onChange": { "type": "function", "params": {}, "body": "{{ref_state_current.value = args[0]}}" }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "APagination",
      "props": {
        "current": { "type": "expression", "body": "ref_state_current" },
        "total": 50
      },
      "directives": { "vOn": { "change": { "type": "function", "params": {}, "body": "{{methods.onChange(args[0])}}" } } }
    }
  }
}