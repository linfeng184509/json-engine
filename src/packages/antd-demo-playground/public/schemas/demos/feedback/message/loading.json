{
  "name": "MessageLoadingDemo",
  "methods": {
    "success": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{var hide = $_antd.message.loading('Action in progress..', 0); setTimeout(hide, 2500);}}"
    }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "AButton",
      "directives": {
        "vOn": {
          "click": { "type": "function", "params": "{{{}}}", "body": "{{methods.success()}}" }
        }
      },
      "children": ["Display a loading indicator"]
    }
  }
}
