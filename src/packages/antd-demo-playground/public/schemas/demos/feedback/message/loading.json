{
  "name": "MessageLoadingDemo",
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        {
          "type": "h3",
          "children": ["Message Loading"]
        },
        {
          "type": "AButton",
          "props": { "type": "primary" },
          "directives": {
            "vOn": {
              "click": { "type": "function", "params": "{{{}}}", "body": "{{AMessage.loading('Loading...', 0)}}var hide = AMessage.loading('Loading...', 2.5); setTimeout(function(){ hide(); }, 2500);" }
            }
          },
          "children": ["Show Loading Message"]
        }
      ]
    }
  }
}