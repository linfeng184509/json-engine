{
  "name": "AlertDescriptionDemo",
  "render": {
    "type": "template",
    "content": {
      "type": "ASpace",
      "props": { "direction": "vertical", "style": "width:100%" },
      "children": [
        {
          "type": "AAlert",
          "props": { "message": "Success Text", "type": "success" },
          "children": [
            {
              "type": "p",
              "directives": { "vSlot": { "name": "description" } },
              "children": [
                "Success Description ",
                { "type": "span", "props": { "style": "color:red" }, "children": ["Success"] },
                " Description Success Description"
              ]
            }
          ]
        },
        {
          "type": "AAlert",
          "props": {
            "message": "Info Text",
            "description": "Info Description Info Description Info Description Info Description",
            "type": "info"
          }
        },
        {
          "type": "AAlert",
          "props": {
            "message": "Warning Text",
            "description": "Warning Description Warning Description Warning Description Warning Description",
            "type": "warning"
          }
        },
        {
          "type": "AAlert",
          "props": {
            "message": "Error Text",
            "description": "Error Description Error Description Error Description Error Description",
            "type": "error"
          }
        }
      ]
    }
  }
}
