{
  "name": "AlertDescriptionDemo",
  "render": {
    "type": "template",
    "content": {
      "type": "ASpace",
      "props": { "direction": "vertical", "style": "width:100%" },
      "children": [
        { "type": "AAlert", "props": { "message": "Success Tips", "description": "Detailed description and advice about successful copywriting.", "type": "success", "showIcon": true } },
        { "type": "AAlert", "props": { "message": "Informational Notes", "description": "Additional description and information about copywriting.", "type": "info", "showIcon": true } },
        { "type": "AAlert", "props": { "message": "Warning", "description": "This is a warning notice about copywriting.", "type": "warning", "showIcon": true, "closable": true } },
        { "type": "AAlert", "props": { "message": "Error", "description": "This is an error message about copywriting.", "type": "error", "showIcon": true } }
      ]
    }
  }
}