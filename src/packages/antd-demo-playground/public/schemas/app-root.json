{
  "name": "AppRoot",
  "state": {
    "collapsed": { "type": "ref", "initial": false },
    "selectedKeys": { "type": "ref", "initial": ["button/basic"] },
    "openKeys": { "type": "ref", "initial": ["general"] },
    "currentRoute": { "type": "ref", "initial": "/" },
    "pageSchemaPath": { "type": "ref", "initial": null },
    "isLoading": { "type": "ref", "initial": false },
    "error": { "type": "ref", "initial": null }
  },
  "methods": {
    "onOpenChange": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{ref_state_openKeys.value = args[0]}}"
    },
    "onMenuClick": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{var item = args[0]; if(item.key) { ref_state_selectedKeys.value = [item.key]; window.location.hash = '/demos/' + item.key; }}}"
    },
    "loadPage": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{var route = args[0] || ref_state_currentRoute; var path = route.split('?')[0] || '/'; var routes = window.__APP_ROUTES__ || []; var matched = null; function matchRoute(routePath, currentPath) { var routeParts = routePath.split('/'); var pathParts = currentPath.split('/'); if (routeParts.length !== pathParts.length) return false; for (var i = 0; i < routeParts.length; i++) { if (routeParts[i].startsWith(':')) continue; if (routeParts[i] !== pathParts[i]) return false; } return true; } for (var i = 0; i < routes.length; i++) { if (matchRoute(routes[i].path, path)) { matched = routes[i]; break; } if (routes[i].path === '/:pathMatch(.*)*') { matched = routes[i]; } } if (!matched) { ref_state_error = 'Page not found: ' + path; return; } if (matched.redirect) { window.location.hash = matched.redirect; return; } ref_state_isLoading = true; ref_state_error = null; ref_state_pageSchemaPath = matched.component; ref_state_isLoading = false;}}"
    },
    "handleHashChange": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{ref_state_currentRoute = window.location.hash.slice(1) || '/'; methods.loadPage(ref_state_currentRoute);}}"
    },
    "retry": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{methods.loadPage(ref_state_currentRoute);}}"
    }
  },
  "lifecycle": {
    "onMounted": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{ref_state_currentRoute = window.location.hash.slice(1) || '/'; methods.loadPage(ref_state_currentRoute); window.addEventListener('hashchange', methods.handleHashChange);}}"
    },
    "onUnmounted": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{window.removeEventListener('hashchange', methods.handleHashChange);}}"
    }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "ALayout",
      "props": { "style": "min-height:100vh" },
      "children": [
        {
          "type": "ALayoutSider",
          "props": {
            "collapsible": true,
            "collapsed": { "type": "expression", "body": "{{ref_state_collapsed}}" },
            "onCollapse": { "type": "function", "params": "{{{}}}", "body": "{{ref_state_collapsed.value = args[0]}}" },
            "width": 240,
            "style": "background:#fff;overflow:auto;height:100vh;position:sticky;left:0;top:0;bottom:0"
          },
          "children": [
            {
              "type": "div",
              "props": { "style": "height:64px;display:flex;align-items:center;justify-content:center;border-bottom:1px solid #f0f0f0" },
              "children": [
                { "type": "span", "props": { "style": "font-size:16px;font-weight:600;color:#1677ff" }, "children": ["Antd Demos"] }
              ]
            },
            {
              "type": "AMenu",
              "props": {
                "mode": "inline",
                "selectedKeys": { "type": "expression", "body": "{{ref_state_selectedKeys}}" },
                "openKeys": { "type": "expression", "body": "{{ref_state_openKeys}}" },
                "style": "border-right:0"
              },
              "directives": {
                "vOn": {
                  "click": { "type": "function", "params": "{{{}}}", "body": "{{methods.onMenuClick(args[0])}}" },
                  "openChange": { "type": "function", "params": "{{{}}}", "body": "{{methods.onOpenChange(args[0])}}" }
                }
              },
              "children": [
                {
                  "type": "ASubMenu",
                  "props": { "key": "general" },
                  "children": [
                    { "type": "template", "directives": { "vSlot": { "name": "title" } }, "children": [ { "type": "span", "children": ["通用 General"] } ] },
                    { "type": "AMenuItem", "props": { "key": "button/basic" }, "children": ["Button Basic"] },
                    { "type": "AMenuItem", "props": { "key": "icon/basic" }, "children": ["Icon Basic"] },
                    { "type": "AMenuItem", "props": { "key": "typography/basic" }, "children": ["Typography Basic"] }
                  ]
                },
                {
                  "type": "ASubMenu",
                  "props": { "key": "layout" },
                  "children": [
                    { "type": "template", "directives": { "vSlot": { "name": "title" } }, "children": [ { "type": "span", "children": ["布局 Layout"] } ] },
                    { "type": "AMenuItem", "props": { "key": "grid/basic" }, "children": ["Grid Basic"] },
                    { "type": "AMenuItem", "props": { "key": "space/basic" }, "children": ["Space Basic"] },
                    { "type": "AMenuItem", "props": { "key": "layout/basic" }, "children": ["Layout Basic"] }
                  ]
                },
                {
                  "type": "ASubMenu",
                  "props": { "key": "data-entry" },
                  "children": [
                    { "type": "template", "directives": { "vSlot": { "name": "title" } }, "children": [ { "type": "span", "children": ["数据录入 Data Entry"] } ] },
                    { "type": "AMenuItem", "props": { "key": "input/basic" }, "children": ["Input Basic"] },
                    { "type": "AMenuItem", "props": { "key": "select/basic" }, "children": ["Select Basic"] },
                    { "type": "AMenuItem", "props": { "key": "form/basic" }, "children": ["Form Basic"] }
                  ]
                },
                {
                  "type": "ASubMenu",
                  "props": { "key": "data-display" },
                  "children": [
                    { "type": "template", "directives": { "vSlot": { "name": "title" } }, "children": [ { "type": "span", "children": ["数据展示 Data Display"] } ] },
                    { "type": "AMenuItem", "props": { "key": "table/basic" }, "children": ["Table Basic"] },
                    { "type": "AMenuItem", "props": { "key": "modal/basic" }, "children": ["Modal Basic"] },
                    { "type": "AMenuItem", "props": { "key": "card/basic" }, "children": ["Card Basic"] }
                  ]
                },
                {
                  "type": "ASubMenu",
                  "props": { "key": "feedback" },
                  "children": [
                    { "type": "template", "directives": { "vSlot": { "name": "title" } }, "children": [ { "type": "span", "children": ["反馈 Feedback"] } ] },
                    { "type": "AMenuItem", "props": { "key": "alert/basic" }, "children": ["Alert Basic"] },
                    { "type": "AMenuItem", "props": { "key": "message/basic" }, "children": ["Message Basic"] },
                    { "type": "AMenuItem", "props": { "key": "progress/basic" }, "children": ["Progress Basic"] }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "ALayout",
          "children": [
            {
              "type": "ALayoutContent",
              "props": { "style": "margin:24px;padding:24px;background:#fff;border-radius:8px;min-height:280px" },
              "children": [
                {
                  "type": "div",
                  "directives": { "vIf": { "type": "expression", "body": "{{ref_state_isLoading}}" } },
                  "props": { "style": "display:flex;justify-content:center;align-items:center;min-height:200px" },
                  "children": ["Loading..."]
                },
                {
                  "type": "div",
                  "directives": { "vIf": { "type": "expression", "body": "{{ref_state_error}}" } },
                  "props": { "style": "text-align:center;padding:48px" },
                  "children": [
                    { "type": "h3", "children": ["Error"] },
                    { "type": "p", "children": [{ "type": "expression", "body": "{{ref_state_error}}" }] },
                    { "type": "AButton", "props": { "type": "primary" }, "directives": { "vOn": { "click": { "type": "function", "params": "{{{}}}", "body": "{{methods.retry()}}" } } }, "children": ["Retry"] }
                  ]
                },
                {
                  "type": "PageLoader",
                  "directives": { "vIf": { "type": "expression", "body": "{{ref_state_pageSchemaPath && !ref_state_error}}" } },
                  "props": {
                    "schemaPath": { "type": "expression", "body": "{{ref_state_pageSchemaPath}}" },
                    "cache": true
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  }
}