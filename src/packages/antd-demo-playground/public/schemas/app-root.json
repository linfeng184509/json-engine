                        { "type": "AMenuItem", "props": { "key": { "type": "string", "body": "'empty/custom'" } }, "children": ["Empty Custom"] },
                        { "type": "AMenuItem", "props": { "key": { "type": "string", "body": "'back-top/basic'" } }, "children": ["BackTop Basic"] },
                        { "type": "AMenuItem", "props": { "key": { "type": "string", "body": "'back-top/custom'" } }, "children": ["BackTop Custom"] },
                        { "type": "AMenuItem", "props": { "key": { "type": "string", "body": "'anchor/basic'" } }, "children": ["Anchor Basic"] },
                        { "type": "AMenuItem", "props": { "key": { "type": "string", "body": "'anchor/horizontal'" } }, "children": ["Anchor Horizontal"] },
                        { "type": "AMenuItem", "props": { "key": { "type": "string", "body": "'affix/basic'" } }, "children": ["Affix Basic"] },
                        { "type": "AMenuItem", "props": { "key": { "type": "string", "body": "'affix/bottom'" } }, "children": ["Affix Bottom"] },
                        { "type": "AMenuItem", "props": { "key": { "type": "string", "body": "'calendar/basic'" } }, "children": ["Calendar Basic"] }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "ALayout",
              "children": [
                {
                  "type": "ALayoutContent",
                  "props": { "style": { "type": "string", "body": "'margin:24px;padding:24px;background:#fff;border-radius:8px;min-height:280px'" } },
                  "children": [
                    {
                      "type": "div",
                      "directives": { "vIf": { "type": "expression", "body": "{{ref_state_isLoading}}" } },
                      "props": { "style": { "type": "string", "body": "'display:flex;justify-content:center;align-items:center;min-height:200px'" } },
                      "children": ["Loading..."]
                    },
                    {
                      "type": "div",
                      "directives": { "vIf": { "type": "expression", "body": "{{ref_state_error}}" } },
                      "props": { "style": { "type": "string", "body": "'text-align:center;padding:48px'" } },
                      "children": [
                        { "type": "h3", "children": ["Error"] },
                        { "type": "p", "children": [{ "type": "expression", "body": "{{ref_state_error}}" }] },
                        { "type": "AButton", "props": { "type": "primary" }, "directives": { "vOn": { "click": { "type": "function", "params": "{{{}}}", "body": "{{methods.retry()}}" } } }, "children": ["Retry"] }
                      ]
                    },
                    {
                      "type": "PageLoader",
                      "directives": { "vIf": { "type": "expression", "body": "{{ref_state_pageSchemaPath && !ref_state_error}}" } },
                      "props": {
                        "schemaPath": { "type": "expression", "body": "{{ref_state_pageSchemaPath}}" },
                        "cache": true
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  }
}