      { "path": "/demos/tag/basic", "name": "TagBasic", "component": "/schemas/demos/data-display/tag/basic.json", "meta": { "title": "Tag Basic", "category": "data-display" } },
      { "path": "/demos/avatar/basic", "name": "AvatarBasic", "component": "/schemas/demos/data-display/avatar/basic.json", "meta": { "title": "Avatar Basic", "category": "data-display" } },
      { "path": "/demos/tree/basic", "name": "TreeBasic", "component": "/schemas/demos/data-display/tree/basic.json", "meta": { "title": "Tree Basic", "category": "data-display" } },
      { "path": "/demos/list/basic", "name": "ListBasic", "component": "/schemas/demos/data-display/list/basic.json", "meta": { "title": "List Basic", "category": "data-display" } },
      { "path": "/demos/descriptions/basic", "name": "DescriptionsBasic", "component": "/schemas/demos/data-display/descriptions/basic.json", "meta": { "title": "Descriptions Basic", "category": "data-display" } },
      
