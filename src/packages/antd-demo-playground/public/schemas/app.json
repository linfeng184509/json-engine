      { "path": "/demos/table/basic", "name": "TableBasic", "component": "/schemas/demos/data-display/table/basic.json", "meta": { "title": "Table Basic", "category": "data-display" } },
      { "path": "/demos/table/pagination", "name": "TablePagination", "component": "/schemas/demos/data-display/table/pagination.json", "meta": { "title": "Table Pagination", "category": "data-display" } },
      { "path": "/demos/tabs/basic", "name": "TabsBasic", "component": "/schemas/demos/data-display/tabs/basic.json", "meta": { "title": "Tabs Basic", "category": "data-display" } },
