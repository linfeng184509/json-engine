      { "path": "/demos/switch/basic", "name": "SwitchBasic", "component": "/schemas/demos/data-entry/switch/basic.json", "meta": { "title": "Switch Basic", "category": "data-entry" } },
      { "path": "/demos/form/basic", "name": "FormBasic", "component": "/schemas/demos/data-entry/form/basic.json", "meta": { "title": "Form Basic", "category": "data-entry" } },
      { "path": "/demos/date-picker/basic", "name": "DatePickerBasic", "component": "/schemas/demos/data-entry/date-picker/basic.json", "meta": { "title": "DatePicker Basic", "category": "data-entry" } },
      { "path": "/demos/time-picker/basic", "name": "TimePickerBasic", "component": "/schemas/demos/data-entry/time-picker/basic.json", "meta": { "title": "TimePicker Basic", "category": "data-entry" } },
      { "path": "/demos/upload/basic", "name": "UploadBasic", "component": "/schemas/demos/data-entry/upload/basic.json", "meta": { "title": "Upload Basic", "category": "data-entry" } },
      
