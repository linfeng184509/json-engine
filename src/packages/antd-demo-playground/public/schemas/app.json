      { "path": "/demos/message/basic", "name": "MessageBasic", "component": "/schemas/demos/feedback/message/basic.json", "meta": { "title": "Message Basic", "category": "feedback" } },
      { "path": "/demos/notification/basic", "name": "NotificationBasic", "component": "/schemas/demos/feedback/notification/basic.json", "meta": { "title": "Notification Basic", "category": "feedback" } },
      { "path": "/demos/progress/basic", "name": "ProgressBasic", "component": "/schemas/demos/feedback/progress/basic.json", "meta": { "title": "Progress Basic", "category": "feedback" } },
      { "path": "/demos/spin/basic", "name": "SpinBasic", "component": "/schemas/demos/feedback/spin/basic.json", "meta": { "title": "Spin Basic", "category": "feedback" } },
      { "path": "/demos/skeleton/basic", "name": "SkeletonBasic", "component": "/schemas/demos/feedback/skeleton/basic.json", "meta": { "title": "Skeleton Basic", "category": "feedback" } },
      
      { "path": "/demos/collapse/basic", "name": "CollapseBasic", "component": "/schemas/demos/other/collapse/basic.json", "meta": { "title": "Collapse Basic", "category": "other" } },
      { "path": "/demos/drawer/basic", "name": "DrawerBasic", "component": "/schemas/demos/other/drawer/basic.json", "meta": { "title": "Drawer Basic", "category": "other" } },
      
