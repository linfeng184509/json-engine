{
  "name": "AntdDemoPlayground",
  "version": "1.0.0",
  "plugins": [
    { "name": "@json-engine/plugin-antd", "config": { "includeIcons": true } },
    { "name": "@json-engine/plugin-router" }
  ],
  "config": {
    "antd": {
      "theme": { "primaryColor": "#1677ff", "borderRadius": 6 },
      "includeIcons": true
    },
    "router": { "mode": "hash", "base": "/" }
  },
  "router": {
    "history": "hash",
    "routes": [
      { "path": "/", "redirect": "/demos/button/basic" },
      
      { "path": "/demos/button/basic", "name": "ButtonBasic", "component": "/schemas/demos/general/button/basic.json", "meta": { "title": "Button Basic", "category": "general" } },
      { "path": "/demos/button/icon", "name": "ButtonIcon", "component": "/schemas/demos/general/button/icon.json", "meta": { "title": "Button Icon", "category": "general" } },
      { "path": "/demos/button/size", "name": "ButtonSize", "component": "/schemas/demos/general/button/size.json", "meta": { "title": "Button Size", "category": "general" } },
      { "path": "/demos/button/loading", "name": "ButtonLoading", "component": "/schemas/demos/general/button/loading.json", "meta": { "title": "Button Loading", "category": "general" } },
      { "path": "/demos/button/disabled", "name": "ButtonDisabled", "component": "/schemas/demos/general/button/disabled.json", "meta": { "title": "Button Disabled", "category": "general" } },
      { "path": "/demos/button/danger", "name": "ButtonDanger", "component": "/schemas/demos/general/button/danger.json", "meta": { "title": "Button Danger", "category": "general" } },
      { "path": "/demos/button/block", "name": "ButtonBlock", "component": "/schemas/demos/general/button/block.json", "meta": { "title": "Button Block", "category": "general" } },
      { "path": "/demos/button/ghost", "name": "ButtonGhost", "component": "/schemas/demos/general/button/ghost.json", "meta": { "title": "Button Ghost", "category": "general" } },
