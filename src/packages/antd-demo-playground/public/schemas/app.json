      { "path": "/demos/layout/basic", "name": "LayoutBasic", "component": "/schemas/demos/layout/layout/basic.json", "meta": { "title": "Layout Basic", "category": "layout" } },
      
      { "path": "/demos/menu/basic", "name": "MenuBasic", "component": "/schemas/demos/navigation/menu/basic.json", "meta": { "title": "Menu Basic", "category": "navigation" } },
      { "path": "/demos/dropdown/basic", "name": "DropdownBasic", "component": "/schemas/demos/navigation/dropdown/basic.json", "meta": { "title": "Dropdown Basic", "category": "navigation" } },
