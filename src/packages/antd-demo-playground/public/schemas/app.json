      { "path": "/demos/select/basic", "name": "SelectBasic", "component": "/schemas/demos/data-entry/select/basic.json", "meta": { "title": "Select Basic", "category": "data-entry" } },
      { "path": "/demos/select/multiple", "name": "SelectMultiple", "component": "/schemas/demos/data-entry/select/multiple.json", "meta": { "title": "Select Multiple", "category": "data-entry" } },
