{
  "name": "StepsIconsDemo",
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        {
          "type": "h3",
          "children": ["Steps Icons"]
        },
        {
          "type": "ASteps",
          "children": [
            { "type": "AStep", "props": { "status": "finish", "title": "Login" }, "children": [{ "type": "template", "directives": { "vSlot": { "name": "icon" } }, "children": [{ "type": "UserOutlined" }] }] },
            { "type": "AStep", "props": { "status": "finish", "title": "Verification" }, "children": [{ "type": "template", "directives": { "vSlot": { "name": "icon" } }, "children": [{ "type": "SolutionOutlined" }] }] },
            { "type": "AStep", "props": { "status": "process", "title": "Pay" }, "children": [{ "type": "template", "directives": { "vSlot": { "name": "icon" } }, "children": [{ "type": "LoadingOutlined" }] }] },
            { "type": "AStep", "props": { "status": "wait", "title": "Done" }, "children": [{ "type": "template", "directives": { "vSlot": { "name": "icon" } }, "children": [{ "type": "SmileOutlined" }] }] }
          ]
        }
      ]
    }
  }
}