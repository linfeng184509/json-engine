{
  "name": "SwitchLoadingDemo",
  "state": {
    "checked1": { "type": "ref", "initial": true },
    "checked2": { "type": "ref", "initial": false }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "ASpace",
      "props": { "direction": "vertical" },
      "children": [
        {
          "type": "ASwitch",
          "props": { "loading": true },
          "directives": {
            "vModel": {
              "prop": { "_type": "reference", "prefix": "state", "variable": "checked1" },
              "arg": "checked"
            }
          }
        },
        {
          "type": "ASwitch",
          "props": { "loading": true, "size": "small" },
          "directives": {
            "vModel": {
              "prop": { "_type": "reference", "prefix": "state", "variable": "checked2" },
              "arg": "checked"
            }
          }
        }
      ]
    }
  }
}
