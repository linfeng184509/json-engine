{
  "name": "InputPasswordDemo",
  "state": {
    "value": { "type": "ref", "initial": "" },
    "value2": { "type": "ref", "initial": "" },
    "value3": { "type": "ref", "initial": "" },
    "value4": { "type": "ref", "initial": "" },
    "visible": { "type": "ref", "initial": true }
  },
  "methods": {
    "toggleVisible": { "$fn": "state.visible = !state.visible;" }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "ASpace",
      "props": { "direction": "vertical", "size": "middle", "style": "width:100%" },
      "children": [
        {
          "type": "AInputPassword",
          "props": { "placeholder": "input password" },
          "directives": {
            "vModel": {
              "prop": { "$ref": "state.value" },
              "arg": "value"
            }
          }
        },
        {
          "type": "AInputPassword",
          "props": { "placeholder": "input password" },
          "children": [
            {
              "type": "EyeTwoTone",
              "directives": { "vSlot": { "name": "iconRender", "props": ["v"] }, "vIf": { "$expr": "v" } }
            },
            {
              "type": "EyeInvisibleOutlined",
              "directives": { "vSlot": { "name": "iconRender", "props": ["v"] }, "vIf": { "$expr": "!v" } }
            }
          ]
        },
        {
          "type": "AInputPassword",
          "props": { "placeholder": "input password", "visibilityToggle": false },
          "directives": {
            "vModel": {
              "prop": { "$ref": "state.value3" },
              "arg": "value"
            }
          }
        },
        {
          "type": "ASpace",
          "children": [
            {
              "type": "AInputPassword",
              "props": { "placeholder": "input password" },
              "directives": {
                "vModel": {
                  "prop": { "$ref": "state.value4" },
                  "arg": "value"
                }
              }
            },
            {
              "type": "AButton",
              "directives": { "vOn": { "click": { "$fn": "methods.toggleVisible();" } } },
              "children": [{ "$expr": "state.visible ? 'Hide' : 'Show'" }]
            }
          ]
        }
      ]
    }
  }
}
