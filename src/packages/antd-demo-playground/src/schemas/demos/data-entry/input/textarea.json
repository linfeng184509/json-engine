{
  "name": "InputTextareaDemo",
  "state": {
    "value": { "type": "ref", "initial": "" }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        {
          "type": "ATextArea",
          "props": { "rows": 4 },
          "directives": {
            "vModel": {
              "prop": { "_type": "reference", "prefix": "state", "variable": "value" },
              "arg": "value"
            }
          }
        },
        { "type": "br" },
        { "type": "br" },
        {
          "type": "ATextArea",
          "props": { "rows": 4, "placeholder": "maxlength is 6", "maxlength": 6 }
        }
      ]
    }
  }
}
