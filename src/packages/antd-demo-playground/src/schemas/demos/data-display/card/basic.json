{
  "name": "CardBasicDemo",
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        {
          "type": "ACard",
          "props": { "title": "Default size card", "style": "width:300px" },
          "children": [
            {
              "type": "a",
              "props": { "href": "#" },
              "directives": { "vSlot": { "name": "extra" } },
              "children": ["more"]
            },
            { "type": "p", "children": ["card content"] },
            { "type": "p", "children": ["card content"] },
            { "type": "p", "children": ["card content"] }
          ]
        },
        { "type": "br" },
        {
          "type": "ACard",
          "props": { "size": "small", "title": "Small size card", "style": "width:300px" },
          "children": [
            {
              "type": "a",
              "props": { "href": "#" },
              "directives": { "vSlot": { "name": "extra" } },
              "children": ["more"]
            },
            { "type": "p", "children": ["card content"] },
            { "type": "p", "children": ["card content"] },
            { "type": "p", "children": ["card content"] }
          ]
        }
      ]
    }
  }
}
