{
  "name": "EnterpriseAdminApp",
  "version": "1.0.0",
  "plugins": [
    { "name": "@json-engine/plugin-axios" },
    { "name": "@json-engine/plugin-antd" },
    { "name": "@json-engine/plugin-router" },
    { "name": "@json-engine/plugin-websocket" },
    { "name": "@json-engine/plugin-storage" },
    { "name": "@json-engine/plugin-auth" },
    { "name": "@json-engine/plugin-i18n" },
    { "name": "@json-engine/plugin-echarts" }
  ],
  "config": {
    "axios": {
      "baseURL": "/api",
      "timeout": 10000,
      "headers": {
        "Content-Type": "application/json"
      }
    },
    "antd": {
      "theme": {
        "primaryColor": "#1677ff",
        "borderRadius": 6
      },
      "locale": "zh_CN"
    },
    "router": {
      "mode": "hash",
      "base": "/"
    },
    "websocket": {
      "url": "ws://localhost:8080",
      "autoReconnect": true,
      "reconnectInterval": 5000,
      "heartbeatInterval": 30000
    },
    "storage": {
      "prefix": "ea_",
      "sync": true
    },
    "auth": {
      "pagePermissions": {
        "/dashboard": "dashboard:view",
        "/system/user": "user:view",
        "/system/role": "role:view"
      }
    },
    "i18n": {
      "locale": "zh_CN",
      "fallbackLocale": "en"
    },
    "echarts": {
      "theme": "default",
      "autoResize": true
    }
  },
  "router": {
    "history": "hash",
    "routes": [
      {
        "path": "/login",
        "name": "Login",
        "component": "/schemas/pages/login.json",
        "meta": {
          "title": "登录"
        }
      },
      {
        "path": "/dashboard",
        "name": "Dashboard",
        "component": "/schemas/pages/dashboard.json",
        "meta": {
          "title": "首页",
          "requiresAuth": true,
          "permissions": ["dashboard:view"]
        }
      },
      {
        "path": "/",
        "redirect": "/dashboard"
      },
      {
        "path": "/:pathMatch(.*)*",
        "name": "NotFound",
        "component": "/schemas/pages/404.json"
      }
    ]
  },
  "ui": {
    "components": [
      { "name": "AForm", "component": "ant-design-vue/es/form" },
      { "name": "AFormItem", "component": "ant-design-vue/es/form/FormItem" },
      { "name": "AInput", "component": "ant-design-vue/es/input" },
      { "name": "AInputPassword", "component": "ant-design-vue/es/input/Password" },
      { "name": "AButton", "component": "ant-design-vue/es/button" },
      { "name": "ACheckbox", "component": "ant-design-vue/es/checkbox" },
      { "name": "ASpin", "component": "ant-design-vue/es/spin" },
      { "name": "ACard", "component": "ant-design-vue/es/card" },
      { "name": "AAlert", "component": "ant-design-vue/es/alert" },
      { "name": "ALayout", "component": "ant-design-vue/es/layout" },
      { "name": "ALayoutHeader", "component": "ant-design-vue/es/layout/Header" },
      { "name": "ALayoutContent", "component": "ant-design-vue/es/layout/Content" },
      { "name": "AResult", "component": "ant-design-vue/es/result" },
      { "name": "AConfigProvider", "component": "ant-design-vue/es/config-provider" }
    ],
    "theme": {
      "primaryColor": "#1677ff",
      "borderRadius": 6
    }
  }
}