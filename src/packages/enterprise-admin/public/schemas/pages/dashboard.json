{
  "name": "DashboardPage",
  "state": {
    "user": { "type": "ref", "initial": null },
    "loading": { "type": "ref", "initial": true },
    "visitData": { "type": "ref", "initial": [120, 200, 150, 80, 70, 110, 130] },
    "categoryData": {
      "type": "ref",
      "initial": [
        { "value": 1048, "name": "搜索引擎" },
        { "value": 735, "name": "直接访问" },
        { "value": 580, "name": "邮件营销" },
        { "value": 484, "name": "联盟广告" }
      ]
    }
  },
  "computed": {
    "greeting": { "get": { "$fn": "var h=new Date().getHours();return h<12?'早上好':h<18?'下午好':'晚上好'" } }
  },
  "methods": {
    "loadData": { "$fn": "var t=$_core.storage.get('token');if(!t){window.location.hash='#/login';return}state.loading=true;var u=$_core.storage.get('userInfo');var p=$_core.storage.get('permissions');if(u)state.user=u;state.loading=false" },
    "updateVisitData": { "$fn": "state.visitData = state.visitData.map(v => v + Math.floor(Math.random() * 100 - 50))" }
  },
  "lifecycle": { "onMounted": { "$fn": "methods.loadData()" } },
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "props": { "style": 'max-width: 1400px; margin: 0 auto; padding: 24px' },
      "children": [
        { "type": "div", "directives": { "vIf": { "$expr": "$state.loading" } }, "props": { "style": 'display: flex; justify-content: center; align-items: center; min-height: 400px' }, "children": [{ "type": "ASpin", "props": { "size": 'large' } }] },
        { "type": "div", "directives": { "vIf": { "$expr": "!$state.loading" } }, "children": [
          { "type": "div", "props": { "style": 'margin-bottom: 24px' }, "children": [
            { "type": "h1", "props": { "style": 'font-size: 24px; font-weight: 600; color: rgba(0,0,0,0.88); margin: 0 0 8px' }, "children": [{ "$expr": "computed.greeting" }, "，", { "$expr": "$state.user?.nickname||$state.user?.username" }] },
            { "type": "p", "props": { "style": 'font-size: 14px; color: rgba(0,0,0,0.45); margin: 0' }, "children": ["欢迎使用企业管理系统，祝您工作愉快"] }
          ] },
          { "type": "div", "props": { "style": 'display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 16px; margin-bottom: 16px' }, "children": [
            { "type": "ACard", "props": { "bordered": false }, "children": [
              { "type": "div", "props": { "style": 'display: flex; align-items: center; gap: 16px' }, "children": [
                { "type": "div", "props": { "style": 'width: 48px; height: 48px; border-radius: 8px; background: #e6f4ff; display: flex; align-items: center; justify-content: center; font-size: 22px' }, "children": ["👤"] },
                { "type": "div", "children": [
                  { "type": "div", "props": { "style": 'font-size: 20px; font-weight: 600; color: rgba(0,0,0,0.88); margin-bottom: 4px' }, "children": [{ "$expr": "$state.user?.username||'-'" }] },
                  { "type": "div", "props": { "style": 'font-size: 12px; color: rgba(0,0,0,0.45)' }, "children": ["用户名"] }
                ] }
              ] }
            ] },
            { "type": "ACard", "props": { "bordered": false }, "children": [
              { "type": "div", "props": { "style": 'display: flex; align-items: center; gap: 16px' }, "children": [
                { "type": "div", "props": { "style": 'width: 48px; height: 48px; border-radius: 8px; background: #f6ffed; display: flex; align-items: center; justify-content: center; font-size: 22px' }, "children": ["✉️"] },
                { "type": "div", "children": [
                  { "type": "div", "props": { "style": 'font-size: 20px; font-weight: 600; color: rgba(0,0,0,0.88); margin-bottom: 4px' }, "children": [{ "$expr": "$state.user?.email||'-'" }] },
                  { "type": "div", "props": { "style": 'font-size: 12px; color: rgba(0,0,0,0.45)' }, "children": ["邮箱"] }
                ] }
              ] }
            ] }
          ] },
          { "type": "div", "props": { "style": 'display: grid; grid-template-columns: repeat(auto-fit, minmax(500px, 1fr)); gap: 24px; margin-bottom: 24px' }, "children": [
            { "type": "ACard", "props": { "title": '访问趋势' }, "children": [
              { "type": "ECharts", "props": { "option": { "type": "echarts-option", "body": { "xAxis": { "type": "category", "data": ["周一", "周二", "周三", "周四", "周五", "周六", "周日"] }, "yAxis": { "type": "value" }, "series": [{ "type": "bar", "data": { "$expr": "$state.visitData" }, "itemStyle": { "color": "#1677ff" } }], "tooltip": { "trigger": "axis" } } }, "autoResize": true, "height": 300 } },
              { "type": "div", "props": { "style": 'margin-top: 16px; display: flex; justify-content: flex-end' }, "children": [{ "type": "AButton", "props": { "type": 'primary' }, "directives": { "vOn": { "click": { "$fn": "methods.updateVisitData()" } } }, "children": ["更新数据"] }] }
            ] },
            { "type": "ACard", "props": { "title": '访问来源' }, "children": [{ "type": "ECharts", "props": { "option": { "type": "echarts-option", "body": { "tooltip": { "trigger": "item" }, "legend": { "orient": "vertical", "left": "left" }, "series": [{ "type": "pie", "radius": "60%", "data": { "$expr": "$state.categoryData" }, "label": { "show": true, "formatter": "{b}: {c} ({d}%)" } }] } }, "autoResize": true, "height": 300 } }] }
          ] },
          { "type": "ACard", "props": { "title": '功能特性', "bordered": false }, "children": [
            { "type": "div", "props": { "style": 'display: flex; flex-wrap: wrap; gap: 8px' }, "children": [
              { "type": "span", "props": { "style": { "type": "string", "body": "'background: #f5f5f5; padding: 4px 12px; border-radius: 4px; font-size: 13px'" } }, "children": ["API 请求"] },
              { "type": "span", "props": { "style": { "type": "string", "body": "'background: #f5f5f5; padding: 4px 12px; border-radius: 4px; font-size: 13px'" } }, "children": ["本地存储"] },
              { "type": "span", "props": { "style": { "type": "string", "body": "'background: #f5f5f5; padding: 4px 12px; border-radius: 4px; font-size: 13px'" } }, "children": ["权限检查"] },
              { "type": "span", "props": { "style": { "type": "string", "body": "'background: #f5f5f5; padding: 4px 12px; border-radius: 4px; font-size: 13px'" } }, "children": ["响应式系统"] },
              { "type": "span", "props": { "style": { "type": "string", "body": "'background: #f5f5f5; padding: 4px 12px; border-radius: 4px; font-size: 13px'" } }, "children": ["模板渲染"] },
              { "type": "span", "props": { "style": { "type": "string", "body": "'background: #f5f5f5; padding: 4px 12px; border-radius: 4px; font-size: 13px'" } }, "children": ["指令系统"] }
            ] }
          ] }
        ] }
      ]
    }
  },
  "styles": {
    "scoped": false,
    "css": ""
  }
}