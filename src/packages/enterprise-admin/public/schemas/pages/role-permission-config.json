{
  "name": "RolePermissionConfigPage",
  "state": {
    "roleId": {
      "type": "ref",
      "initial": null
    },
    "roleInfo": {
      "type": "ref",
      "initial": null
    },
    "permissionTree": {
      "type": "ref",
      "initial": []
    },
    "expandedKeys": {
      "type": "ref",
      "initial": []
    },
    "selectedNode": {
      "type": "ref",
      "initial": null
    },
    "currentPermissions": {
      "type": "ref",
      "initial": {
        "pages": [],
        "forms": [],
        "fields": []
      }
    },
    "allRoles": {
      "type": "ref",
      "initial": []
    },
    "compareRoleId": {
      "type": "ref",
      "initial": null
    },
    "compareResult": {
      "type": "ref",
      "initial": null
    },
    "activeTab": {
      "type": "ref",
      "initial": "list"
    },
    "loading": {
      "type": "ref",
      "initial": true
    },
    "saving": {
      "type": "ref",
      "initial": false
    },
    "previewData": {
      "type": "ref",
      "initial": null
    },
    "stats": {
      "type": "ref",
      "initial": {
        "pageLevel": 0,
        "formLevel": 0,
        "fieldLevel": 0,
        "inheritedFieldLevel": 0,
        "total": 0
      }
    },
    "inheritanceTree": {
      "type": "ref",
      "initial": {}
    },
    "selectedNodePerm": {
      "type": "reactive",
      "initial": {
        "read": true,
        "write": true,
        "hidden": false,
        "privacy": false
      }
    }
  },
  "computed": {
    "hasNodeSelected": {
      "get": {
        "$fn": "return !!state.selectedNode"
      }
    },
    "isFieldNode": {
      "get": {
        "$fn": "return !!(state.selectedNode && state.selectedNode.type === 'field')"
      }
    },
    "canInherit": {
      "get": {
        "$fn": "return !!(state.selectedNode && (state.selectedNode.type === 'page' || state.selectedNode.type === 'form'))"
      }
    }
  },
  "methods": {
    "loadRoleId": {
      "$fn": "var hash = window.location.hash; var match = hash.match(/\\/system\\/role\\/([^\\/]+)\\/permissions/); if (match) { state.roleId = match[1]; } else { window.location.hash = '#/system/role'; return; } methods.loadData();"
    },
    "loadData": {
      "$fn": "state.loading = true; Promise.all([$_core.api.get('/api/role/' + state.roleId), $_core.api.get('/api/permission-tree'), $_core.api.get('/api/role/all'), $_core.api.get('/api/role/' + state.roleId + '/permissions/preview')]).then(function(results) { var roleRes = results[0]; var treeRes = results[1]; var rolesRes = results[2]; var previewRes = results[3]; if (roleRes.success) state.roleInfo = roleRes.data; if (treeRes.success) { state.permissionTree = treeRes.data; state.expandedKeys = ['p1', 'm1', 'm2']; } if (rolesRes.success) state.allRoles = rolesRes.data.filter(function(r) { return r.id !== state.roleId; }); if (previewRes.success) { state.previewData = previewRes.data.permissions; state.stats = previewRes.data.stats; state.inheritanceTree = previewRes.data.inheritanceTree; state.currentPermissions = { pages: previewRes.data.permissions.pages || [], forms: previewRes.data.permissions.forms || [], fields: previewRes.data.permissions.fields || [] }; } state.loading = false; }).catch(function(e) { console.error(e); state.loading = false; })"
    },
    "loadCompareResult": {
      "$fn": "if (!state.compareRoleId) return; $_core.api.get('/api/role/compare', { params: { roleId1: state.roleId, roleId2: state.compareRoleId } }).then(function(res) { if (res.success) state.compareResult = res.data; else $_ui.antd.message.error(res.error); });"
    },
    "findNode": {
      "$fn": "var nodes = args[0]; var key = args[1]; for (var i = 0; i < nodes.length; i++) { var n = nodes[i]; if (n.key === key || n.id === key) return n; if (n.children) { var f = methods.findNode(n.children, key); if (f) return f; } } return null;"
    },
    "onSelect": {
      "$fn": "var key = args[0] && args[0][0]; if (!key) { state.selectedNode = null; return; } state.selectedNode = methods.findNode(state.permissionTree, key); if (state.selectedNode && state.selectedNode.type === 'field') { var fieldPerm = state.currentPermissions.fields.find(function(f) { return f.fieldId === state.selectedNode.id; }); if (fieldPerm) { state.selectedNodePerm.read = fieldPerm.read; state.selectedNodePerm.write = fieldPerm.write; state.selectedNodePerm.hidden = fieldPerm.hidden; state.selectedNodePerm.privacy = fieldPerm.privacy; } else { state.selectedNodePerm.read = true; state.selectedNodePerm.write = false; state.selectedNodePerm.hidden = false; state.selectedNodePerm.privacy = false; } }"
    },
    "onExpand": {
      "$fn": "state.expandedKeys = args[0]"
    },
    "handlePageCheck": {
      "$fn": "var node = args[0]; var checked = args[1]; if (checked) { if (!state.currentPermissions.pages.includes(node.code)) state.currentPermissions.pages.push(node.code); } else { var idx = state.currentPermissions.pages.indexOf(node.code); if (idx > -1) state.currentPermissions.pages.splice(idx, 1); } methods.updatePreview();"
    },
    "handleFormCheck": {
      "$fn": "var node = args[0]; var checked = args[1]; if (checked) { if (!state.currentPermissions.forms.includes(node.code)) state.currentPermissions.forms.push(node.code); } else { var idx = state.currentPermissions.forms.indexOf(node.code); if (idx > -1) state.currentPermissions.forms.splice(idx, 1); } methods.updatePreview();"
    },
    "handleFieldPermChange": {
      "$fn": "var fieldId = state.selectedNode.id; var fieldCode = state.selectedNode.code; var fieldName = state.selectedNode.name; var existingIdx = state.currentPermissions.fields.findIndex(function(f) { return f.fieldId === fieldId; }); var newPerm = { fieldId: fieldId, fieldCode: fieldCode, fieldName: fieldName, read: state.selectedNodePerm.read, write: state.selectedNodePerm.write, hidden: state.selectedNodePerm.hidden, privacy: state.selectedNodePerm.privacy, inherited: false }; if (existingIdx > -1) state.currentPermissions.fields[existingIdx] = newPerm; else state.currentPermissions.fields.push(newPerm); methods.updatePreview();"
    },
    "updatePreview": {
      "$fn": "$_core.api.get('/api/role/' + state.roleId + '/permissions/preview').then(function(res) { if (res.success) { state.previewData = res.data.permissions; state.stats = res.data.stats; state.inheritanceTree = res.data.inheritanceTree; } });"
    },
    "handleSave": {
      "$fn": "state.saving = true; $_core.api.put('/api/role/' + state.roleId + '/permissions', { permissions: state.currentPermissions }).then(function(res) { if (res.success) $_ui.antd.message.success('保存成功'); else $_ui.antd.message.error(res.error || '保存失败'); }).finally(function() { state.saving = false; });"
    },
    "handleBack": {
      "$fn": "window.location.hash = '#/system/role'"
    },
    "handleBatchAllow": {
      "$fn": "var type = args[0]; if (type === 'page') state.currentPermissions.pages = ['*']; else if (type === 'form') state.currentPermissions.forms = ['*']; methods.updatePreview();"
    },
    "handleBatchDeny": {
      "$fn": "var type = args[0]; if (type === 'page') state.currentPermissions.pages = []; else if (type === 'form') state.currentPermissions.forms = []; methods.updatePreview();"
    },
    "getNodeTypeText": {
      "$fn": "var type = args[0]; var map = { 'platform': '平台', 'menu': '菜单', 'page': '页面', 'feature': '功能', 'form': '表单', 'field': '字段' }; return map[type] || type;"
    },
    "getNodeTypeColor": {
      "$fn": "var type = args[0]; var map = { 'platform': 'blue', 'menu': 'green', 'page': 'orange', 'feature': 'purple', 'form': 'cyan', 'field': 'gold' }; return map[type] || 'default';"
    },
    "getCompareStats": {
      "$fn": "if (!state.compareResult) return { added: 0, removed: 0, common: 0 }; return { added: state.compareResult.added.length, removed: state.compareResult.removed.length, common: state.compareResult.common.length };"
    }
  },
  "lifecycle": {
    "onMounted": {
      "$fn": "methods.loadRoleId()"
    }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "props": {
        "style": { "type": "object", "body": "{{{ \"padding\": \"24px\" }}}" }
      },
      "children": [
        {
          "type": "div",
          "props": {
            "style": "margin-bottom: 16px; display: flex; align-items: center; gap: 16px"
          },
          "children": [
            {
              "type": "AButton",
              "props": {
                "icon": "'left'",
                "onClick": {
                  "$fn": "methods.handleBack()"
                }
              },
              "children": [
                "返回"
              ]
            },
            {
              "type": "ATitle",
              "props": {
                "level": 4
              },
              "children": [
                {
                  "type": "expression",
                  "body": "{{'角色权限配置: '}}"
                },
                {
                  "type": "expression",
                  "body": "$state.roleInfo?.name || '加载中...'"
                },
                {
                  "type": "expression",
                  "body": "' ('"
                },
                {
                  "type": "expression",
                  "body": "$state.roleInfo?.code"
                },
                {
                  "type": "expression",
                  "body": "{{')'}}"
                }
              ]
            }
          ]
        },
        {
          "type": "div",
          "props": {
            "style": "display: flex; gap: 24px; height: calc(100vh - 200px)"
          },
          "children": [
            {
              "type": "ACard",
              "props": {
                "title": "'权限树'",
                "style": "width: 400px; flex-shrink: 0"
              },
              "children": [
                {
                  "type": "div",
                  "directives": {
                    "vIf": {
                      "$expr": "$state.loading"
                    }
                  },
                  "props": {
                    "style": "text-align: center; padding: 40px 0"
                  },
                  "children": [
                    {
                      "type": "ASpin"
                    }
                  ]
                },
                {
                  "type": "div",
                  "directives": {
                    "vIf": {
                      "$expr": "!$state.loading"
                    }
                  },
                  "children": [
                    {
                      "type": "ATree",
                      "props": {
                        "treeData": {
                          "$expr": "$state.permissionTree"
                        },
                        "selectedKeys": {
                          "$expr": "$state.selectedNode ? [$state.selectedNode.id] : []"
                        },
                        "expandedKeys": {
                          "$expr": "$state.expandedKeys"
                        },
                        "blockNode": true,
                        "showLine": true,
                        "checkable": true,
                        "checkStrictly": true
                      },
                      "directives": {
                        "vOn": {
                          "select": {
                            "$fn": "methods.onSelect(args[0])"
                          },
                          "expand": {
                            "$fn": "methods.onExpand(args[0])"
                          },
                          "check": {
                            "$fn": "var node = args[0]; var checked = args[1]; if (node.type === 'page') methods.handlePageCheck(node, checked); else if (node.type === 'form') methods.handleFormCheck(node, checked);"
                          }
                        }
                      }
                    }
                  ]
                }
              ]
            },
            {
              "type": "ACard",
              "props": {
                "title": "'配置详情'",
                "style": { "type": "object", "body": "{{{ \"flex\": \"1\" }}}" }
              },
              "children": [
                {
                  "type": "div",
                  "directives": {
                    "vIf": {
                      "$expr": "!computed.hasNodeSelected"
                    }
                  },
                  "props": {
                    "style": "text-align: center; padding: 60px 0; color: #999"
                  },
                  "children": [
                    "请从左侧选择一个节点进行配置"
                  ]
                },
                {
                  "type": "div",
                  "directives": {
                    "vIf": {
                      "$expr": "computed.hasNodeSelected"
                    }
                  },
                  "children": [
                    {
                      "type": "div",
                      "props": {
                        "style": { "type": "object", "body": "{{{ \"marginBottom\": \"16px\" }}}" }
                      },
                      "children": [
                        {
                          "type": "ASpace",
                          "children": [
                            {
                              "type": "ATag",
                              "props": {
                                "color": {
                                  "$expr": "methods.getNodeTypeColor($state.selectedNode.type)"
                                }
                              },
                              "children": [
                                {
                                  "$expr": "methods.getNodeTypeText($state.selectedNode.type)"
                                }
                              ]
                            },
                            {
                              "type": "span",
                              "props": {
                                "style": { "type": "object", "body": "{{{ \"fontWeight\": \"500\" }}}" }
                              },
                              "children": [
                                {
                                  "$expr": "$state.selectedNode.name"
                                }
                              ]
                            },
                            {
                              "type": "span",
                              "props": {
                                "style": "margin-left: 8px; color: #666"
                              },
                              "children": [
                                {
                                  "type": "expression",
                                  "body": "'('"
                                },
                                {
                                  "type": "expression",
                                  "body": "$state.selectedNode.code"
                                },
                                {
                                  "type": "expression",
                                  "body": "{{')'}}"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "ATabs",
                      "props": {
                        "activeKey": {
                          "$expr": "$state.activeTab"
                        },
                        "onChange": {
                          "$fn": "$state.activeTab = args[0]"
                        }
                      },
                      "children": [
                        {
                          "type": "ATabsTab",
                          "props": {
                            "key": "'list'",
                            "tab": "'权限列表'"
                          },
                          "children": [
                            {
                              "type": "div",
                              "directives": {
                                "vIf": {
                                  "$expr": "computed.canInherit"
                                }
                              },
                              "props": {
                                "style": { "type": "object", "body": "{{{ \"marginBottom\": \"16px\" }}}" }
                              },
                              "children": [
                                {
                                  "type": "ASpace",
                                  "children": [
                                    {
                                      "type": "AButton",
                                      "props": {
                                        "size": "'small'",
                                        "onClick": {
                                          "$fn": "methods.handleBatchAllow($state.selectedNode.type)"
                                        }
                                      },
                                      "children": [
                                        "全部允许"
                                      ]
                                    },
                                    {
                                      "type": "AButton",
                                      "props": {
                                        "size": "'small'",
                                        "onClick": {
                                          "$fn": "methods.handleBatchDeny($state.selectedNode.type)"
                                        }
                                      },
                                      "children": [
                                        "全部禁止"
                                      ]
                                    }
                                  ]
                                }
                              ]
                            },
                            {
                              "type": "ACheckbox",
                              "props": {
                                "checked": { "$expr": "$state.selectedNodePerm.read" }, "onChange": { "$fn": "state.selectedNodePerm.read=args[0].target.checked; methods.handleFieldPermChange()" }",
                                "style": { "type": "object", "body": "{{{ \"marginRight\": \"24px\" }}}" },
                                "disabled": {
                                  "$expr": "!computed.isFieldNode"
                                }
                              },
                              "children": [
                                "可读"
                              ]
                            },
                            {
                              "type": "ACheckbox",
                              "props": {
                                "checked": { "$expr": "$state.selectedNodePerm.write" }, "onChange": { "$fn": "state.selectedNodePerm.write=args[0].target.checked; methods.handleFieldPermChange()" }",
                                "style": { "type": "object", "body": "{{{ \"marginRight\": \"24px\" }}}" },
                                "disabled": {
                                  "$expr": "!computed.isFieldNode"
                                }
                              },
                              "children": [
                                "可写"
                              ]
                            },
                            {
                              "type": "ACheckbox",
                              "props": {
                                "checked": { "$expr": "$state.selectedNodePerm.hidden" }, "onChange": { "$fn": "state.selectedNodePerm.hidden=args[0].target.checked; methods.handleFieldPermChange()" }",
                                "style": { "type": "object", "body": "{{{ \"marginRight\": \"24px\" }}}" },
                                "disabled": {
                                  "$expr": "!computed.isFieldNode"
                                }
                              },
                              "children": [
                                "隐藏"
                              ]
                            },
                            {
                              "type": "ACheckbox",
                              "props": {
                                "checked": { "$expr": "$state.selectedNodePerm.privacy" }, "onChange": { "$fn": "state.selectedNodePerm.privacy=args[0].target.checked; methods.handleFieldPermChange()" }",
                                "disabled": {
                                  "$expr": "!computed.isFieldNode"
                                }
                              },
                              "children": [
                                "隐私"
                              ]
                            }
                          ]
                        },
                        {
                          "type": "ATabsTab",
                          "props": {
                            "key": "'stats'",
                            "tab": "'权限统计'"
                          },
                          "children": [
                            {
                              "type": "ARow",
                              "props": {
                                "gutter": 16
                              },
                              "children": [
                                {
                                  "type": "ACol",
                                  "props": {
                                    "span": 8
                                  },
                                  "children": [
                                    {
                                      "type": "ACard",
                                      "props": {
                                        "bordered": false,
                                        "style": { "type": "object", "body": "{{{ \"background\": \"#e6f4ff\" }}}" }
                                      },
                                      "children": [
                                        {
                                          "type": "div",
                                          "props": {
                                            "style": "font-size: 24px; font-weight: 600; color: #1677ff"
                                          },
                                          "children": [
                                            {
                                              "$expr": "$state.stats.pageLevel"
                                            }
                                          ]
                                        },
                                        {
                                          "type": "div",
                                          "props": {
                                            "style": "font-size: 14px; color: #666"
                                          },
                                          "children": [
                                            "页面级权限"
                                          ]
                                        }
                                      ]
                                    }
                                  ]
                                },
                                {
                                  "type": "ACol",
                                  "props": {
                                    "span": 8
                                  },
                                  "children": [
                                    {
                                      "type": "ACard",
                                      "props": {
                                        "bordered": false,
                                        "style": { "type": "object", "body": "{{{ \"background\": \"#f6ffed\" }}}" }
                                      },
                                      "children": [
                                        {
                                          "type": "div",
                                          "props": {
                                            "style": "font-size: 24px; font-weight: 600; color: #52c41a"
                                          },
                                          "children": [
                                            {
                                              "$expr": "$state.stats.formLevel"
                                            }
                                          ]
                                        },
                                        {
                                          "type": "div",
                                          "props": {
                                            "style": "font-size: 14px; color: #666"
                                          },
                                          "children": [
                                            "表单级权限"
                                          ]
                                        }
                                      ]
                                    }
                                  ]
                                },
                                {
                                  "type": "ACol",
                                  "props": {
                                    "span": 8
                                  },
                                  "children": [
                                    {
                                      "type": "ACard",
                                      "props": {
                                        "bordered": false,
                                        "style": { "type": "object", "body": "{{{ \"background\": \"#fff7e6\" }}}" }
                                      },
                                      "children": [
                                        {
                                          "type": "div",
                                          "props": {
                                            "style": "font-size: 24px; font-weight: 600; color: #fa8c16"
                                          },
                                          "children": [
                                            {
                                              "$expr": "$state.stats.fieldLevel"
                                            }
                                          ]
                                        },
                                        {
                                          "type": "div",
                                          "props": {
                                            "style": "font-size: 14px; color: #666"
                                          },
                                          "children": [
                                            "字段级权限"
                                          ]
                                        }
                                      ]
                                    }
                                  ]
                                }
                              ]
                            },
                            {
                              "type": "ADivider",
                              "children": [
                                "继承统计"
                              ]
                            },
                            {
                              "type": "ACard",
                              "props": {
                                "bordered": false,
                                "style": { "type": "object", "body": "{{{ \"background\": \"#f5f5f5\" }}}" }
                              },
                              "children": [
                                {
                                  "type": "div",
                                  "props": {
                                    "style": { "type": "object", "body": "{{{ \"fontSize\": \"14px\" }}}" }
                                  },
                                  "children": [
                                    {
                                      "type": "span",
                                      "children": [
                                        "直接配置字段权限: "
                                      ]
                                    },
                                    {
                                      "type": "span",
                                      "props": {
                                        "style": { "type": "object", "body": "{{{ \"fontWeight\": \"600\" }}}" }
                                      },
"children": [
                                         {
                                           "$expr": "$state.stats.fieldLevel"
                                         }
                                       ]
                                     },
                                     {
                                       "type": "span",
                                       "children": [
                                         " 个"
                                       ]
                                     }
                                   ]
                                 },
                                 {
                                   "type": "div",
                                   "props": {
                                    "style": "font-size: 14px; margin-top: 8px"
                                  },
                                  "children": [
                                    {
                                      "type": "span",
                                      "children": [
                                        "继承字段权限: "
                                      ]
                                    },
                                    {
                                      "type": "span",
                                      "props": {
                                        "style": { "type": "object", "body": "{{{ \"fontWeight\": \"600\" }}}" }
                                      },
"children": [
                                         {
                                           "$expr": "$state.stats.inheritedFieldLevel"
                                         }
                                       ]
                                    },
                                    {
                                      "type": "span",
                                      "children": [
                                        " 个"
                                      ]
                                    }
                                  ]
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "ATabsTab",
                          "props": {
                            "key": "'inheritance'",
                            "tab": "'继承关系'"
                          },
                          "children": [
                            {
                              "type": "ADescriptions",
                              "props": {
                                "column": 1,
                                "bordered": true,
                                "size": "'small'"
                              },
                              "children": [
                                {
                                  "type": "ADescriptionsItem",
                                  "props": {
                                    "label": "'继承说明'"
                                  },
                                  "children": [
                                    {
                                      "type": "ul",
                                      "props": {
                                        "style": "margin: 0; padding-left: 20px"
                                      },
                                      "children": [
                                        {
                                          "type": "li",
                                          "children": [
                                            "页面级权限开启后，所有子表单和字段默认继承可读权限"
                                          ]
                                        },
                                        {
                                          "type": "li",
                                          "children": [
                                            "表单级权限开启后，所有子字段默认继承可读权限"
                                          ]
                                        },
                                        {
                                          "type": "li",
                                          "children": [
                                            "字段级权限可以单独配置，覆盖继承权限"
                                          ]
                                        }
                                      ]
                                    }
                                  ]
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "ATabsTab",
                          "props": {
                            "key": "'compare'",
                            "tab": "'角色对比'"
                          },
                          "children": [
                            {
                              "type": "ASpace",
                              "props": {
