{
  "name": "AppLayout",
  "state": {
    "collapsed": { "type": "ref", "initial": false },
    "user": { "type": "ref", "initial": null },
    "currentRoute": { "type": "ref", "initial": "" }
  },
  "computed": {
    "selectedKeys": {
      "get": {
        "type": "function",
        "params": "{{{}}}",
        "body": "{{var path = window.location.hash.slice(1) || '/'; if(path.includes('dashboard')) return ['dashboard']; if(path.includes('basic-data')) return ['basic-data']; if(path.includes('role')) return ['role-management']; return ['dashboard']}}"
      }
    }
  },
  "props": {
    "pageContent": { "type": "any", "default": null }
  },
  "methods": {
    "loadUser": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{var u=$_core_storage.get('userInfo');if(u)ref_state_user=u}}",
      "cached": false
    },
    "logout": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{$_core_storage.remove('token');$_core_storage.remove('userInfo');$_core_storage.remove('permissions');window.location.hash='#/login'}}",
      "cached": false
    }
  },
  "lifecycle": {
    "onMounted": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{methods.loadUser()}}"
    }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "props": { "style": { "type": "string", "body": "'min-height: 100vh'" } },
      "children": [
        {
          "type": "ALayout",
          "props": { "style": { "type": "string", "body": "'min-height: 100vh'" } },
          "children": [
            {
              "type": "ALayoutSider",
              "props": {
                "theme": { "type": "string", "body": "'light'" },
                "collapsible": true,
                "collapsed": { "type": "expression", "body": "{{ref_state_collapsed}}" },
                "style": { "type": "string", "body": "'min-height: 100vh; overflow: auto'" }
              },
              "directives": {
                "vOn": {
                  "collapse": { "type": "function", "params": "{{{}}}", "body": "{{var collapsed=args[0];ref_state_collapsed = collapsed}}" }
                }
              },
              "children": [
                {
                  "type": "div",
                  "props": { "style": { "type": "string", "body": "'height: 64px; display: flex; align-items: center; justify-content: center; border-bottom: 1px solid #f0f0f0; font-size: 16px; font-weight: 600; color: #1677ff'" } },
                  "children": [{ "type": "expression", "body": "{{ref_state_collapsed ? 'E' : '企业管理系统'}}" }]
                },
                {
                  "type": "AMenu",
                  "props": {
                    "theme": { "type": "string", "body": "'light'" },
                    "mode": { "type": "string", "body": "'inline'" },
                    "selectedKeys": { "type": "expression", "body": "{{ref_computed_selectedKeys.value}}" },
                    "style": { "type": "string", "body": "'border: none; height: calc(100vh - 64px); overflow-y: auto'" }
                  },
                  "children": [
                    { "type": "AMenuItem", "props": { "key": { "type": "string", "body": "'dashboard'" } }, "directives": { "vOn": { "click": { "type": "function", "params": "{{{}}}", "body": "{{window.location.hash='#/dashboard'}}" } } }, "children": ["首页"] },
                    { "type": "AMenuItem", "props": { "key": { "type": "string", "body": "'basic-data'" } }, "directives": { "vOn": { "click": { "type": "function", "params": "{{{}}}", "body": "{{window.location.hash='#/basic-data-config'}}" } } }, "children": ["基础数据配置"] },
                    { "type": "AMenuItem", "props": { "key": { "type": "string", "body": "'role-management'" } }, "directives": { "vOn": { "click": { "type": "function", "params": "{{{}}}", "body": "{{window.location.hash='#/system/role'}}" } } }, "children": ["角色管理"] }
                  ]
                }
              ]
            },
            {
              "type": "ALayout",
              "props": { "style": { "type": "string", "body": "'min-height: 100vh; display: flex; flex-direction: column; flex: 1'" } },
              "children": [
                {
                  "type": "ALayoutHeader",
                  "props": { "style": { "type": "string", "body": "'background: #fff; padding: 0 24px; border-bottom: 1px solid #f0f0f0; display: flex; justify-content: space-between; align-items: center'" } },
                  "children": [
                    {
                      "type": "div",
                      "props": { "style": { "type": "string", "body": "'font-size: 16px; font-weight: 600'" } },
                      "children": [{ "type": "expression", "body": "{{ref_state_user?.nickname || ref_state_user?.username || '用户'}}" }]
                    },
                    {
                      "type": "div",
                      "props": { "style": { "type": "string", "body": "'display: flex; align-items: center; gap: 16px'" } },
                      "children": [
                        {
                          "type": "AButton",
                          "props": { "type": { "type": "string", "body": "'link'" } },
                          "directives": { "vOn": { "click": { "type": "function", "params": "{{{}}}", "body": "{{methods.logout()}}" } } },
                          "children": ["退出"]
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "ALayoutContent",
                  "props": { "style": { "type": "string", "body": "'padding: 24px; background: #f5f5f5; overflow-y: auto'" } },
                  "children": [
                    { "type": "expression", "body": "{{ref_props_pageContent}}" }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  },
  "styles": {
    "scoped": false,
    "css": ""
  }
}