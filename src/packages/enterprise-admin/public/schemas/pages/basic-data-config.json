{
  "name": "BasicDataConfigPage",
  "state": {
    "treeData": { "type": "ref", "initial": [] },
    "expandedKeys": { "type": "ref", "initial": [] },
    "selectedKey": { "type": "ref", "initial": null },
    "selectedNode": { "type": "ref", "initial": null },
    "loading": { "type": "ref", "initial": true },
    "editForm": { "type": "reactive", "initial": { "code": "", "name": "", "read": true, "write": true, "hidden": false, "privacy": false } },
    "saving": { "type": "ref", "initial": false },
    "addModalVisible": { "type": "ref", "initial": false },
    "addFormData": { "type": "reactive", "initial": { "code": "", "name": "", "nodeType": "field" } },
    "deleteModalVisible": { "type": "ref", "initial": false }
  },
  "computed": {
    "isFieldSelected": {
      "get": {
        "$fn": "return state.selectedNode && state.selectedNode.type==='field'"
      }
    },
    "isNotRoot": {
      "get": {
        "$fn": "return state.selectedNode && state.selectedNode.parentId"
      }
    },
    "hasSelected": {
      "get": {
        "$fn": "return !!state.selectedKey"
      }
    },
    "canAddChild": {
      "get": {
        "$fn": "return state.selectedNode && (state.selectedNode.type==='platform' || state.selectedNode.type==='menu' || state.selectedNode.type==='page' || state.selectedNode.type==='feature' || state.selectedNode.type==='form')"
      }
    },
    "addFormIsValid": {
      "get": {
        "$fn": "return !!state.addFormData.code && !!state.addFormData.name"
      }
    }
  },
  "methods": {
    "loadTreeData": {
      "$fn": "state.loading=true; $_core_api.get('/api/basic-data/tree').then(function(d){var raw=d.data||[]; var transform=function(nodes){return nodes.map(function(n){var r={key:n.id,title:n.name,type:n.type,code:n.code,id:n.id,parentId:n.parentId,permissions:n.permissions}; if(n.children&&n.children.length>0){r.children=transform(n.children)} return r})}; state.treeData=transform(raw); state.expandedKeys=['p1','m1','m2']; state.loading=false}).catch(function(e){console.error(e); state.loading=false})",
      "cached": false
    },
    "onSelect": {
      "$fn": "var key=$event&&$event[0]; if(!key){state.selectedKey=null; state.selectedNode=null; return} state.selectedKey=key; var node=methods.findNode(state.treeData,key); state.selectedNode=node; if(node&&node.type==='field'){state.editForm.code=node.code; state.editForm.name=node.name; state.editForm.read=node.permissions?.read??true; state.editForm.write=node.permissions?.write??true; state.editForm.hidden=node.permissions?.hidden??false; state.editForm.privacy=node.permissions?.privacy??false} else if(node){state.editForm.code=node.code; state.editForm.name=node.name}",
      "cached": false
    },
    "findNode": {
      "$fn": "var nodes=args[0];var key=args[1];for(var i=0;i<nodes.length;i++){var n=nodes[i]; if(n.key===key)return n; if(n.children){var f=methods.findNode(n.children,key); if(f)return f}} return null",
      "cached": false
    },
    "onExpand": {
      "$fn": "state.expandedKeys=$event",
      "cached": false
    },
    "getNodeTypeText": {
      "$fn": "var type=args[0];var map={'platform':'平台','menu':'菜单','page':'页面','feature':'功能','form':'表单','field':'字段'};return map[type]||type",
      "cached": false
    },
    "handleSavePermissions": {
      "$fn": "if(!state.selectedNode||state.selectedNode.type!=='field')return; state.saving=true; var data={permissions:{read:state.editForm.read,write:state.editForm.write,hidden:state.editForm.hidden,privacy:state.editForm.privacy}}; $_core_api.put('/api/basic-data/node/'+state.selectedNode.id,data).then(function(res){if(res.success){$_antd.message.success('保存成功'); methods.loadTreeData()}else{$_antd.message.error(res.error||'保存失败')}}).catch(function(e){$_antd.message.error('保存失败');console.error(e)}).finally(function(){state.saving=false})",
      "cached": false
    },
    "handleAddNode": {
      "$fn": "if(!state.selectedNode)return; state.addFormData.code=''; state.addFormData.name=''; var typeMap={'platform':'menu','menu':'page','page':'feature','feature':'form','form':'field'}; state.addFormData.nodeType=typeMap[state.selectedNode.type]||'field'; state.addModalVisible=true",
      "cached": false
    },
    "confirmAddNode": {
      "$fn": "if(!state.addFormData.code||!state.addFormData.name){$_antd.message.warning('请填写必填项');return} state.saving=true; var data={code:state.addFormData.code,name:state.addFormData.name,type:state.addFormData.nodeType,parentId:state.selectedNode.id,permissions:{read:true,write:true,hidden:false,privacy:false}}; $_core_api.post('/api/basic-data/node',data).then(function(res){if(res.success){$_antd.message.success('新增成功'); state.addModalVisible=false; methods.loadTreeData()}else{$_antd.message.error(res.error||'新增失败')}}).catch(function(e){$_antd.message.error('新增失败');console.error(e)}).finally(function(){state.saving=false})",
      "cached": false
    },
    "cancelAddNode": {
      "$fn": "state.addModalVisible=false",
      "cached": false
    },
    "handleDeleteNode": {
      "$fn": "if(!state.selectedNode||!state.selectedNode.parentId)return; state.deleteModalVisible=true",
      "cached": false
    },
    "confirmDeleteNode": {
      "$fn": "if(!state.selectedNode)return; state.saving=true; $_core_api.delete('/api/basic-data/node/'+state.selectedNode.id).then(function(res){if(res.success){$_antd.message.success('删除成功'); state.deleteModalVisible=false; state.selectedKey=null; state.selectedNode=null; methods.loadTreeData()}else{$_antd.message.error(res.error||'删除失败')}}).catch(function(e){$_antd.message.error('删除失败');console.error(e)}).finally(function(){state.saving=false})",
      "cached": false
    },
    "cancelDeleteNode": {
      "$fn": "state.deleteModalVisible=false",
      "cached": false
    }
  },
  "lifecycle": {
    "onMounted": {
      "$fn": "methods.loadTreeData()"
    }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "props": {
        "style": {
          "type": "string",
          "body": "'padding: 24px'"
        }
      },
      "children": [
        {
          "type": "div",
          "props": {
            "style": {
              "type": "string",
              "body": "'margin-bottom: 16px'"
            }
          },
          "children": [
            {
              "type": "ASpace",
              "children": [
                {
                  "type": "AButton",
                  "props": {
                    "type": {
                      "type": "string",
                      "body": "'primary'"
                    },
                    "icon": {
                      "type": "string",
                      "body": "'plus'"
                    },
                    "disabled": {
                      "$expr": "!computed.canAddChild"
                    },
                    "onClick": {
                      "type": "function",
                      "params": "{{{}}}",
                      "body": "{{methods.handleAddNode()}}"
                    }
                  },
                  "children": ["新增节点"]
                },
                {
                  "type": "AButton",
                  "props": {
                    "icon": {
                      "type": "string",
                      "body": "'delete'"
                    },
                    "danger": true,
                    "disabled": {
                      "$expr": "!computed.isNotRoot"
                    },
                    "onClick": {
                      "type": "function",
                      "params": "{{{}}}",
                      "body": "{{methods.handleDeleteNode()}}"
                    }
                  },
                  "children": ["删除节点"]
                }
              ]
            }
          ]
        },
        {
          "type": "div",
          "props": {
            "style": {
              "type": "string",
              "body": "'display: flex; gap: 24px; height: calc(100vh - 200px)'"
            }
          },
          "children": [
            {
              "type": "ACard",
              "props": {
                "title": {
                  "type": "string",
                  "body": "'层级结构'"
                },
                "style": {
                  "type": "string",
                  "body": "'width: 360px; flex-shrink: 0'"
                }
              },
              "children": [
                {
                  "type": "div",
                  "directives": {
                    "vIf": {
                      "$expr": "$state.loading"
                    }
                  },
                  "props": {
                    "style": {
                      "type": "string",
                      "body": "'text-align: center; padding: 40px 0'"
                    }
                  },
                  "children": [{"type": "ASpin"}]
                },
                {
                  "type": "ATree",
                  "props": {
                    "treeData": {
                      "$expr": "$state.treeData"
                    },
                    "selectedKeys": {
                      "$expr": "[$state.selectedKey]"
                    },
                    "expandedKeys": {
                      "$expr": "$state.expandedKeys"
                    },
                    "blockNode": true,
                    "showLine": true
                  },
                  "directives": {
                    "vOn": {
                      "select": {
                        "$fn": "methods.onSelect($event)"
                      },
                      "expand": {
                        "$fn": "methods.onExpand($event)"
                      }
                    }
                  }
                }
              ]
            },
            {
              "type": "ACard",
              "props": {
                "title": {
                  "type": "string",
                  "body": "'配置详情'"
                },
                "style": {
                  "type": "string",
                  "body": "'flex: 1'"
                }
              },
              "children": [
                {
                  "type": "div",
                  "directives": {
                    "vIf": {
                      "$expr": "!computed.hasSelected"
                    }
                  },
                  "props": {
                    "style": {
                      "type": "string",
                      "body": "'text-align: center; padding: 60px 0; color: #999'"
                    }
                  },
                  "children": ["请从左侧选择一个节点"]
                },
                {
                  "type": "div",
                  "directives": {
                    "vIf": {
                      "$expr": "computed.hasSelected"
                    }
                  },
                  "children": [
                    {
                      "type": "div",
                      "props": {
                        "style": {
                          "type": "string",
                          "body": "'margin-bottom: 16px'"
                        }
                      },
                      "children": [
                        {
                          "type": "ATag",
                          "props": {
                            "color": {
                              "$expr": "$state.selectedNode.type==='platform' ? 'blue' : $state.selectedNode.type==='menu' ? 'green' : $state.selectedNode.type==='page' ? 'orange' : $state.selectedNode.type==='feature' ? 'purple' : $state.selectedNode.type==='form' ? 'cyan' : 'gold'"
                            }
                          },
                          "children": [
                            {
                              "$expr": "methods.getNodeTypeText($state.selectedNode.type)"
                            }
                          ]
                        },
                        {
                          "type": "span",
                          "props": {
                            "style": {
                              "type": "string",
                              "body": "'margin-left: 8px; font-weight: 500'"
                            }
                          },
                          "children": [
                            {
                              "$expr": "$state.selectedNode.name"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "ADescriptions",
                      "props": {
                        "column": 2,
                        "bordered": true,
                        "size": {
                          "type": "string",
                          "body": "'small'"
                        }
                      },
                      "children": [
                        {
                          "type": "ADescriptionsItem",
                          "props": {
                            "label": {
                              "type": "string",
                              "body": "'编码'"
                            }
                          },
"children": [
                            {
                              "$expr": "methods.getNodeTypeText($state.selectedNode.type)"
                            }
                          ]
                        },
                        {
                          "type": "ADescriptionsItem",
                          "props": {
                            "label": {
                              "type": "string",
                              "body": "'名称'"
                            }
                          },
                          "children": [
                            {
                              "$expr": "$state.selectedNode.name"
                            }
                          ]
                        },
                        {
                          "type": "ADescriptionsItem",
                          "props": {
                            "label": {
                              "type": "string",
                              "body": "'类型'"
                            }
                          },
                          "children": [
                            {
                              "$expr": "methods.getNodeTypeText($state.selectedNode.type)"
                            }
                          ]
                        },
                        {
                          "type": "ADescriptionsItem",
                          "props": {
                            "label": {
                              "type": "string",
                              "body": "'ID'"
                            }
                          },
"children": [
                            {
                              "$expr": "$state.selectedNode.name"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "div",
                      "directives": {
"vIf": {
                      "$expr": "computed.isFieldSelected"
                    }
                      },
                      "props": {
                        "style": {
                          "type": "string",
                          "body": "'margin-top: 24px'"
                        }
                      },
                      "children": [
                        {
                          "type": "ATitle",
                          "props": {
                            "level": 5
                          },
                          "children": ["字段权限"]
                        },
                        {
                          "type": "ACheckbox",
                          "props": {
                            "checked": {
                              "$expr": "$state.editForm.read"
                            },
                            "onChange": {
                              "$fn": "state.editForm.read=args[0].target.checked"
                            },
                            "style": {
                              "type": "string",
                              "body": "'margin-right: 24px'"
                            }
                          },
                          "children": ["可读"]
                        },
                        {
                          "type": "ACheckbox",
                          "props": {
                            "checked": {
                              "$expr": "$state.editForm.write"
                            },
                            "onChange": {
                              "$fn": "state.editForm.write=args[0].target.checked"
                            },
                            "style": {
                              "type": "string",
                              "body": "'margin-right: 24px'"
                            }
                          },
                          "children": ["可写"]
                        },
                        {
                          "type": "ACheckbox",
                          "props": {
                            "checked": {
                              "$expr": "$state.editForm.hidden"
                            },
                            "onChange": {
                              "$fn": "state.editForm.hidden=args[0].target.checked"
                            },
                            "style": {
                              "type": "string",
                              "body": "'margin-right: 24px'"
                            }
                          },
                          "children": ["隐藏"]
                        },
                        {
                          "type": "ACheckbox",
                          "props": {
                            "checked": {
                              "$expr": "$state.editForm.privacy"
                            },
                            "onChange": {
                              "$fn": "state.editForm.privacy=args[0].target.checked"
                            }
                          },
                          "children": ["隐私"]
                        },
                        {
                          "type": "AButton",
                          "props": {
                            "type": {
                              "type": "string",
                              "body": "'primary'"
                            },
                            "loading": {
                              "$expr": "$state.saving"
                            },
                            "onClick": {
                              "type": "function",
                              "params": "{{{}}}",
                              "body": "{{methods.handleSavePermissions()}}"
                            },
                            "style": {
                              "type": "string",
                              "body": "'margin-top: 16px'"
                            }
                          },
                          "children": ["保存权限"]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "AModal",
          "props": {
            "title": {
              "type": "string",
              "body": "'新增节点'"
            },
            "open": {
              "$expr": "$state.addModalVisible"
            },
            "onOk": {
              "type": "function",
              "params": "{{{}}}",
              "body": "{{methods.confirmAddNode()}}"
            },
            "onCancel": {
              "type": "function",
              "params": "{{{}}}",
              "body": "{{methods.cancelAddNode()}}"
            },
            "confirmLoading": {
              "$expr": "$state.saving"
            }
          },
          "children": [
            {
              "type": "AForm",
              "props": {
                "layout": "vertical"
              },
              "children": [
                {
                  "type": "AFormItem",
                  "props": {
                    "label": {
                      "type": "string",
                      "body": "'节点编码'"
                    },
                    "required": true
                  },
                  "children": [
                    {
                      "type": "AInput",
                      "props": {
                        "placeholder": {
                          "type": "string",
                          "body": "'请输入节点编码'"
                        },
                        "value": {
                          "$expr": "$state.addFormData.code"
                        },
                        "onChange": {
                          "$fn": "state.addFormData.code=args[0].target.value"
                        }
                      }
                    }
                  ]
                },
                {
                  "type": "AFormItem",
                  "props": {
                    "label": {
                      "type": "string",
                      "body": "'节点名称'"
                    },
                    "required": true
                  },
                  "children": [
                    {
                      "type": "AInput",
                      "props": {
                        "placeholder": {
                          "type": "string",
                          "body": "'请输入节点名称'"
                        },
                        "value": {
                          "$expr": "$state.addFormData.name"
                        },
                        "onChange": {
                          "$fn": "state.addFormData.name=args[0].target.value"
                        }
                      }
                    }
                  ]
                },
                {
                  "type": "AFormItem",
                  "props": {
                    "label": {
                      "type": "string",
                      "body": "'节点类型'"
                    }
                  },
                  "children": [
                    {
                      "type": "ASelect",
                      "props": {
                        "value": {
                          "$expr": "$state.addFormData.nodeType"
                        },
                        "onChange": {
                          "$fn": "state.addFormData.nodeType=args[0]"
                        },
                        "disabled": true
                      },
                      "children": [
                        {
                          "type": "ASelectOption",
                          "props": {
                            "value": {
                              "type": "string",
                              "body": "'menu'"
                            }
                          },
                          "children": ["菜单"]
                        },
                        {
                          "type": "ASelectOption",
                          "props": {
                            "value": {
                              "type": "string",
                              "body": "'page'"
                            }
                          },
                          "children": ["页面"]
                        },
                        {
                          "type": "ASelectOption",
                          "props": {
                            "value": {
                              "type": "string",
                              "body": "'feature'"
                            }
                          },
                          "children": ["功能"]
                        },
                        {
                          "type": "ASelectOption",
                          "props": {
                            "value": {
                              "type": "string",
                              "body": "'form'"
                            }
                          },
                          "children": ["表单"]
                        },
                        {
                          "type": "ASelectOption",
                          "props": {
                            "value": {
                              "type": "string",
                              "body": "'field'"
                            }
                          },
                          "children": ["字段"]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "AModal",
          "props": {
            "title": {
              "type": "string",
              "body": "'确认删除'"
            },
            "open": {
              "$expr": "$state.deleteModalVisible"
            },
            "onOk": {
              "type": "function",
              "params": "{{{}}}",
              "body": "{{methods.confirmDeleteNode()}}"
            },
            "onCancel": {
              "type": "function",
              "params": "{{{}}}",
              "body": "{{methods.cancelDeleteNode()}}"
            },
"confirmLoading": {
              "$expr": "$state.saving"
            }
          },
          "children": [
            {
              "type": "p",
              "children": [
                {
                  "type": "expression",
                  "body": "'确定要删除节点 \"' + ($state.selectedNode?.name || '') + '\" 吗？该操作将同时删除其所有子节点。'"
                }
              ]
            }
          ]
            }
          ]
        }
      ]
    }
  },
  "styles": {
    "scoped": false,
    "css": ""
  }
}