{
  "name": "RoleManagementPage",
  "state": {
    "roleList": { "type": "ref", "initial": [] },
    "loading": { "type": "ref", "initial": true },
    "pagination": { "type": "reactive", "initial": { "current": 1, "pageSize": 10, "total": 0 } },
    "searchForm": { "type": "reactive", "initial": { "keyword": "", "status": "" } },
    "selectedRow": { "type": "ref", "initial": null },
    "modalVisible": { "type": "ref", "initial": false },
    "modalTitle": { "type": "ref", "initial": "新增角色" },
    "editingRole": { "type": "ref", "initial": null },
    "formData": { "type": "reactive", "initial": { "code": "", "name": "", "description": "", "status": "active" } },
    "confirmLoading": { "type": "ref", "initial": false },
    "deleteModalVisible": { "type": "ref", "initial": false },
    "deletingRole": { "type": "ref", "initial": null },
    "statusToggleModalVisible": { "type": "ref", "initial": false },
    "togglingRole": { "type": "ref", "initial": null }
  },
  "computed": {
    "hasSelected": {
      "get": {
        "$fn": "return !!state.selectedRow"
      }
    },
    "isEditing": {
      "get": {
        "$fn": "return !!state.editingRole"
      }
    },
    "formIsValid": {
      "get": {
        "$fn": "return !!state.formData.code && !!state.formData.name"
      }
    }
  },
  "methods": {
    "loadRoleList": {
      "$fn": "state.loading = true; var params = { page: state.pagination.current, pageSize: state.pagination.pageSize, keyword: state.searchForm.keyword, status: state.searchForm.status }; $_core_api.get('/api/role/list', { params: params }).then(function(res) { state.roleList = res.data.list; state.pagination.total = res.data.total; state.loading = false; }).catch(function(e) { console.error(e); $_antd.message.error('加载失败'); state.loading = false; })"
    },
    "handleSearch": {
      "$fn": "state.pagination.current = 1; methods.loadRoleList()"
    },
    "handleReset": {
      "$fn": "state.searchForm.keyword = ''; state.searchForm.status = ''; state.pagination.current = 1; methods.loadRoleList()"
    },
    "handleTableChange": {
      "$fn": "state.pagination.current = args[0].current; state.pagination.pageSize = args[0].pageSize; methods.loadRoleList()"
    },
    "handleAdd": {
      "$fn": "state.editingRole = null; state.modalTitle = '新增角色'; state.formData.code = ''; state.formData.name = ''; state.formData.description = ''; state.formData.status = 'active'; state.modalVisible = true"
    },
    "handleEdit": {
      "$fn": "state.editingRole = args[0]; state.modalTitle = '编辑角色'; state.formData.code = args[0].code; state.formData.name = args[0].name; state.formData.description = args[0].description || ''; state.formData.status = args[0].status; state.modalVisible = true"
    },
    "handleDelete": {
      "$fn": "state.deletingRole = args[0]; state.deleteModalVisible = true"
    },
    "confirmDelete": {
      "$fn": "if (!state.deletingRole) return; state.confirmLoading = true; $_core_api.delete('/api/role/' + state.deletingRole.id).then(function(res) { if (res.success) { $_antd.message.success('删除成功'); state.deleteModalVisible = false; methods.loadRoleList(); } else { $_antd.message.error(res.error || '删除失败'); } }).catch(function(e) { $_antd.message.error('删除失败'); console.error(e); }).finally(function() { state.confirmLoading = false; state.deletingRole = null; })"
    },
    "cancelDelete": {
      "$fn": "state.deleteModalVisible = false; state.deletingRole = null"
    },
    "handleModalOk": {
      "$fn": "if (!computed.formIsValid) { $_antd.message.warning('请填写必填项'); return; } state.confirmLoading = true; var data = { code: state.formData.code, name: state.formData.name, description: state.formData.description, status: state.formData.status }; var promise = state.editingRole ? $_core_api.put('/api/role/' + state.editingRole.id, data) : $_core_api.post('/api/role', data); promise.then(function(res) { if (res.success) { $_antd.message.success(state.editingRole ? '编辑成功' : '新增成功'); state.modalVisible = false; methods.loadRoleList(); } else { $_antd.message.error(res.error || '操作失败'); } }).catch(function(e) { $_antd.message.error('操作失败'); console.error(e); }).finally(function() { state.confirmLoading = false; })"
    },
    "handleModalCancel": {
      "$fn": "state.modalVisible = false"
    },
    "handleConfigPermissions": {
      "$fn": "window.location.hash = '#/system/role/' + args[0].id + '/permissions'"
    },
    "handleToggleStatus": {
      "$fn": "state.togglingRole = args[0]; state.statusToggleModalVisible = true"
    },
    "confirmToggleStatus": {
      "$fn": "if (!state.togglingRole) return; var role = state.togglingRole; var newStatus = role.status === 'active' ? 'inactive' : 'active'; state.confirmLoading = true; $_core_api.put('/api/role/' + role.id, { status: newStatus }).then(function(res) { if (res.success) { $_antd.message.success(newStatus === 'active' ? '已启用' : '已停用'); state.statusToggleModalVisible = false; methods.loadRoleList(); } else { $_antd.message.error(res.error || '操作失败'); } }).catch(function(e) { $_antd.message.error('操作失败'); console.error(e); }).finally(function() { state.confirmLoading = false; state.togglingRole = null; })"
    },
    "cancelToggleStatus": {
      "$fn": "state.statusToggleModalVisible = false; state.togglingRole = null"
    },
    "getStatusTag": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{ return args[0] === 'active' ? { color: 'success', text: '启用' } : { color: 'default', text: '停用' } }}"
    },
    "getPermissionCount": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{ var p = args[0]; if (!p) return 0; var count = 0; if (p.pages && p.pages.length > 0) count += p.pages.length; if (p.forms && p.forms.length > 0) count += p.forms.length; if (p.fields && p.fields.length > 0) count += p.fields.length; return count; }}"
    }
  },
  "lifecycle": {
    "onMounted": {
      "$fn": "methods.loadRoleList()"
    }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "props": {
        "style": {
          "type": "string",
          "body": "'padding: 24px'"
        }
      },
      "children": [
        {
          "type": "ACard",
          "props": {
            "title": {
              "type": "string",
              "body": "'角色列表'"
            },
            "bordered": false
          },
          "children": [
            {
              "type": "div",
              "props": {
                "style": {
                  "type": "string",
                  "body": "'margin-bottom: 16px'"
                }
              },
              "children": [
                {
                  "type": "AForm",
                  "props": {
                    "layout": "inline"
                  },
                  "children": [
                    {
                      "type": "AFormItem",
                      "props": {
                        "label": {
                          "type": "string",
                          "body": "'角色名称'"
                        }
                      },
                      "children": [
                        {
                          "type": "AInput",
                          "props": {
                            "placeholder": {
                              "type": "string",
                              "body": "'请输入角色名称'"
                            },
                            "value": {
                              "$expr": "$state.searchForm.keyword"
                            },
                            "onChange": {
                              "$fn": "state.searchForm.keyword = args[0].target.value"
                            },
                            "style": {
                              "type": "string",
                              "body": "'width: 200px'"
                            }
                          }
                        }
                      ]
                    },
                    {
                      "type": "AFormItem",
                      "props": {
                        "label": {
                          "type": "string",
                          "body": "'状态'"
                        }
                      },
                      "children": [
                        {
                          "type": "ASelect",
                          "props": {
                            "placeholder": {
                              "type": "string",
                              "body": "'请选择状态'"
                            },
                            "value": {
                              "$expr": "$state.searchForm.status"
                            },
                            "onChange": {
                              "$fn": "state.searchForm.status = args[0]"
                            },
                            "style": {
                              "type": "string",
                              "body": "'width: 120px'"
                            },
                            "allowClear": true
                          },
                          "children": [
                            {
                              "type": "ASelectOption",
                              "props": {
                                "value": {
                                  "type": "string",
                                  "body": "'active'"
                                }
                              },
                              "children": ["启用"]
                            },
                            {
                              "type": "ASelectOption",
                              "props": {
                                "value": {
                                  "type": "string",
                                  "body": "'inactive'"
                                }
                              },
                              "children": ["停用"]
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "AFormItem",
                      "children": [
                        {
                          "type": "ASpace",
                          "children": [
                            {
                              "type": "AButton",
                              "props": {
                                "type": {
                                  "type": "string",
                                  "body": "'primary'"
                                },
                                "onClick": {
                                  "type": "function",
                                  "params": "{{{}}}",
                                  "body": "{{methods.handleSearch()}}"
                                }
                              },
                              "children": ["查询"]
                            },
                            {
                              "type": "AButton",
                              "props": {
                                "onClick": {
                                  "type": "function",
                                  "params": "{{{}}}",
                                  "body": "{{methods.handleReset()}}"
                                }
                              },
                              "children": ["重置"]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "div",
              "props": {
                "style": {
                  "type": "string",
                  "body": "'margin-bottom: 16px'"
                }
              },
              "children": [
                {
                  "type": "AButton",
                  "props": {
                    "type": {
                      "type": "string",
                      "body": "'primary'"
                    },
                    "icon": {
                      "type": "string",
                      "body": "'plus'"
                    },
                    "onClick": {
                      "type": "function",
                      "params": "{{{}}}",
                      "body": "{{methods.handleAdd()}}"
                    }
                  },
                  "children": ["新增角色"]
                }
              ]
            },
            {
              "type": "ATable",
              "props": {
                "dataSource": {
                  "$expr": "$state.roleList"
                },
                "rowKey": {
                  "type": "string",
                  "body": "'id'"
                },
                "loading": {
                  "$expr": "$state.loading"
                },
                "pagination": {
                  "$expr": "$state.pagination"
                },
                "onChange": {
                  "type": "function",
                  "params": "{{{}}}",
                  "body": "{{methods.handleTableChange(args[0])}}"
                }
              },
              "children": [
                {
                  "type": "ATableColumn",
                  "props": {
                    "title": {
                      "type": "string",
                      "body": "'角色编码'"
                    },
                    "dataIndex": {
                      "type": "string",
                      "body": "'code'"
                    },
                    "width": 150
                  }
                },
                {
                  "type": "ATableColumn",
                  "props": {
                    "title": {
                      "type": "string",
                      "body": "'角色名称'"
                    },
                    "dataIndex": {
                      "type": "string",
                      "body": "'name'"
                    },
                    "width": 150
                  }
                },
                {
                  "type": "ATableColumn",
                  "props": {
                    "title": {
                      "type": "string",
                      "body": "'描述'"
                    },
                    "dataIndex": {
                      "type": "string",
                      "body": "'description'"
                    },
                    "ellipsis": true
                  }
                },
                {
                  "type": "ATableColumn",
                  "props": {
                    "title": {
                      "type": "string",
                      "body": "'状态'"
                    },
                    "dataIndex": {
                      "type": "string",
                      "body": "'status'"
                    },
                    "width": 100
                  },
                  "children": [
                    {
                      "type": "ATag",
                      "props": {
                        "color": {
                          "type": "function",
                          "params": "{{{}}}",
                          "body": "{{methods.getStatusTag(args[0]).color}}"
                        }
                      },
                      "children": [
                        {
                          "type": "function",
                          "params": "{{{}}}",
                          "body": "{{return methods.getStatusTag(args[0]).text}}"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "ATableColumn",
                  "props": {
                    "title": {
                      "type": "string",
                      "body": "'权限数量'"
                    },
                    "width": 100
                  },
                  "children": [
                    {
                      "type": "function",
                      "params": "{{{}}}",
                      "body": "{{return methods.getPermissionCount(args[0].permissions)}}"
                    }
                  ]
                },
                {
                  "type": "ATableColumn",
                  "props": {
                    "title": {
                      "type": "string",
                      "body": "'创建时间'"
                    },
                    "dataIndex": {
                      "type": "string",
                      "body": "'createdAt'"
                    },
                    "width": 180
                  }
                },
                {
                  "type": "ATableColumn",
                  "props": {
                    "title": {
                      "type": "string",
                      "body": "'操作'"
                    },
                    "width": 280,
                    "fixed": {
                      "type": "string",
                      "body": "'right'"
                    }
                  },
                  "children": [
                    {
                      "type": "ASpace",
                      "children": [
                        {
                          "type": "AButton",
                          "props": {
                            "type": {
                              "type": "string",
                              "body": "'link'"
                            },
                            "size": {
                              "type": "string",
                              "body": "'small'"
                            },
                            "onClick": {
                              "type": "function",
                              "params": "{{{}}}",
                              "body": "{{methods.handleEdit(args[0])}}"
                            }
                          },
                          "children": ["编辑"]
                        },
                        {
                          "type": "AButton",
                          "props": {
                            "type": {
                              "type": "string",
                              "body": "'link'"
                            },
                            "size": {
                              "type": "string",
                              "body": "'small'"
                            },
                            "onClick": {
                              "type": "function",
                              "params": "{{{}}}",
                              "body": "{{methods.handleConfigPermissions(args[0])}}"
                            }
                          },
                          "children": ["配置权限"]
                        },
                        {
                          "type": "AButton",
                          "props": {
                            "type": {
                              "type": "string",
                              "body": "'link'"
                            },
                            "size": {
                              "type": "string",
                              "body": "'small'"
                            },
                            "onClick": {
                              "type": "function",
                              "params": "{{{}}}",
                              "body": "{{methods.handleToggleStatus(args[0])}}"
                            }
                          },
                          "children": [
                            {
                              "type": "function",
                              "params": "{{{}}}",
                              "body": "{{return args[0].status === 'active' ? '停用' : '启用'}}"
                            }
                          ]
                        },
                        {
                          "type": "AButton",
                          "props": {
                            "type": {
                              "type": "string",
                              "body": "'link'"
                            },
                            "danger": true,
                            "size": {
                              "type": "string",
                              "body": "'small'"
                            },
                            "onClick": {
                              "type": "function",
                              "params": "{{{}}}",
                              "body": "{{methods.handleDelete(args[0])}}"
                            }
                          },
                          "children": ["删除"]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "AModal",
          "props": {
            "title": {
              "$expr": "$state.modalTitle"
            },
            "open": {
              "$expr": "$state.modalVisible"
            },
            "onOk": {
              "type": "function",
              "params": "{{{}}}",
              "body": "{{methods.handleModalOk()}}"
            },
            "onCancel": {
              "type": "function",
              "params": "{{{}}}",
              "body": "{{methods.handleModalCancel()}}"
            },
            "confirmLoading": {
              "$expr": "$state.confirmLoading"
            },
            "width": 500
          },
          "children": [
            {
              "type": "AForm",
              "props": {
                "layout": "vertical"
              },
              "children": [
                {
                  "type": "AFormItem",
                  "props": {
                    "label": {
                      "type": "string",
                      "body": "'角色编码'"
                    },
                    "required": true
                  },
                  "children": [
                    {
                      "type": "AInput",
                      "props": {
                        "placeholder": {
                          "type": "string",
                          "body": "'请输入角色编码'"
                        },
                        "value": {
                          "$expr": "$state.formData.code"
                        },
                        "onChange": {
                          "$fn": "state.formData.code = args[0].target.value"
                        },
                        "disabled": {
                          "$expr": "$state.editingRole"
                        }
                      }
                    }
                  ]
                },
                {
                  "type": "AFormItem",
                  "props": {
                    "label": {
                      "type": "string",
                      "body": "'角色名称'"
                    },
                    "required": true
                  },
                  "children": [
                    {
                      "type": "AInput",
                      "props": {
                        "placeholder": {
                          "type": "string",
                          "body": "'请输入角色名称'"
                        },
                        "value": {
                          "$expr": "$state.formData.name"
                        },
                        "onChange": {
                          "$fn": "state.formData.name = args[0].target.value"
                        }
                      }
                    }
                  ]
                },
                {
                  "type": "AFormItem",
                  "props": {
                    "label": {
                      "type": "string",
                      "body": "'描述'"
                    }
                  },
                  "children": [
                    {
                      "type": "ATextarea",
                      "props": {
                        "placeholder": {
                          "type": "string",
                          "body": "'请输入角色描述'"
                        },
                        "value": {
                          "$expr": "$state.formData.description"
                        },
                        "onChange": {
                          "$fn": "state.formData.description = args[0].target.value"
                        },
                        "rows": 3
                      }
                    }
                  ]
                },
                {
                  "type": "AFormItem",
                  "props": {
                    "label": {
                      "type": "string",
                      "body": "'状态'"
                    }
                  },
                  "children": [
                    {
                      "type": "ARadioGroup",
                      "props": {
                        "value": {
                          "$expr": "$state.formData.status"
                        },
                        "onChange": {
                          "$fn": "state.formData.status = args[0].target.value"
                        }
                      },
                      "children": [
                        {
                          "type": "ARadio",
                          "props": {
                            "value": {
                              "type": "string",
                              "body": "'active'"
                            }
                          },
                          "children": ["启用"]
                        },
                        {
                          "type": "ARadio",
                          "props": {
                            "value": {
                              "type": "string",
                              "body": "'inactive'"
                            }
                          },
                          "children": ["停用"]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "AModal",
          "props": {
            "title": {
              "type": "string",
              "body": "'确认删除'"
            },
            "open": {
              "$expr": "$state.deleteModalVisible"
            },
            "onOk": {
              "type": "function",
              "params": "{{{}}}",
              "body": "{{methods.confirmDelete()}}"
            },
            "onCancel": {
              "type": "function",
              "params": "{{{}}}",
              "body": "{{methods.cancelDelete()}}"
            },
            "confirmLoading": {
              "$expr": "$state.confirmLoading"
            }
          },
          "children": [
            {
              "type": "p",
              "children": [
                {
                  "type": "expression",
                  "body": "'确定要删除角色 '"
                },
                {
                  "type": "expression",
                  "body": "$state.deletingRole?.name || ''"
                },
                {
                  "type": "expression",
                  "body": "{{' 吗？此操作不可恢复。'}}"
                }
              ]
            }
          ]
        },
        {
          "type": "AModal",
          "props": {
            "title": {
              "type": "string",
              "body": "'确认切换状态'"
            },
            "open": {
              "$expr": "$state.statusToggleModalVisible"
            },
            "onOk": {
              "type": "function",
              "params": "{{{}}}",
              "body": "{{methods.confirmToggleStatus()}}"
            },
            "onCancel": {
              "type": "function",
              "params": "{{{}}}",
              "body": "{{methods.cancelToggleStatus()}}"
            },
            "confirmLoading": {
              "$expr": "$state.confirmLoading"
            }
          },
          "children": [
            {
              "type": "p",
              "children": [
                {
                  "type": "expression",
                  "body": "$state.togglingRole?.status === 'active' ? '确定要停用角色 ' : '确定要启用角色 '"
                },
                {
                  "type": "expression",
                  "body": "$state.togglingRole?.name || ''"
                },
                {
                  "type": "expression",
                  "body": "{{' 吗？'}}"
                }
              ]
            }
          ]
        }
      ]
    }
  },
  "styles": {
    "scoped": false,
    "css": ""
  }
}