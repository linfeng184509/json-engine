{
  "name": "RoleManagementPage",
  "state": {
    "roleList": { "type": "ref", "initial": [] },
    "loading": { "type": "ref", "initial": true },
    "pagination": { "type": "reactive", "initial": { "current": 1, "pageSize": 10, "total": 0 } },
    "searchForm": { "type": "reactive", "initial": { "keyword": "", "status": "" } },
    "selectedRow": { "type": "ref", "initial": null },
    "modalVisible": { "type": "ref", "initial": false },
    "modalTitle": { "type": "ref", "initial": "新增角色" },
    "editingRole": { "type": "ref", "initial": null },
    "formData": { "type": "reactive", "initial": { "code": "", "name": "", "description": "", "status": "active" } },
    "confirmLoading": { "type": "ref", "initial": false },
    "deleteModalVisible": { "type": "ref", "initial": false },
    "deletingRole": { "type": "ref", "initial": null }
  },
  "computed": {
    "hasSelected": {
      "get": {
        "type": "function",
        "params": "{{{}}}",
        "body": "{{return !!ref_state_selectedRow}}"
      }
    },
    "isEditing": {
      "get": {
        "type": "function",
        "params": "{{{}}}",
        "body": "{{return !!ref_state_editingRole}}"
      }
    },
    "formIsValid": {
      "get": {
        "type": "function",
        "params": "{{{}}}",
        "body": "{{return !!ref_state_formData.code && !!ref_state_formData.name}}"
      }
    }
  },
  "methods": {
    "loadRoleList": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{ref_state_loading.value = true; var params = { page: ref_state_pagination.current, pageSize: ref_state_pagination.pageSize, keyword: ref_state_searchForm.keyword, status: ref_state_searchForm.status }; $_[core]_api.get('/api/role/list', { params: params }).then(function(res) { ref_state_roleList.value = res.data.list; ref_state_pagination.total = res.data.total; ref_state_loading.value = false; }).catch(function(e) { console.error(e); ref_state_loading.value = false; }) }}"
    },
    "handleSearch": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{ref_state_pagination.current = 1; methods.loadRoleList() }}"
    },
    "handleReset": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{ref_state_searchForm.keyword = ''; ref_state_searchForm.status = ''; ref_state_pagination.current = 1; methods.loadRoleList() }}"
    },
    "handleTableChange": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{ref_state_pagination.current = args[0].current; ref_state_pagination.pageSize = args[0].pageSize; methods.loadRoleList() }}"
    },
    "handleAdd": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{ref_state_editingRole.value = null; ref_state_modalTitle.value = '新增角色'; ref_state_formData.code = ''; ref_state_formData.name = ''; ref_state_formData.description = ''; ref_state_formData.status = 'active'; ref_state_modalVisible.value = true }}"
    },
    "handleEdit": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{ref_state_editingRole.value = args[0]; ref_state_modalTitle.value = '编辑角色'; ref_state_formData.code = args[0].code; ref_state_formData.name = args[0].name; ref_state_formData.description = args[0].description || ''; ref_state_formData.status = args[0].status; ref_state_modalVisible.value = true }}"
    },
    "handleDelete": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{ref_state_deletingRole.value = args[0]; ref_state_deleteModalVisible.value = true }}"
    },
    "confirmDelete": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{ if (!ref_state_deletingRole.value) return; ref_state_confirmLoading.value = true; $_[core]_api.delete('/api/role/' + ref_state_deletingRole.value.id).then(function(res) { if (res.success) { ref_state_deleteModalVisible.value = false; methods.loadRoleList(); } else { alert(res.error || '删除失败'); } }).finally(function() { ref_state_confirmLoading.value = false; ref_state_deletingRole.value = null; }) }}"
    },
    "cancelDelete": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{ref_state_deleteModalVisible.value = false; ref_state_deletingRole.value = null }}"
    },
    "handleModalOk": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{ if (!ref_computed_formIsValid.value) return; ref_state_confirmLoading.value = true; var data = { code: ref_state_formData.code, name: ref_state_formData.name, description: ref_state_formData.description, status: ref_state_formData.status }; var promise = ref_state_editingRole.value ? $_[core]_api.put('/api/role/' + ref_state_editingRole.value.id, data) : $_[core]_api.post('/api/role', data); promise.then(function(res) { if (res.success) { ref_state_modalVisible.value = false; methods.loadRoleList(); } else { alert(res.error || '操作失败'); } }).finally(function() { ref_state_confirmLoading.value = false; }) }}"
    },
    "handleModalCancel": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{ref_state_modalVisible.value = false }}"
    },
    "handleConfigPermissions": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{ window.location.hash = '#/system/role/' + args[0].id + '/permissions' }}"
    },
    "handleToggleStatus": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{ var role = args[0]; var newStatus = role.status === 'active' ? 'inactive' : 'active'; $_[core]_api.put('/api/role/' + role.id, { status: newStatus }).then(function(res) { if (res.success) { methods.loadRoleList(); } else { alert(res.error || '操作失败'); } }) }}"
    },
    "getStatusTag": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{ return args[0] === 'active' ? { color: 'success', text: '启用' } : { color: 'default', text: '停用' } }}"
    },
    "getPermissionCount": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{ var p = args[0]; if (!p) return 0; var count = 0; if (p.pages && p.pages.length > 0) count += p.pages.length; if (p.forms && p.forms.length > 0) count += p.forms.length; if (p.fields && p.fields.length > 0) count += p.fields.length; return count; }}"
    }
  },
  "lifecycle": {
    "onMounted": {
      "type": "function",
      "params": "{{{}}}",
      "body": "{{ methods.loadRoleList() }}"
    }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "props": {
        "style": {
          "type": "string",
          "body": "'padding: 24px'"
        }
      },
      "children": [
        {
          "type": "ACard",
          "props": {
            "title": {
              "type": "string",
              "body": "'角色列表'"
            },
            "bordered": false
          },
          "children": [
            {
              "type": "div",
              "props": {
                "style": {
                  "type": "string",
                  "body": "'margin-bottom: 16px'"
                }
              },
              "children": [
                {
                  "type": "AForm",
                  "props": {
                    "layout": "inline"
                  },
                  "children": [
                    {
                      "type": "AFormItem",
                      "props": {
                        "label": {
                          "type": "string",
                          "body": "'角色名称'"
                        }
                      },
                      "children": [
                        {
                          "type": "AInput",
                          "props": {
                            "placeholder": {
                              "type": "string",
                              "body": "'请输入角色名称'"
                            },
"value": {
                             "type": "expression",
                             "body": "{{ref_state_searchForm.keyword}}"
                           },
                           "onChange": {
                             "type": "function",
                             "params": "{{{}}}",
                             "body": "{{ref_state_searchForm.keyword = args[0].target.value}}"
                           },
                            "style": {
                              "type": "string",
                              "body": "'width: 200px'"
                            }
                          }
                        }
                      ]
                    },
                    {
                      "type": "AFormItem",
                      "props": {
                        "label": {
                          "type": "string",
                          "body": "'状态'"
                        }
                      },
                      "children": [
                        {
                          "type": "ASelect",
                          "props": {
                            "placeholder": {
                              "type": "string",
                              "body": "'请选择状态'"
                            },
"value": {
                             "type": "expression",
                             "body": "{{ref_state_searchForm.status}}"
                           },
                           "onChange": {
                             "type": "function",
                             "params": "{{{}}}",
                             "body": "{{ref_state_searchForm.status = args[0]}}"
                           },
                            "style": {
                              "type": "string",
                              "body": "'width: 120px'"
                            },
                            "allowClear": true
                          },
                          "children": [
                            {
                              "type": "ASelectOption",
                              "props": {
                                "value": {
                                  "type": "string",
                                  "body": "'active'"
                                }
                              },
                              "children": ["启用"]
                            },
                            {
                              "type": "ASelectOption",
                              "props": {
                                "value": {
                                  "type": "string",
                                  "body": "'inactive'"
                                }
                              },
                              "children": ["停用"]
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "AFormItem",
                      "children": [
                        {
                          "type": "ASpace",
                          "children": [
                            {
                              "type": "AButton",
                              "props": {
                                "type": {
                                  "type": "string",
                                  "body": "'primary'"
                                },
                                "onClick": {
                                  "type": "function",
                                  "params": "{{{}}}",
                                  "body": "{{methods.handleSearch()}}"
                                }
                              },
                              "children": ["查询"]
                            },
                            {
                              "type": "AButton",
                              "props": {
                                "onClick": {
                                  "type": "function",
                                  "params": "{{{}}}",
                                  "body": "{{methods.handleReset()}}"
                                }
                              },
                              "children": ["重置"]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "div",
              "props": {
                "style": {
                  "type": "string",
                  "body": "'margin-bottom: 16px'"
                }
              },
              "children": [
                {
                  "type": "AButton",
                  "props": {
                    "type": {
                      "type": "string",
                      "body": "'primary'"
                    },
                    "icon": {
                      "type": "string",
                      "body": "'plus'"
                    },
                    "onClick": {
                      "type": "function",
                      "params": "{{{}}}",
                      "body": "{{methods.handleAdd()}}"
                    }
                  },
                  "children": ["新增角色"]
                }
              ]
            },
            {
              "type": "ATable",
              "props": {
                "dataSource": {
                  "type": "expression",
                  "body": "{{ref_state_roleList}}"
                },
                "rowKey": {
                  "type": "string",
                  "body": "'id'"
                },
                "loading": {
                  "type": "expression",
                  "body": "{{ref_state_loading}}"
                },
                "pagination": {
                  "type": "expression",
                  "body": "{{ref_state_pagination}}"
                },
                "onChange": {
                  "type": "function",
                  "params": "{{{}}}",
                  "body": "{{methods.handleTableChange(args[0])}}"
                }
              },
              "children": [
                {
                  "type": "ATableColumn",
                  "props": {
                    "title": {
                      "type": "string",
                      "body": "'角色编码'"
                    },
                    "dataIndex": {
                      "type": "string",
                      "body": "'code'"
                    },
                    "width": 150
                  }
                },
                {
                  "type": "ATableColumn",
                  "props": {
                    "title": {
                      "type": "string",
                      "body": "'角色名称'"
                    },
                    "dataIndex": {
                      "type": "string",
                      "body": "'name'"
                    },
                    "width": 150
                  }
                },
                {
                  "type": "ATableColumn",
                  "props": {
                    "title": {
                      "type": "string",
                      "body": "'描述'"
                    },
                    "dataIndex": {
                      "type": "string",
                      "body": "'description'"
                    },
                    "ellipsis": true
                  }
                },
                {
                  "type": "ATableColumn",
                  "props": {
                    "title": {
                      "type": "string",
                      "body": "'状态'"
                    },
                    "dataIndex": {
                      "type": "string",
                      "body": "'status'"
                    },
                    "width": 100
                  },
                  "children": [
                    {
                      "type": "ATag",
                      "props": {
                        "color": {
                          "type": "function",
                          "params": "{{{}}}",
                          "body": "{{methods.getStatusTag(args[0]).color}}"
                        }
                      },
                      "children": [
                        {
                          "type": "function",
                          "params": "{{{}}}",
                          "body": "{{return methods.getStatusTag(args[0]).text}}"
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "ATableColumn",
                  "props": {
                    "title": {
                      "type": "string",
                      "body": "'权限数量'"
                    },
                    "width": 100
                  },
                  "children": [
                    {
                      "type": "function",
                      "params": "{{{}}}",
                      "body": "{{return methods.getPermissionCount(args[0].permissions)}}"
                    }
                  ]
                },
                {
                  "type": "ATableColumn",
                  "props": {
                    "title": {
                      "type": "string",
                      "body": "'创建时间'"
                    },
                    "dataIndex": {
                      "type": "string",
                      "body": "'createdAt'"
                    },
                    "width": 180
                  }
                },
                {
                  "type": "ATableColumn",
                  "props": {
                    "title": {
                      "type": "string",
                      "body": "'操作'"
                    },
                    "width": 280,
                    "fixed": {
                      "type": "string",
                      "body": "'right'"
                    }
                  },
                  "children": [
                    {
                      "type": "ASpace",
                      "children": [
                        {
                          "type": "AButton",
                          "props": {
                            "type": {
                              "type": "string",
                              "body": "'link'"
                            },
                            "size": {
                              "type": "string",
                              "body": "'small'"
                            },
                            "onClick": {
                              "type": "function",
                              "params": "{{{}}}",
                              "body": "{{methods.handleEdit(args[0])}}"
                            }
                          },
                          "children": ["编辑"]
                        },
                        {
                          "type": "AButton",
                          "props": {
                            "type": {
                              "type": "string",
                              "body": "'link'"
                            },
                            "size": {
                              "type": "string",
                              "body": "'small'"
                            },
                            "onClick": {
                              "type": "function",
                              "params": "{{{}}}",
                              "body": "{{methods.handleConfigPermissions(args[0])}}"
                            }
                          },
                          "children": ["配置权限"]
                        },
                        {
                          "type": "AButton",
                          "props": {
                            "type": {
                              "type": "string",
                              "body": "'link'"
                            },
                            "size": {
                              "type": "string",
                              "body": "'small'"
                            },
                            "onClick": {
                              "type": "function",
                              "params": "{{{}}}",
                              "body": "{{methods.handleToggleStatus(args[0])}}"
                            }
                          },
                          "children": [
                            {
                              "type": "function",
                              "params": "{{{}}}",
                              "body": "{{return args[0].status === 'active' ? '停用' : '启用'}}"
                            }
                          ]
                        },
                        {
                          "type": "AButton",
                          "props": {
                            "type": {
                              "type": "string",
                              "body": "'link'"
                            },
                            "danger": true,
                            "size": {
                              "type": "string",
                              "body": "'small'"
                            },
                            "onClick": {
                              "type": "function",
                              "params": "{{{}}}",
                              "body": "{{methods.handleDelete(args[0])}}"
                            }
                          },
                          "children": ["删除"]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "AModal",
          "props": {
"title": {
               "type": "expression",
               "body": "{{ref_state_modalTitle}}"
             },
            "visible": {
              "type": "expression",
              "body": "{{ref_state_modalVisible}}"
            },
            "onOk": {
              "type": "function",
              "params": "{{{}}}",
              "body": "{{methods.handleModalOk()}}"
            },
            "onCancel": {
              "type": "function",
              "params": "{{{}}}",
              "body": "{{methods.handleModalCancel()}}"
            },
            "confirmLoading": {
              "type": "expression",
              "body": "{{ref_state_confirmLoading}}"
            },
            "width": 500
          },
          "children": [
            {
              "type": "AForm",
              "props": {
                "layout": "vertical"
              },
              "children": [
                {
                  "type": "AFormItem",
                  "props": {
                    "label": {
                      "type": "string",
                      "body": "'角色编码'"
                    },
                    "required": true
                  },
                  "children": [
                    {
                      "type": "AInput",
                      "props": {
                        "placeholder": {
                          "type": "string",
                          "body": "'请输入角色编码'"
                        },
"value": {
                         "type": "expression",
                         "body": "{{ref_state_formData.code}}"
                       },
                       "onChange": {
                         "type": "function",
                         "params": "{{{}}}",
                         "body": "{{ref_state_formData.code = args[0].target.value}}"
                       },
                       "disabled": {
                         "type": "expression",
                         "body": "{{ref_state_editingRole}}"
                       }
                      }
                    }
                  ]
                },
                {
                  "type": "AFormItem",
                  "props": {
                    "label": {
                      "type": "string",
                      "body": "'角色名称'"
                    },
                    "required": true
                  },
                  "children": [
                    {
                      "type": "AInput",
                      "props": {
                        "placeholder": {
                          "type": "string",
                          "body": "'请输入角色名称'"
                        },
"value": {
                         "type": "expression",
                         "body": "{{ref_state_formData.name}}"
                       },
                       "onChange": {
                         "type": "function",
                         "params": "{{{}}}",
                         "body": "{{ref_state_formData.name = args[0].target.value}}"
                       }
                      }
                    }
                  ]
                },
                {
                  "type": "AFormItem",
                  "props": {
                    "label": {
                      "type": "string",
                      "body": "'描述'"
                    }
                  },
                  "children": [
                    {
                      "type": "ATextarea",
                      "props": {
                        "placeholder": {
                          "type": "string",
                          "body": "'请输入角色描述'"
                        },
"value": {
                         "type": "expression",
                         "body": "{{ref_state_formData.description}}"
                       },
                       "onChange": {
                         "type": "function",
                         "params": "{{{}}}",
                         "body": "{{ref_state_formData.description = args[0].target.value}}"
                       },
                        "rows": 3
                      }
                    }
                  ]
                },
                {
                  "type": "AFormItem",
                  "props": {
                    "label": {
                      "type": "string",
                      "body": "'状态'"
                    }
                  },
                  "children": [
                    {
                      "type": "ARadioGroup",
                      "props": {
"value": {
                         "type": "expression",
                         "body": "{{ref_state_formData.status}}"
                       },
                       "onChange": {
                         "type": "function",
                         "params": "{{{}}}",
                         "body": "{{ref_state_formData.status = args[0].target.value}}"
                       }
                      },
                      "children": [
                        {
                          "type": "ARadio",
                          "props": {
                            "value": {
                              "type": "string",
                              "body": "'active'"
                            }
                          },
                          "children": ["启用"]
                        },
                        {
                          "type": "ARadio",
                          "props": {
                            "value": {
                              "type": "string",
                              "body": "'inactive'"
                            }
                          },
                          "children": ["停用"]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "AModal",
          "props": {
            "title": {
              "type": "string",
              "body": "'确认删除'"
            },
            "visible": {
              "type": "expression",
              "body": "{{ref_state_deleteModalVisible}}"
            },
            "onOk": {
              "type": "function",
              "params": "{{{}}}",
              "body": "{{methods.confirmDelete()}}"
            },
            "onCancel": {
              "type": "function",
              "params": "{{{}}}",
              "body": "{{methods.cancelDelete()}}"
            },
            "confirmLoading": {
              "type": "expression",
              "body": "{{ref_state_confirmLoading}}"
            }
          },
          "children": [
            {
              "type": "p",
              "children": [
                {
                  "type": "expression",
                  "body": "{{'确定要删除角色 '}}"
                },
                {
                  "type": "expression",
                  "body": "{{ref_state_deletingRole?.value?.name || ''}}"
                },
                {
                  "type": "expression",
                  "body": "{{' 吗？'}}"
                }
              ]
            }
          ]
        }
      ]
    }
  },
  "styles": {
    "scoped": false,
    "css": ""
  }
}