{
  "name": "EnterpriseAdmin",
  "version": "0.0.1",
  "router": {
    "history": "hash",
    "routes": [
      {
        "path": "/login",
        "name": "Login",
        "component": "/schemas/pages/login.json",
        "meta": {
          "title": "登录"
        }
      },
      {
        "path": "/dashboard",
        "name": "Dashboard",
        "component": "/schemas/pages/dashboard.json",
        "meta": {
          "title": "首页",
          "requiresAuth": true,
          "permissions": ["dashboard:view"]
        }
      },
      {
        "path": "/",
        "redirect": "/dashboard"
      },
      {
        "path": "/:pathMatch(.*)*",
        "name": "NotFound",
        "component": "/schemas/pages/404.json"
      }
    ],
    "guards": {
      "beforeEach": {
        "type": "function",
        "params": "{{{\"to\": \"RouteLocationNormalized\", \"from\": \"RouteLocationNormalized\", \"next\": \"NavigationGuardCallback\"}}}",
        "body": "{{const token = localStorage.getItem('enterprise_admin_token'); if (ref_props_to.meta.requiresAuth && !token) { next('/login'); } else { next(); }}}"
      }
    }
  },
  "ui": {
    "components": [
      { "name": "AForm", "component": "ant-design-vue/es/form" },
      { "name": "AFormItem", "component": "ant-design-vue/es/form/FormItem" },
      { "name": "AInput", "component": "ant-design-vue/es/input" },
      { "name": "AInputPassword", "component": "ant-design-vue/es/input/InputPassword" },
      { "name": "AButton", "component": "ant-design-vue/es/button" },
      { "name": "ACheckbox", "component": "ant-design-vue/es/checkbox" },
      { "name": "ASpin", "component": "ant-design-vue/es/spin" },
      { "name": "ACard", "component": "ant-design-vue/es/card" },
      { "name": "AAlert", "component": "ant-design-vue/es/alert" },
      { "name": "ALayout", "component": "ant-design-vue/es/layout" },
      { "name": "ALayoutHeader", "component": "ant-design-vue/es/layout/Header" },
      { "name": "ALayoutContent", "component": "ant-design-vue/es/layout/LayoutContent" },
      { "name": "AResult", "component": "ant-design-vue/es/result" }
    ],
    "theme": {
      "primaryColor": "#1677ff",
      "borderRadius": 6
    }
  },
  "network": {
    "axios": {
      "baseURL": "/api",
      "timeout": 10000,
      "headers": {
        "Content-Type": "application/json"
      },
      "retry": {
        "retries": 3,
        "retryDelay": 1000
      }
    }
  },
  "websocket": {
    "url": "ws://localhost:8080",
    "autoReconnect": true,
    "reconnectInterval": 5000,
    "heartbeatInterval": 30000
  },
  "storage": {
    "prefix": "enterprise_admin_",
    "encrypt": false,
    "sync": true
  },
  "auth": {
    "pagePermissions": {
      "/dashboard": "dashboard:view",
      "/system/user": "user:view",
      "/system/role": "role:view"
    }
  }
}