{
  "name": "EnterpriseAdminApp",
  "version": "1.0.0",
  "plugins": [
    { "name": "@json-engine/plugin-axios" },
    { "name": "@json-engine/plugin-antd" },
    { "name": "@json-engine/plugin-router" },
    { "name": "@json-engine/plugin-websocket" },
    { "name": "@json-engine/plugin-storage" },
    { "name": "@json-engine/plugin-auth" },
    { "name": "@json-engine/plugin-i18n" },
    { "name": "@json-engine/plugin-echarts" }
  ],
  "config": {
    "axios": {
      "baseURL": "/api",
      "timeout": 10000,
      "headers": {
        "Content-Type": "application/json"
      }
    },
    "antd": {
      "theme": {
        "primaryColor": "#1677ff",
        "borderRadius": 6
      },
      "locale": "zh_CN"
    },
    "router": {
      "mode": "hash",
      "base": "/"
    },
    "websocket": {
      "url": "ws://localhost:8080",
      "autoReconnect": true,
      "reconnectInterval": 5000,
      "heartbeatInterval": 30000
    },
    "storage": {
      "prefix": "ea_",
      "sync": true
    },
    "auth": {
      "pagePermissions": {
        "/dashboard": "dashboard:view",
        "/system/user": "user:view",
        "/system/role": "role:view",
        "/system/role/:id/permissions": "role:edit"
      }
    },
    "i18n": {
      "locale": "zh_CN",
      "fallbackLocale": "en"
    },
    "echarts": {
      "theme": "default",
      "autoResize": true
    }
  },
  "router": {
    "history": "hash",
    "routes": [
      {
        "path": "/login",
        "name": "Login",
        "component": "./schemas/pages/login.json",
        "meta": {
          "title": "登录"
        }
      },
      {
        "path": "/dashboard",
        "name": "Dashboard",
        "component": "./schemas/pages/dashboard.json",
        "meta": {
          "title": "首页",
          "requiresAuth": true,
          "permissions": ["dashboard:view"],
          "layout": "./schemas/pages/app-layout.json"
        }
      },
      {
        "path": "/basic-data-config",
        "name": "BasicDataConfig",
        "component": "./schemas/pages/basic-data-config.json",
        "meta": {
          "title": "基础数据配置",
          "requiresAuth": true,
          "permissions": ["system:manage"],
          "layout": "./schemas/pages/app-layout.json"
        }
      },
      {
        "path": "/system/role",
        "name": "RoleManagement",
        "component": "./schemas/pages/role-management.json",
        "meta": {
          "title": "角色管理",
          "requiresAuth": true,
          "permissions": ["role:view"],
          "layout": "./schemas/pages/app-layout.json"
        }
      },
      {
        "path": "/system/role/:id/permissions",
        "name": "RolePermissionConfig",
        "component": "./schemas/pages/role-permission-config.json",
        "meta": {
          "title": "权限配置",
          "requiresAuth": true,
          "permissions": ["role:edit"],
          "layout": "./schemas/pages/app-layout.json"
        }
      },
      {
        "path": "/",
        "redirect": "/dashboard"
      },
      {
        "path": "/:pathMatch(.*)*",
        "name": "NotFound",
        "component": "./schemas/pages/404.json"
      }
    ]
  }
}