{
  "name": "LoginPage",
  "props": {
    "title": {
      "type": "String",
      "default": "企业管理系统"
    }
  },
  "state": {
    "formData": {
      "type": "reactive",
      "initial": {
        "username": "",
        "password": "",
        "captchaCode": "",
        "rememberMe": false
      }
    },
    "captcha": {
      "type": "ref",
      "initial": {
        "captchaId": "",
        "captchaImage": ""
      }
    },
    "loading": {
      "type": "ref",
      "initial": false
    },
    "errors": {
      "type": "reactive",
      "initial": {
        "username": "",
        "password": "",
        "general": ""
      }
    }
  },
  "computed": {
    "isValid": {
      "get": { "type": "function", "params": "{{{}}}", "body": "{{return ref_state_formData.username && ref_state_formData.password;}}" }
    },
    "submitDisabled": {
      "get": { "type": "function", "params": "{{{}}}", "body": "{{return ref_state_loading || !computed.isValid.value;}}" }
    }
  },
  "methods": {
    "fetchCaptcha": { "type": "function", "params": "{{{}}}", "body": "{{fetch('/api/auth/captcha').then(res => res.json()).then(data => { ref_state_captcha = data; }).catch(err => { console.error('Failed to fetch captcha:', err); });}}" },
    "validateForm": { "type": "function", "params": "{{{}}}", "body": "{{let valid = true; if (!ref_state_formData.username) { ref_state_errors.username = '请输入用户名'; valid = false; } else { ref_state_errors.username = ''; } if (!ref_state_formData.password) { ref_state_errors.password = '请输入密码'; valid = false; } else { ref_state_errors.password = ''; } return valid;}}" },
    "handleLogin": { "type": "function", "params": "{{{}}}", "body": "{{if (!methods.validateForm()) return; ref_state_loading = true; ref_state_errors.general = ''; fetch('/api/auth/login', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ username: ref_state_formData.username, password: ref_state_formData.password, captchaId: ref_state_captcha.captchaId, captchaCode: ref_state_formData.captchaCode }) }).then(res => res.json()).then(data => { if (data.success) { localStorage.setItem('enterprise_admin_token', data.token); window.location.hash = '#/dashboard'; } else { ref_state_errors.general = data.error || '登录失败'; methods.fetchCaptcha(); } }).catch(err => { ref_state_errors.general = '网络错误，请稍后重试'; }).finally(() => { ref_state_loading = false; });}}" }
  },
  "lifecycle": {
    "onMounted": { "type": "function", "params": "{{{}}}", "body": "{{methods.fetchCaptcha();}}" }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "props": {
        "class": { "type": "string", "body": "'login-container'" }
      },
      "children": [
        {
          "type": "div",
          "props": {
            "class": { "type": "string", "body": "'login-content'" }
          },
          "children": [
            {
              "type": "div",
              "props": {
                "class": { "type": "string", "body": "'login-header'" }
              },
              "children": [
                {
                  "type": "h1",
                  "props": {
                    "class": { "type": "string", "body": "'login-title'" }
                  },
                  "children": [
                    { "type": "expression", "body": "{{ref_props_title}}" }
                  ]
                }
              ]
            },
            {
              "type": "a-form",
              "props": {
                "class": { "type": "string", "body": "'login-form'" },
                "layout": { "type": "string", "body": "'vertical'" }
              },
              "directives": {
                "vOn": {
                  "submit.prevent": { "type": "function", "params": "{{{}}}", "body": "{{methods.handleLogin();}}" }
                }
              },
              "children": [
                {
                  "type": "a-alert",
                  "directives": {
                    "vIf": { "type": "expression", "body": "{{ref_state_errors.general}}" }
                  },
                  "props": {
                    "type": { "type": "string", "body": "'error'" },
                    "message": { "type": "expression", "body": "{{ref_state_errors.general}}" },
                    "showIcon": { "type": "string", "body": "'true'" },
                    "class": { "type": "string", "body": "'login-error'" }
                  }
                },
                {
                  "type": "a-form-item",
                  "props": {
                    "label": { "type": "string", "body": "'用户名'" },
                    "required": { "type": "string", "body": "'true'" },
                    "validateStatus": { "type": "expression", "body": "{{ref_state_errors.username ? 'error' : ''}}" },
                    "help": { "type": "expression", "body": "{{ref_state_errors.username}}" }
                  },
                  "children": [
                    {
                      "type": "a-input",
                      "props": {
                        "placeholder": { "type": "string", "body": "'请输入用户名'" },
                        "size": { "type": "string", "body": "'large'" },
                        "allowClear": { "type": "string", "body": "'true'" }
                      },
                      "directives": {
                        "vModel": {
                          "prop": { "type": "state", "body": "{{ref_state_formData.username}}" }
                        },
                        "vOn": {
                          "blur": { "type": "function", "params": "{{{}}}", "body": "{{if (!ref_state_formData.username) ref_state_errors.username = '请输入用户名'; else ref_state_errors.username = '';}}" }
                        }
                      }
                    }
                  ]
                },
                {
                  "type": "a-form-item",
                  "props": {
                    "label": { "type": "string", "body": "'密码'" },
                    "required": { "type": "string", "body": "'true'" },
                    "validateStatus": { "type": "expression", "body": "{{ref_state_errors.password ? 'error' : ''}}" },
                    "help": { "type": "expression", "body": "{{ref_state_errors.password}}" }
                  },
                  "children": [
                    {
                      "type": "a-input-password",
                      "props": {
                        "placeholder": { "type": "string", "body": "'请输入密码'" },
                        "size": { "type": "string", "body": "'large'" },
                        "allowClear": { "type": "string", "body": "'true'" }
                      },
                      "directives": {
                        "vModel": {
                          "prop": { "type": "state", "body": "{{ref_state_formData.password}}" }
                        },
                        "vOn": {
                          "blur": { "type": "function", "params": "{{{}}}", "body": "{{if (!ref_state_formData.password) ref_state_errors.password = '请输入密码'; else ref_state_errors.password = '';}}" }
                        }
                      }
                    }
                  ]
                },
                {
                  "type": "a-form-item",
                  "props": {
                    "label": { "type": "string", "body": "'验证码'" }
                  },
                  "children": [
                    {
                      "type": "div",
                      "props": {
                        "class": { "type": "string", "body": "'captcha-row'" }
                      },
                      "children": [
                        {
                          "type": "a-input",
                          "props": {
                            "placeholder": { "type": "string", "body": "'请输入验证码'" },
                            "size": { "type": "string", "body": "'large'" },
                            "class": { "type": "string", "body": "'captcha-input'" }
                          },
                          "directives": {
                            "vModel": {
                              "prop": { "type": "state", "body": "{{ref_state_formData.captchaCode}}" }
                            }
                          }
                        },
                        {
                          "type": "img",
                          "props": {
                            "src": { "type": "expression", "body": "{{ref_state_captcha.captchaImage}}" },
                            "alt": { "type": "string", "body": "'验证码'" },
                            "class": { "type": "string", "body": "'captcha-image'" }
                          },
                          "directives": {
                            "vOn": {
                              "click": { "type": "function", "params": "{{{}}}", "body": "{{methods.fetchCaptcha();}}" }
                            }
                          }
                        }
                      ]
                    }
                  ]
                },
                {
                  "type": "a-form-item",
                  "children": [
                    {
                      "type": "a-checkbox",
                      "directives": {
                        "vModel": {
                          "prop": { "type": "state", "body": "{{ref_state_formData.rememberMe}}" }
                        }
                      },
                      "children": ["记住我"]
                    }
                  ]
                },
                {
                  "type": "a-form-item",
                  "children": [
                    {
                      "type": "a-button",
                      "props": {
                        "type": { "type": "string", "body": "'primary'" },
                        "htmlType": { "type": "string", "body": "'submit'" },
                        "size": { "type": "string", "body": "'large'" },
                        "loading": { "type": "expression", "body": "{{ref_state_loading}}" },
                        "disabled": { "type": "expression", "body": "{{computed.submitDisabled.value}}" },
                        "block": { "type": "string", "body": "'true'" },
                        "class": { "type": "string", "body": "'login-button'" }
                      },
                      "children": [
                        { "type": "expression", "body": "{{ref_state_loading ? '登录中...' : '登录'}}" }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  },
  "styles": {
    "scoped": true,
    "css": ".login-container { min-height: 100vh; display: flex; justify-content: center; align-items: center; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 16px; } .login-content { width: 100%; max-width: 400px; background: #ffffff; border-radius: 8px; padding: 32px; box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15); } .login-header { text-align: center; margin-bottom: 32px; } .login-title { font-size: 24px; font-weight: 600; color: rgba(0, 0, 0, 0.85); margin: 0; line-height: 32px; } .login-form { width: 100%; } .login-error { margin-bottom: 24px; } .captcha-row { display: flex; align-items: center; gap: 8px; } .captcha-input { flex: 1; } .captcha-image { width: 120px; height: 40px; cursor: pointer; border-radius: 6px; border: 1px solid #d9d9d9; } .login-button { margin-top: 8px; }"
  }
}