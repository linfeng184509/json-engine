{
  "name": "DashboardPage",
  "state": {
    "user": {
      "type": "ref",
      "initial": null
    },
    "loading": {
      "type": "ref",
      "initial": true
    }
  },
  "computed": {
    "greeting": {
      "get": { "type": "function", "params": "{{{}}}", "body": "{{const hour = new Date().getHours(); if (hour < 12) return '早上好'; if (hour < 18) return '下午好'; return '晚上好';}}" }
    }
  },
  "methods": {
    "fetchUserInfo": { "type": "function", "params": "{{{}}}", "body": "{{const token = localStorage.getItem('enterprise_admin_token'); if (!token) { window.location.hash = '#/login'; return; } fetch('/api/user/info', { headers: { 'Authorization': 'Bearer ' + token } }).then(res => res.json()).then(data => { if (data.id) { ref_state_user = data; } else { window.location.hash = '#/login'; } }).catch(err => { console.error('Failed to fetch user info:', err); }).finally(() => { ref_state_loading = false; });}}" },
    "handleLogout": { "type": "function", "params": "{{{}}}", "body": "{{const token = localStorage.getItem('enterprise_admin_token'); if (token) { fetch('/api/auth/logout', { method: 'POST', headers: { 'Authorization': 'Bearer ' + token } }); } localStorage.removeItem('enterprise_admin_token'); window.location.hash = '#/login';}}" }
  },
  "lifecycle": {
    "onMounted": { "type": "function", "params": "{{{}}}", "body": "{{methods.fetchUserInfo();}}" }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "props": {
        "class": { "type": "string", "body": "'dashboard-container'" }
      },
      "children": [
        {
          "type": "a-layout",
          "props": {
            "class": { "type": "string", "body": "'dashboard-layout'" }
          },
          "children": [
            {
              "type": "a-layout-header",
              "props": {
                "class": { "type": "string", "body": "'dashboard-header'" }
              },
              "children": [
                {
                  "type": "div",
                  "props": {
                    "class": { "type": "string", "body": "'header-content'" }
                  },
                  "children": [
                    {
                      "type": "h2",
                      "props": {
                        "class": { "type": "string", "body": "'header-title'" }
                      },
                      "children": ["企业管理系统"]
                    },
                    {
                      "type": "div",
                      "props": {
                        "class": { "type": "string", "body": "'header-right'" }
                      },
                      "children": [
                        {
                          "type": "span",
                          "directives": {
                            "vIf": { "type": "expression", "body": "{{ref_state_user}}" }
                          },
                          "props": {
                            "class": { "type": "string", "body": "'user-name'" }
                          },
                          "children": [
                            { "type": "expression", "body": "{{ref_state_user?.nickname || ref_state_user?.username}}" }
                          ]
                        },
                        {
                          "type": "a-button",
                          "props": {
                            "type": { "type": "string", "body": "'link'" },
                            "class": { "type": "string", "body": "'logout-btn'" }
                          },
                          "directives": {
                            "vOn": {
                              "click": { "type": "function", "params": "{{{}}}", "body": "{{methods.handleLogout();}}" }
                            }
                          },
                          "children": ["退出登录"]
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "a-layout-content",
              "props": {
                "class": { "type": "string", "body": "'dashboard-content'" }
              },
              "children": [
                {
                  "type": "div",
                  "directives": {
                    "vIf": { "type": "expression", "body": "{{ref_state_loading}}" }
                  },
                  "props": {
                    "class": { "type": "string", "body": "'loading-container'" }
                  },
                  "children": [
                    {
                      "type": "a-spin",
                      "props": {
                        "size": { "type": "string", "body": "'large'" }
                      }
                    }
                  ]
                },
                {
                  "type": "div",
                  "directives": {
                    "vIf": { "type": "expression", "body": "{{!ref_state_loading && ref_state_user}}" }
                  },
                  "props": {
                    "class": { "type": "string", "body": "'welcome-section'" }
                  },
                  "children": [
                    {
                      "type": "h1",
                      "children": [
                        { "type": "expression", "body": "{{computed.greeting.value}}，" },
                        { "type": "expression", "body": "{{ref_state_user?.nickname || ref_state_user?.username}}！" }
                      ]
                    },
                    {
                      "type": "p",
                      "props": {
                        "class": { "type": "string", "body": "'welcome-desc'" }
                      },
                      "children": ["欢迎使用企业管理系统"]
                    },
                    {
                      "type": "a-card",
                      "props": {
                        "title": { "type": "string", "body": "'快速入口'" },
                        "class": { "type": "string", "body": "'quick-links'" }
                      },
                      "children": [
                        {
                          "type": "p",
                          "children": ["登录成功！这是一个演示页面。"]
                        },
                        {
                          "type": "p",
                          "children": ["测试账号: admin / admin123 或 user / user123"]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  },
  "styles": {
    "scoped": true,
    "css": ".dashboard-container { min-height: 100vh; background: #f0f2f5; } .dashboard-layout { min-height: 100vh; } .dashboard-header { background: #001529; padding: 0 24px; } .header-content { display: flex; justify-content: space-between; align-items: center; max-width: 1440px; margin: 0 auto; } .header-title { color: #ffffff; margin: 0; font-size: 18px; font-weight: 500; } .header-right { display: flex; align-items: center; gap: 16px; } .user-name { color: #ffffff; } .logout-btn { color: rgba(255, 255, 255, 0.85); } .dashboard-content { padding: 24px; max-width: 1440px; margin: 0 auto; } .loading-container { display: flex; justify-content: center; align-items: center; min-height: 400px; } .welcome-section h1 { font-size: 28px; font-weight: 600; color: rgba(0, 0, 0, 0.85); margin-bottom: 8px; } .welcome-desc { font-size: 14px; color: rgba(0, 0, 0, 0.45); margin-bottom: 24px; } .quick-links { margin-top: 24px; }"
  }
}