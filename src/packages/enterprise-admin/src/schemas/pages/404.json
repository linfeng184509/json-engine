{
  "name": "NotFoundPage",
  "methods": {
    "goHome": { "$fn": "window.location.hash = '#/';" }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "props": {
        "class": "not-found-container"
      },
      "children": [
        {
          "type": "AResult",
          "props": {
            "status": "404",
            "title": "页面未找到",
            "subTitle": "抱歉，您访问的页面不存在"
          },
          "children": [
            {
              "type": "template",
              "children": [
                {
                  "type": "AButton",
                  "props": {
                    "type": "primary",
                    "size": "large"
                  },
                  "directives": {
                    "vOn": {
                      "click": { "$fn": "methods.goHome();" }
                    }
                  },
                  "children": ["返回首页"]
                }
              ]
            }
          ]
        }
      ]
    }
  },
  "styles": {
    "scoped": true,
    "css": ".not-found-container { min-height: 100vh; display: flex; justify-content: center; align-items: center; background: #f5f5f5; }"
  }
}