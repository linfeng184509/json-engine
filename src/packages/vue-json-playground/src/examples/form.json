{
  "name": "DynamicForm",
  "props": {
    "formTitle": {
      "type": "String",
      "default": "Contact Form"
    }
  },
  "state": {
    "formData": {
      "type": "reactive",
      "initial": {
        "name": "",
        "email": "",
        "message": ""
      }
    },
    "errors": {
      "type": "reactive",
      "initial": {}
    },
    "isSubmitting": {
      "type": "ref",
      "initial": false
    }
  },
  "computed": {
    "isValid": {
      "get": { "type": "function", "params": "{{{}}}", "body": "{{return !state.errors.name && !state.errors.email && !state.errors.message && state.formData.name && state.formData.email && state.formData.message;}}" }
    }
  },
  "methods": {
    "validateName": { "type": "function", "params": "{{{}}}", "body": "{{if (!state.formData.name) { state.errors.name = 'Name is required'; } else { state.errors.name = ''; }}}" },
    "validateEmail": { "type": "function", "params": "{{{}}}", "body": "{{const emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/; if (!state.formData.email) { state.errors.email = 'Email is required'; } else if (!emailRegex.test(state.formData.email)) { state.errors.email = 'Invalid email format'; } else { state.errors.email = ''; }}}" },
    "validateMessage": { "type": "function", "params": "{{{}}}", "body": "{{if (!state.formData.message) { state.errors.message = 'Message is required'; } else if (state.formData.message.length < 10) { state.errors.message = 'Message must be at least 10 characters'; } else { state.errors.message = ''; }}}" },
    "handleSubmit": { "type": "function", "params": "{{{}}}", "body": "{{methods.validateName(); methods.validateEmail(); methods.validateMessage(); if (computed.isValid.value) { state.isSubmitting.value = true; setTimeout(() => { alert('Form submitted: ' + JSON.stringify(state.formData)); state.isSubmitting.value = false; }, 1000); }}}" },
    "resetForm": { "type": "function", "params": "{{{}}}", "body": "{{state.formData.name = ''; state.formData.email = ''; state.formData.message = ''; state.errors.name = ''; state.errors.email = ''; state.errors.message = '';}}" }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "form",
      "props": {
        "class": { "type": "string", "body": "'dynamic-form'" }
      },
      "directives": {
        "vOn": {
          "submit.prevent": { "type": "function", "params": "{{{}}}", "body": "{{methods.handleSubmit();}}" }
        }
      },
      "children": [
        {
          "type": "h2",
          "children": [
            { "type": "expression", "body": "{{ref_props_formTitle}}" }
          ]
        },
        {
          "type": "div",
          "props": {
            "class": { "type": "string", "body": "'form-group'" }
          },
          "children": [
            {
              "type": "label",
              "props": {
                "for": { "type": "string", "body": "'name'" }
              },
              "children": ["Name:"]
            },
            {
              "type": "input",
              "props": {
                "id": { "type": "string", "body": "'name'" },
                "type": { "type": "string", "body": "'text'" }
              },
              "directives": {
                "vModel": {
                  "prop": { "type": "state", "body": "{{ref_state_formData}}" }
                },
                "vOn": {
                  "blur": { "type": "function", "params": "{{{}}}", "body": "{{methods.validateName();}}" }
                }
              }
            },
            {
              "type": "span",
              "props": {
                "class": { "type": "string", "body": "'error'" }
              },
              "directives": {
                "vIf": { "type": "expression", "body": "{{state.errors.name}}" }
              },
              "children": [
                { "type": "expression", "body": "{{state.errors.name}}" }
              ]
            }
          ]
        },
        {
          "type": "div",
          "props": {
            "class": { "type": "string", "body": "'form-group'" }
          },
          "children": [
            {
              "type": "label",
              "props": {
                "for": { "type": "string", "body": "'email'" }
              },
              "children": ["Email:"]
            },
            {
              "type": "input",
              "props": {
                "id": { "type": "string", "body": "'email'" },
                "type": { "type": "string", "body": "'email'" }
              },
              "directives": {
                "vModel": {
                  "prop": { "type": "state", "body": "{{ref_state_formData}}" }
                },
                "vOn": {
                  "blur": { "type": "function", "params": "{{{}}}", "body": "{{methods.validateEmail();}}" }
                }
              }
            },
            {
              "type": "span",
              "props": {
                "class": { "type": "string", "body": "'error'" }
              },
              "directives": {
                "vIf": { "type": "expression", "body": "{{state.errors.email}}" }
              },
              "children": [
                { "type": "expression", "body": "{{state.errors.email}}" }
              ]
            }
          ]
        },
        {
          "type": "div",
          "props": {
            "class": { "type": "string", "body": "'form-group'" }
          },
          "children": [
            {
              "type": "label",
              "props": {
                "for": { "type": "string", "body": "'message'" }
              },
              "children": ["Message:"]
            },
            {
              "type": "textarea",
              "props": {
                "id": { "type": "string", "body": "'message'" },
                "rows": { "type": "string", "body": "'4'" }
              },
              "directives": {
                "vModel": {
                  "prop": { "type": "state", "body": "{{ref_state_formData}}" }
                },
                "vOn": {
                  "blur": { "type": "function", "params": "{{{}}}", "body": "{{methods.validateMessage();}}" }
                }
              }
            },
            {
              "type": "span",
              "props": {
                "class": { "type": "string", "body": "'error'" }
              },
              "directives": {
                "vIf": { "type": "expression", "body": "{{state.errors.message}}" }
              },
              "children": [
                { "type": "expression", "body": "{{state.errors.message}}" }
              ]
            }
          ]
        },
        {
          "type": "div",
          "props": {
            "class": { "type": "string", "body": "'form-actions'" }
          },
          "children": [
            {
              "type": "button",
              "props": {
                "type": { "type": "string", "body": "'submit'" },
                "disabled": { "type": "expression", "body": "{{ref_state_isSubmitting}}" }
              },
              "children": [
                { "type": "expression", "body": "{{state.isSubmitting.value ? 'Submitting...' : 'Submit'}}" }
              ]
            },
            {
              "type": "button",
              "props": {
                "type": { "type": "string", "body": "'button'" }
              },
              "directives": {
                "vOn": {
                  "click": { "type": "function", "params": "{{{}}}", "body": "{{methods.resetForm();}}" }
                }
              },
              "children": ["Reset"]
            }
          ]
        }
      ]
    }
  },
  "styles": {
    "scoped": true,
    "css": ".dynamic-form { max-width: 500px; margin: 0 auto; padding: 20px; } h2 { margin-bottom: 20px; } .form-group { margin-bottom: 15px; } label { display: block; margin-bottom: 5px; font-weight: bold; } input, textarea { width: 100%; padding: 8px; border: 1px solid #ccc; border-radius: 4px; } .error { color: red; font-size: 12px; } .form-actions { margin-top: 20px; } button { margin-right: 10px; padding: 10px 20px; cursor: pointer; } button:disabled { opacity: 0.5; cursor: not-allowed; }"
  }
}