{
  "name": "TodoList",
  "props": {
    "title": {
      "type": "String",
      "default": "My Todo List"
    }
  },
  "state": {
    "todos": {
      "type": "ref",
      "initial": []
    },
    "newTodo": {
      "type": "ref",
      "initial": ""
    },
    "filter": {
      "type": "ref",
      "initial": "all"
    }
  },
  "computed": {
    "filteredTodos": {
      "get": { "type": "function", "params": "{{{}}}", "body": "{{const todos = ref_state_todos; const filter = ref_state_filter; if (filter === 'all') return todos; if (filter === 'active') return todos.filter(t => !t.completed); if (filter === 'completed') return todos.filter(t => t.completed); return todos;}}" }
    },
    "remainingCount": {
      "get": { "type": "function", "params": "{{{}}}", "body": "{{return ref_state_todos.filter(t => !t.completed).length;}}" }
    }
  },
  "methods": {
    "addTodo": { "type": "function", "params": "{{{}}}", "body": "{{if (ref_state_newTodo.trim()) { ref_state_todos.push({ id: Date.now(), text: ref_state_newTodo.trim(), completed: false }); ref_state_newTodo = ''; }}}" },
    "removeTodo": { "type": "function", "params": "{{{}}}", "body": "{{ref_state_todos = ref_state_todos.filter(t => t.id !== args[0]);}}" },
    "toggleTodo": { "type": "function", "params": "{{{}}}", "body": "{{const todo = ref_state_todos.find(t => t.id === args[0]); if (todo) todo.completed = !todo.completed;}}" },
    "setFilter": { "type": "function", "params": "{{{}}}", "body": "{{ref_state_filter = args[0];}}" }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "props": {
        "class": { "type": "string", "body": "'todo-list'" }
      },
      "children": [
        {
          "type": "h2",
          "children": [
            { "type": "expression", "body": "{{ref_props_title}}" }
          ]
        },
        {
          "type": "div",
          "props": {
            "class": { "type": "string", "body": "'input-group'" }
          },
          "children": [
            {
              "type": "input",
              "directives": {
                "vModel": {
                  "prop": { "type": "state", "body": "{{ref_state_newTodo}}" }
                }
              },
              "props": {
                "type": { "type": "string", "body": "'text'" },
                "placeholder": { "type": "string", "body": "'Add a new todo...'" }
              }
            },
            {
              "type": "button",
              "directives": {
                "vOn": {
                  "click": { "type": "function", "params": "{{{}}}", "body": "{{methods.addTodo();}}" }
                }
              },
              "children": ["Add"]
            }
          ]
        },
        {
          "type": "div",
          "props": {
            "class": { "type": "string", "body": "'filters'" }
          },
          "children": [
            {
              "type": "button",
              "directives": {
                "vOn": {
                  "click": { "type": "function", "params": "{{{}}}", "body": "{{methods.setFilter('all');}}" }
                }
              },
              "children": ["All"]
            },
            {
              "type": "button",
              "directives": {
                "vOn": {
                  "click": { "type": "function", "params": "{{{}}}", "body": "{{methods.setFilter('active');}}" }
                }
              },
              "children": ["Active"]
            },
            {
              "type": "button",
              "directives": {
                "vOn": {
                  "click": { "type": "function", "params": "{{{}}}", "body": "{{methods.setFilter('completed');}}" }
                }
              },
              "children": ["Completed"]
            }
          ]
        },
        {
          "type": "ul",
          "children": [
            {
              "type": "li",
              "directives": {
                "vFor": {
                  "source": { "type": "expression", "body": "{{ref_computed_filteredTodos}}" },
                  "alias": "todo"
                }
              },
              "children": [
                {
                  "type": "input",
                  "props": {
                    "type": { "type": "string", "body": "'checkbox'" }
                  },
                  "directives": {
                    "vBind": {
                      "checked": { "type": "expression", "body": "{{todo.completed}}" }
                    },
                    "vOn": {
                      "change": { "type": "function", "params": "{{{}}}", "body": "{{methods.toggleTodo(todo.id);}}" }
                    }
                  }
                },
                {
                  "type": "span",
                  "directives": {
                    "vBind": {
                      "style": { "type": "expression", "body": "{{todo.completed ? 'text-decoration: line-through' : ''}}" }
                    }
                  },
                  "children": [
                    { "type": "expression", "body": "{{todo.text}}" }
                  ]
                },
                {
                  "type": "button",
                  "directives": {
                    "vOn": {
                      "click": { "type": "function", "params": "{{{}}}", "body": "{{methods.removeTodo(todo.id);}}" }
                    }
                  },
                  "children": ["x"]
                }
              ]
            }
          ]
        },
        {
          "type": "p",
          "children": [
            { "type": "expression", "body": "{{ref_computed_remainingCount}}" },
            " items left"
          ]
        }
      ]
    }
  },
  "styles": {
    "scoped": true,
    "css": ".todo-list { max-width: 500px; margin: 0 auto; padding: 20px; } .input-group { display: flex; gap: 10px; margin-bottom: 20px; } input[type='text'] { flex: 1; padding: 8px; } button { padding: 8px 16px; cursor: pointer; } .filters { margin-bottom: 15px; } .filters button { margin-right: 5px; } li { display: flex; align-items: center; gap: 10px; margin: 5px 0; }"
  }
}