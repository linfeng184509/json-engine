{
  "name": "Counter",
  "props": {
    "initialCount": {
      "type": "Number",
      "default": 0
    }
  },
  "state": {
    "count": {
      "type": "ref",
      "initial": { "type": "props", "body": "{{ref_props_initialCount}}" }
    }
  },
  "computed": {
    "doubleCount": {
      "get": { "type": "function", "params": "{{{}}}", "body": "{{return state.count.value * 2;}}" }
    }
  },
  "methods": {
    "increment": { "type": "function", "params": "{{{}}}", "body": "{{state.count.value++;}}" },
    "decrement": { "type": "function", "params": "{{{}}}", "body": "{{state.count.value--;}}" },
    "reset": { "type": "function", "params": "{{{}}}", "body": "{{state.count.value = props.initialCount;}}" }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "props": {
        "class": { "type": "string", "body": "'counter'" }
      },
      "children": [
        { "type": "h2", "children": "Counter Example" },
        {
          "type": "p",
          "children": [
            "Count: ",
            { "type": "expression", "body": "{{ref_state_count}}" }
          ]
        },
        {
          "type": "p",
          "children": [
            "Double: ",
            { "type": "expression", "body": "{{ref_computed_doubleCount}}" }
          ]
        },
        {
          "type": "div",
          "children": [
            {
              "type": "button",
              "directives": {
                "vOn": {
                  "click": { "type": "function", "params": "{{{}}}", "body": "{{methods.decrement();}}" }
                }
              },
              "children": "-"
            },
            {
              "type": "button",
              "directives": {
                "vOn": {
                  "click": { "type": "function", "params": "{{{}}}", "body": "{{methods.reset();}}" }
                }
              },
              "children": "Reset"
            },
            {
              "type": "button",
              "directives": {
                "vOn": {
                  "click": { "type": "function", "params": "{{{}}}", "body": "{{methods.increment();}}" }
                }
              },
              "children": "+"
            }
          ]
        }
      ]
    }
  },
  "styles": {
    "scoped": true,
    "css": ".counter { padding: 20px; text-align: center; } button { margin: 5px; padding: 8px 16px; font-size: 16px; cursor: pointer; } h2 { color: #333; }"
  }
}