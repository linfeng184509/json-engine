{
  "name": "Counter",
  "props": {
    "initialCount": {
      "type": "Number",
      "default": 0
    }
  },
  "state": {
    "count": {
      "type": "ref",
      "initial": "{{ref_props_initialCount}}"
    }
  },
  "computed": {
    "doubleCount": {
      "get": "return ref_state_count * 2;"
    }
  },
  "methods": {
    "increment": "ref_state_count.value++;",
    "decrement": "ref_state_count.value--;",
    "reset": "ref_state_count.value = ref_props_initialCount;"
  },
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "props": {
        "class": "counter"
      },
      "children": [
        {
          "type": "h2",
          "children": ["Counter Example"]
        },
        {
          "type": "p",
          "children": ["Count: ", { "type": "text", "content": "{{ref_state_count}}" }]
        },
        {
          "type": "p",
          "children": ["Double: ", { "type": "text", "content": "{{ref_computed_doubleCount}}" }]
        },
        {
          "type": "div",
          "children": [
            {
              "type": "button",
              "directives": {
                "vOn": {
                  "click": "methods.decrement();"
                }
              },
              "children": ["-"]
            },
            {
              "type": "button",
              "directives": {
                "vOn": {
                  "click": "methods.reset();"
                }
              },
              "children": ["Reset"]
            },
            {
              "type": "button",
              "directives": {
                "vOn": {
                  "click": "methods.increment();"
                }
              },
              "children": ["+"]
            }
          ]
        }
      ]
    }
  },
  "styles": {
    "scoped": true,
    "css": ".counter { padding: 20px; text-align: center; } button { margin: 5px; padding: 8px 16px; font-size: 16px; cursor: pointer; } h2 { color: #333; }"
  }
}