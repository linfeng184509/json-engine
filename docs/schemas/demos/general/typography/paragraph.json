{
  "name": "TypographyParagraphDemo",
  "render": {
    "type": "template",
    "content": {
      "type": "ATypography",
      "children": [
        { "type": "ATypographyParagraph", "children": ["This is a paragraph."] },
        { "type": "ATypographyParagraph", "props": { "copyable": true }, "children": ["This is a copyable paragraph."] },
        { "type": "ATypographyParagraph", "props": { "ellipsis": true }, "children": ["Ant Design, a design language for background applications, is refined by Ant UED Team. This is a paragraph with ellipsis that will be truncated when it exceeds the container width."] }
      ]
    }
  }
}