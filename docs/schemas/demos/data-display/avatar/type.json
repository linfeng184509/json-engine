{
  "name": "AvatarTypeDemo",
  "render": {
    "type": "template",
    "content": {
      "type": "ASpace",
      "props": { "size": 16, "wrap": true },
      "children": [
        { "type": "AAvatar", "children": [{ "type": "UserOutlined", "directives": { "vSlot": { "name": "icon" } } }] },
        { "type": "AAvatar", "children": ["U"] },
        { "type": "AAvatar", "props": { "size": 40 }, "children": ["USER"] },
        { "type": "AAvatar", "props": { "src": "https://www.antdv.com/assets/logo.1ef800a8.svg" } },
        { "type": "AAvatar", "props": { "style": "color:#f56a00;background-color:#fde3cf" }, "children": ["U"] },
        { "type": "AAvatar", "props": { "style": "background-color:#87d068" }, "children": [{ "type": "UserOutlined", "directives": { "vSlot": { "name": "icon" } } }] }
      ]
    }
  }
}
