{
  "name": "CardMetaDemo",
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        {
          "type": "h3",
          "children": ["Card Meta"]
        },
        {
          "type": "ASpace",
          "props": { "size": 16 },
          "children": [
            {
              "type": "ACard",
              "props": { "hoverable": true, "style": "width:240px" },
              "children": [
                {
                  "type": "template",
                  "directives": { "vSlot": { "name": "cover" } },
                  "children": [
                    { "type": "img", "props": { "alt": "example", "src": "https://via.placeholder.com/240x180" } }
                  ]
                },
                {
                  "type": "ACardMeta",
                  "props": {
                    "title": "Card Title",
                    "description": "This is the description"
                  }
                }
              ]
            },
            {
              "type": "ACard",
              "props": { "hoverable": true, "style": "width:240px" },
              "children": [
                {
                  "type": "ACardMeta",
                  "props": {
                    "title": "Card Title",
                    "description": "This is the description",
                    "avatar": { "type": "AAvatar", "props": { "src": "https://via.placeholder.com/40" } }
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  }
}