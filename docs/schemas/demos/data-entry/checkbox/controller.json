{
  "name": "CheckboxControllerDemo",
  "state": {
    "checked": { "type": "ref", "initial": false },
    "disabled": { "type": "ref", "initial": false }
  },
  "computed": {
    "label": {
      "get": {
        "$fn": "(state.checked ? 'Checked' : 'Unchecked') + '-' + (state.disabled ? 'Disabled' : 'Enabled')"
      }
    }
  },
  "methods": {
    "toggleChecked": {
      "$fn": "state.checked = !state.checked;"
    },
    "toggleDisable": {
      "$fn": "state.disabled = !state.disabled;"
    }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        {
          "type": "p",
          "props": { "style": "margin-bottom:20px" },
          "children": [
            {
              "type": "ACheckbox",
              "directives": {
                "vModel": {
                  "prop": { "$ref": "state.checked" },
                  "arg": "checked"
                }
              },
              "props": {
                "disabled": { "$expr": "$state.disabled" }
              },
              "children": [{ "$expr": "$computed.label" }]
            }
          ]
        },
        {
          "type": "p",
          "children": [
            {
              "type": "AButton",
              "props": { "type": "primary", "size": "small" },
              "directives": { "vOn": { "click": { "$fn": "methods.toggleChecked();" } } },
              "children": [{ "$expr": "!state.checked ? 'Check' : 'Uncheck'" }]
            },
            {
              "type": "AButton",
              "props": { "type": "primary", "size": "small", "style": "margin-left:10px" },
              "directives": { "vOn": { "click": { "$fn": "methods.toggleDisable();" } } },
              "children": [{ "$expr": "!state.disabled ? 'Disable' : 'Enable'" }]
            }
          ]
        }
      ]
    }
  }
}
