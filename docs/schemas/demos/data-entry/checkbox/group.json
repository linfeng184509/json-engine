{
  "name": "CheckboxGroupDemo",
  "state": {
    "value1": { "type": "ref", "initial": [] },
    "value2": { "type": "ref", "initial": ["Apple"] },
    "value3": { "type": "ref", "initial": ["Pear"] },
    "value4": { "type": "ref", "initial": ["Apple"] },
    "plainOptions": { "type": "ref", "initial": ["Apple", "Pear", "Orange"] },
    "options": { "type": "ref", "initial": [{ "label": "Apple", "value": "Apple" }, { "label": "Pear", "value": "Pear" }, { "label": "Orange", "value": "Orange" }] },
    "optionsWithDisabled": { "type": "ref", "initial": [{ "label": "Apple", "value": "Apple" }, { "label": "Pear", "value": "Pear" }, { "label": "Orange", "value": "Orange", "disabled": false }] }
  },
  "render": {
    "type": "template",
    "content": {
      "type": "div",
      "children": [
        {
          "type": "ACheckboxGroup",
          "props": { "options": { "$expr": "$state.plainOptions" }, "name": "checkboxgroup" },
          "directives": {
            "vModel": {
              "prop": { "$ref": "state.value1" },
              "arg": "value"
            }
          }
        },
        { "type": "br" },
        { "type": "br" },
        {
          "type": "ACheckboxGroup",
          "props": { "options": { "$expr": "$state.plainOptions" } },
          "directives": {
            "vModel": {
              "prop": { "$ref": "state.value2" },
              "arg": "value"
            }
          }
        },
        { "type": "br" },
        { "type": "br" },
        {
          "type": "ACheckboxGroup",
          "props": { "options": { "$expr": "$state.options" } },
          "directives": {
            "vModel": {
              "prop": { "$ref": "state.value3" },
              "arg": "value"
            }
          }
        },
        { "type": "br" },
        { "type": "br" },
        {
          "type": "ACheckboxGroup",
          "props": { "options": { "$expr": "$state.optionsWithDisabled" }, "disabled": true },
          "directives": {
            "vModel": {
              "prop": { "$ref": "state.value4" },
              "arg": "value"
            }
          }
        }
      ]
    }
  }
}
